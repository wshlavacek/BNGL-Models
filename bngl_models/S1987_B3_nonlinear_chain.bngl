begin model
#@model_id: S1987_B3_nonlinear_chain
#@title: Nonlinear chemical reaction chain
#@description: Three-species nonlinear chain dZ1/dt = -Z1, dZ2/dt = Z1 - Z2^2, dZ3/dt = Z2^2. From Savageau & Voit (1987) Problem B3.
#@organism: other
#@authors: unknown
#@created: 2026-03-08
#@modified: 2026-03-08
#@bng_version: >=2.9.3
#@units_convention: population-based; molecule counts
#@runtime_expectation: ~<1 min typical runs
#@license: CC-BY-4.0
#@house_style_version: 0.1
#@source: from_antimony

begin parameters
  NA       6.02214076e23  # 1/mol
  V_ref    1.0            # L
  f        1.0            # dimensionless
  S        100            # dimensionless; scale factor

  k_decay  1.0            # 1/s; first-order decay of Z1
  k_transfer 1.0          # 1/s; first-order transfer Z1 -> Z2
  k_quad   1.0            # 1/(molecules*s); quadratic consumption/production rate (1/S)
end parameters

begin molecule types
  Z1()
  Z2()
  Z3()
end molecule types

begin seed species
  Z1()  100  # molecules (Z1(0)=1 scaled x100)
  Z2()    0  # molecules (Z2(0)=0)
  Z3()    0  # molecules (Z3(0)=0)
end seed species

begin observables
  Molecules  Obs_Z1  Z1()
  Molecules  Obs_Z2  Z2()
  Molecules  Obs_Z3  Z3()
end observables

begin functions
  # dZ1/dt = -Z1  =>  consumption at rate k_decay*Z1
  # dZ2/dt = Z1 - Z2^2  =>  production from Z1 at rate k_transfer, consumption (k_quad/S)*Z2^2
  # dZ3/dt = Z2^2  =>  production at rate (k_quad/S)*Z2^2
  rate_quad_consume() = (k_quad / S) * Obs_Z2 * Obs_Z2
  rate_quad_produce() = (k_quad / S) * Obs_Z2 * Obs_Z2
end functions

begin reaction rules
  # Z1 first-order decay
  Z1() -> Z2()  k_transfer

  # Z2 quadratic consumption: Z2^2 term removes Z2
  Z2() -> 0  rate_quad_consume()

  # Z2^2 produces Z3
  0 -> Z3()  rate_quad_produce()
end reaction rules

end model

begin actions
  generate_network({overwrite=>1})

  simulate({method=>"ode",suffix=>"ode",t_start=>0,t_end=>20,n_steps=>400})
  simulate({method=>"ssa",suffix=>"ssa",t_start=>0,t_end=>20,n_steps=>400})
  simulate({method=>"nf",suffix=>"nfr",t_start=>0,t_end=>20,n_steps=>400,complex=>1})
end actions
