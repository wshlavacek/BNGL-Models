## (EGFR-EGFR dimers)(992,1068,1086,1114,1148,1173)
## (ErbB2-EGFR dimers)(992,1068,1086,1114,1148,1173)
## (ErbB4-EGFR dimers)(992,1068,1086,1114,1148,1173)

## ErbB2
## (EGFR-ErbB2 dimers)(1139,1196,1222,1248)
## (ErbB4-ErbB2 dimers)(1139,1196,1222,1248)

## ErbB3
## (EGFR-ErbB3 dimers)(1054,1197,1222,Y1260,1276,1289,1328)
## (ErbB2-ErbB3 dimers)(1054,1197,1222,Y1260,1276,1289,1328)
## (ErbB4-ErbB3 dimers)(1054,1197,1222,Y1260,1276,1289,1328)

## ErbB4
## (EGFR-ErbB4 dimers)(1056,1188,1242)
## (ErbB2-ErbB4 dimers)(1056,1188,1242)
## (ErbB4-ErbB4 dimers)(1056,1188,1242)

## -----------------------------------------

# cross-phosphorylation of EGFR
