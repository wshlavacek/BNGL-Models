# Ras activation by Sos
# REM domain unbound
222 Sos1(REM,GEF!3,S1132~O,S1167~O,S1178~O,S1193~O).KRas(GTPase!3,g~GDP) <-> Sos1(REM,GEF!3,S1132~O,S1167~O,S1178~O,S1193~O).KRas(GTPase!3,g~GTP)     Sos1kp5,Sos1km5

# Ras activation by Sos
# REM domain bound to Ras-GTP, this is a positive feedback loop which increases Ras activation
223 Sos1(REM!+,GEF!3,S1132~O,S1167~O,S1178~O,S1193~O).KRas(GTPase!3,g~GDP) <-> Sos1(REM!+,GEF!3,S1132~O,S1167~O,S1178~O,S1193~O).KRas(GTPase!3,g~GTP)     Sos1kp6,Sos1km6

