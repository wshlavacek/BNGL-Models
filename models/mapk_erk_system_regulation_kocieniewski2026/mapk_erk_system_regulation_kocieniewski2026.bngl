  #Species  CC_dim_no_cross_L    RAF(iso~C,dif!7,C_ftt!5).RAF(iso~C,dif!7,C_ftt).FTT(raf!5,dim!9).FTT(raf,dim!9)
  #Species  CC_dim_no_cross_R    RAF(iso~C,dif!7,C_ftt).RAF(iso~C,dif!7,C_ftt!6).FTT(raf,dim!9).FTT(raf!6,dim!9)
  #Species  CC_dim_noFTT         RAF(iso~C,dif!7,C_ftt).RAF(iso~C,dif!7,C_ftt)
  #Species  CC_dim_FF            RAF(iso~C,dif!7,C_ftt!5).RAF(iso~C,dif!7,C_ftt!6).FTT(raf!5,dim!9).FTT(dim!9,raf).FTT(raf!6,dim!10).FTT(dim!10,raf)
  #Species  CC_dim_free          RAF(iso~C,ras,dif!7).RAF(iso~C,ras,dif!7)

