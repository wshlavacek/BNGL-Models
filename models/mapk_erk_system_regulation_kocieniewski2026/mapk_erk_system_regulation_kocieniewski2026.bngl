  #Species  AC_dim_noFTT         RAF(iso~A,dif!7,C_ftt).RAF(iso~C,dif!7,C_ftt)
  #Species  AC_dim_FF            RAF(iso~A,dif!7,C_ftt!5).RAF(iso~C,dif!7,C_ftt!6).FTT(raf!5,dim!9).FTT(dim!9,raf).FTT(raf!6,dim!10).FTT(dim!10,raf)
  #Species  AC_dim_free          RAF(iso~A,ras,dif!7).RAF(iso~C,ras,dif!7)

  #Species  AA_dim_cross         RAF(iso~A,dif!7,C_ftt!5).RAF(iso~A,dif!7,C_ftt!6).FTT(raf!5,dim!9).FTT(raf!6,dim!9)
  #Species  AA_dim_no_cross_L    RAF(iso~A,dif!7,C_ftt!5).RAF(iso~A,dif!7,C_ftt).FTT(raf!5,dim!9).FTT(raf,dim!9)
  #Species  AA_dim_no_cross_R    RAF(iso~A,dif!7,C_ftt).RAF(iso~A,dif!7,C_ftt!6).FTT(raf,dim!9).FTT(raf!6,dim!9)
  #Species  AA_dim_noFTT         RAF(iso~A,dif!7,C_ftt).RAF(iso~A,dif!7,C_ftt)
  #Species  AA_dim_FF            RAF(iso~A,dif!7,C_ftt!5).RAF(iso~A,dif!7,C_ftt!6).FTT(raf!5,dim!9).FTT(dim!9,raf).FTT(raf!6,dim!10).FTT(dim!10,raf)
  #Species  AA_dim_free          RAF(iso~A,ras,dif!7).RAF(iso~A,ras,dif!7)

  # Miscellaneous RAF & 14-3-3 species
  #Molecules  B_Np_FTT_mono      RAF(iso~B,dif,N_ftt!1,C_ftt).FTT(raf!1)
  #Molecules  B_noFTT            RAF(iso~B,N_ftt,C_ftt)
  #Molecules  B_noFTT_mono       RAF(iso~B,dif,N_ftt,C_ftt)
  #Molecules  B_open             RAF(iso~B,N_ftt!+,dif,C_ftt) RAF(iso~B,N_ftt,dif,C_ftt!+) RAF(iso~B,N_ftt,dif,C_ftt)
  #Molecules  B_closed           RAF(iso~B,N_ftt!1,C_ftt!2).FTT(raf!1,dim!9).FTT(raf!2,dim!9)
  #Species    B_RAS              RAF(iso~B,ras!+)

  #Molecules  C_Cp_FTT_mono      RAF(iso~C,dif,N_ftt,C_ftt!1).FTT(raf!1)
  #Molecules  C_noFTT            RAF(iso~C,N_ftt,C_ftt)
  #Molecules  C_noFTT_mono       RAF(iso~C,dif,N_ftt,C_ftt)
  #Molecules  C_closed           RAF(iso~C,dif,N_ftt!4,C_ftt!5).FTT(raf!4,dim!9).FTT(raf!5,dim!9)
  #Molecules  C_open             RAF(iso~C,dif,N_ftt!+,C_ftt) RAF(iso~C,dif,N_ftt,C_ftt!+) RAF(iso~C,dif,N_ftt,C_ftt)
  #Molecules  C_RAS_mono         RAF(iso~C,ras!+,dif)
  #Molecules  C_RAS_mono_N_P0    RAF(iso~C,ras!+,dif,N_ftt~P0)
  #Molecules  C_RAS_dim_no_cross RAF(iso~C,ras!+,dif!+,N_ftt~P0,C_ftt)
  #Molecules  C_RAS_dim_cross    RAF(iso~C,ras!+,dif!+,N_ftt~P0,C_ftt!5).FTT(raf!+,dim!9).FTT(raf!5,dim!9)
  #Species    C_RAS              RAF(iso~C,ras!+)

  #Molecules  A_Cp_FTT_mono      RAF(iso~A,dif,N_ftt,C_ftt!1).FTT(raf!1)
  #Molecules  A_noFTT            RAF(iso~A,N_ftt,C_ftt)
  #Molecules  A_noFTT_mono       RAF(iso~A,dif,N_ftt,C_ftt)
  #Molecules  A_closed           RAF(iso~A,dif,N_ftt!1,C_ftt!2).FTT(raf!1,dim!9).FTT(raf!2,dim!9)
  #Molecules  A_open             RAF(iso~A,dif,N_ftt!+,C_ftt) RAF(iso~A,dif,N_ftt,C_ftt!+) RAF(iso~A,dif,N_ftt,C_ftt)
  #Molecules  A_RAS_mono         RAF(iso~A,ras!+,dif)
  #Molecules  A_RAS_mono_N_P0    RAF(iso~A,ras!+,dif,N_ftt~P0)
  #Molecules  A_RAS_dim_no_cross RAF(iso~A,ras!+,dif!+,N_ftt~P0,C_ftt)
  #Molecules  A_RAS_dim_cross    RAF(iso~A,ras!+,dif!+,N_ftt~P0,C_ftt!5).FTT(raf!+,dim!9).FTT(raf!5,dim!9)
  #Species    A_RAS              RAF(iso~A,ras!+)

  # For comparison with experiment (BRAF IP): levels of CRAF--BRAF dimers
  #Molecules  BRAF_IP_CRAF_tot   RAF(iso~B,dif!7).RAF(iso~C,dif!7)
  #Molecules  BRAF_IP_CRAF_S621p RAF(iso~B,dif!7).RAF(iso~C,dif!7,C_ftt~P1!?)
  #Molecules  BRAF_IP_CRAF_S338p RAF(iso~B,dif!7).RAF(iso~C,dif!7,NtA~P1!?)
  #Molecules  BRAF_IP_CRAF_DIFp  RAF(iso~B,dif!7).RAF(iso~C,dif~P1!7)

  # For comparison with experiment: levels of CRAF phosphorylated at specific serines
  #Molecules  CRAF_S259p_LYS     RAF(iso~C,N_ftt~P1!?)
  #Molecules  CRAF_S621p_LYS     RAF(iso~C,C_ftt~P1!?)
  #Molecules  CRAF_DIFp_LYS      RAF(iso~C,dif~P1!?)
  #Molecules  CRAF_S338p_LYS     RAF(iso~C,NtA~P1!?)

  # For comparison with experiment: levels of CRAF phosphorylated at specific serines
  #Molecules  ARAF_S214p_LYS     RAF(iso~A,N_ftt~P1!?)
  #Molecules  ARAF_S582p_LYS     RAF(iso~A,C_ftt~P1!?)
  #Molecules  ARAF_DIFp_LYS      RAF(iso~A,dif~P1!?)
  #Molecules  ARAF_S299p_LYS     RAF(iso~A,NtA~P1!?)

  # For comparison with experiment: levels of BRAF phosphorylated at specific serines
  #Molecules  BRAF_S356p_LYS     RAF(iso~B,N_ftt~P1!?)
  #Molecules  BRAF_S729p_LYS     RAF(iso~B,C_ftt~P1!?)
  #Molecules  BRAF_DIFp_LYS      RAF(iso~B,dif~P1!?)
  #Molecules  BRAF_S446p_LYS     RAF(iso~B,NtA~P1!?)

  # Total Species
  #Molecules EGFR_TOT    EGFR()
  #Molecules SOS_TOT     SOS()
  #Molecules RAS_TOT     RAS()
  #Molecules BRAF_TOT    RAF(iso~B)
  #Molecules CRAF_TOT    RAF(iso~C)
  #Molecules ARAF_TOT    RAF(iso~A)
  #Molecules MEK1_TOT    MEK(iso~mek1)
  #Molecules MEK2_TOT    MEK(iso~mek2)
  #Molecules ERK_TOT     ERK()
  #Molecules RasGAP_TOT  RasGAP()
  #Molecules FTT_TOT     FTT()

end observables

begin reaction rules

  # ===== Processes relevant to the unstimulated cell quiescent state ==========

  # +++ BRAF +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
  # (DE)PHOSPHORYLATION OF THE N_TERMINAL 14-3-3 BINDING SITE (FB)-------------

    # (B)(+) phosphorylation of cytoplasmic BRAF at S365 (BRAF secondary 14-3-3 binding site); only when 14-3-3 not bound to this site

      RAF(iso~B,ras,N_ftt~P0,dif) -> \
      RAF(iso~B,ras,N_ftt~P1,dif)  p_B_S365

    # (B)(-) dephosphorylation of cytoplasmic BRAF pS365 (BRAF secondary 14-3-3 binding site); only when 14-3-3 not bound

      RAF(iso~B,ras,N_ftt~P1) -> \
      RAF(iso~B,ras,N_ftt~P0)  q_B_S365p

  # RAF BINDIND AND DISSOCIATION WITH C-TERMINAL FTT BINDING SITE (N_ftt)
    # (B) BRAF & free 14-3-3 binding at S729

      RAF(iso~B,N_ftt,C_ftt~P1) + FTT(raf,dim!9).FTT(iso~A,raf,dim!9) -> \
      RAF(iso~B,N_ftt,C_ftt~P1!5).FTT(raf,dim!9).FTT(iso~A,raf!5,dim!9)   b_FB_S729p

    # (B) BRAF--14-3-3 dissociation at S729

      RAF(iso~B,C_ftt!5).FTT(raf,dim!9).FTT(raf!5,dim!9) -> \
      RAF(iso~B,C_ftt) + FTT(raf,dim!9).FTT(raf,dim!9)    u_FB_S729p

  #BRAF (DE)CROSSLINKING (C-->N) - 14-3-3 BOUND TO N_FTT ----------------------------------------------
    # (B) BRAF & 14-3-3 binding  (BRAF crosslinking from C-terminus to N-terminus) (NtA~P0)

      RAF(iso~B,ras,N_ftt~P1,dif,C_ftt!5,NtA~P0).FTT(iso~A,raf,dim!9).FTT(raf!5,dim!9) -> \
      RAF(iso~B,ras,N_ftt~P1!4,dif,C_ftt!5,NtA~P0).FTT(iso~A,raf!4,dim!9).FTT(raf!5,dim!9) b_FB_CN_intra_P0

    # (B) BRAF & 14-3-3 binding  (BRAF crosslinking from C-terminus to N-terminus) (NtA~P1)

      RAF(iso~B,ras,N_ftt~P1,dif,C_ftt!5,NtA~P1).FTT(iso~A,raf,dim!9).FTT(raf!5,dim!9) -> \
     RAF(iso~B,ras,N_ftt~P1!4,dif,C_ftt!5,NtA~P1).FTT(iso~A,raf!4,dim!9).FTT(raf!5,dim!9) b_FB_CN_intra_P1

    # (B) BRAF--14-3-3 decrosslinking (from N-terminus)

      RAF(iso~B,N_ftt~P1!4,C_ftt!5).FTT(raf!4,dim!9).FTT(raf!5,dim!9) -> \
      RAF(iso~B,N_ftt~P1,C_ftt!5).FTT(raf,dim!9).FTT(raf!5,dim!9)       u_FB_NC_intra

# +++ C/ARAF +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

  # (DE)PHOSPHORYLATION OF THE N_TERMINAL 14-3-3 BINDING SITE (FB)-------------

    # (C) phosphorylation of cytoplasmic CRAF at S259 (CRAF primary 14-3-3 binding site); only when 14-3-3 not bound (to this site)

      RAF(iso~C,ras,N_ftt~P0,dif) -> \
      RAF(iso~C,ras,N_ftt~P1,dif)  p_C_S259

    # (A) phosphorylation of cytoplasmic ARAF at S214 (CRAF primary 14-3-3 binding site); only when 14-3-3 not bound (to this site)

      RAF(iso~A,ras,N_ftt~P0,dif) -> \
      RAF(iso~A,ras,N_ftt~P1,dif)  p_A_S214

    # (C) dephosphorylation of cytoplasmic CRAF pS259 (CRAF primary 14-3-3 binding site); only when 14-3-3 not bound

      RAF(iso~C,ras,N_ftt~P1) -> \
      RAF(iso~C,ras,N_ftt~P0)  q_C_S259p

    # (A) dephosphorylation of cytoplasmic ARAF pS214 (ARAF primary 14-3-3 binding site); only when 14-3-3 not bound

      RAF(iso~A,ras,N_ftt~P1) -> \
      RAF(iso~A,ras,N_ftt~P0)  q_A_S214p

  # (DE)PHOSPHORYLATION OF THE C-TERMINAL 14-3-3 BINDING SITE (FC)

  #(C) monomeric CRAF auto-phosphorylation at S621 (secondary 14-3-3 binding site);

    RAF(iso~C,dif,C_ftt~P0) -> \
    RAF(iso~C,dif,C_ftt~P1)  p_C_S621

    #(A) monomeric ARAF auto-phosphorylation at S582 (secondary 14-3-3 binding site);

      RAF(iso~A,dif,C_ftt~P0) -> \
          RAF(iso~A,dif,C_ftt~P1)  p_A_S582

   #(C) (+) auto-phosphorylation of CRAF at S621 within dimer (secondary 14-3-3 binding site);

      RAF(iso~C,dif!+,C_ftt~P0) -> \
      RAF(iso~C,dif!+,C_ftt~P1)  p_C_S621_dim

    #(A) (+) auto-phosphorylation of ARAF at S582 within dimer (secondary 14-3-3 binding site);

      RAF(iso~A,dif!+,C_ftt~P0) -> \
      RAF(iso~A,dif!+,C_ftt~P1)  p_A_S582_dim

    #(A) (-) dephosphorylation of CRAF at pS621 (secondary 14-3-3 binding site)

      RAF(iso~C,C_ftt~P1) -> \
      RAF(iso~C,C_ftt~P0)  q_C_S621p

    #(C) (-) dephosphorylation of at ARAF pS582 (secondary 14-3-3 binding site)

      RAF(iso~A,C_ftt~P1) -> \
      RAF(iso~A,C_ftt~P0)  q_A_S582p

  #-------------------------------------------------------------------------------------------------
  #(DE)PHOSPHORYLATION OF THE NTA DOMAIN (NtA)

   #(C) (+) CRAF S338 (NtA motif) phosphorylation on RAS (only in dimer)

      RAF(iso~C,ras!+,dif!+,NtA~P0) -> \
      RAF(iso~C,ras!+,dif!+,NtA~P1)  p_C_S338_dim

    #(A) (+) ARAF S299 (NtA motif) phosphorylation on RAS (only in dimer)

      RAF(iso~A,ras!+,dif!+,NtA~P0) -> \
      RAF(iso~A,ras!+,dif!+,NtA~P1)  p_A_S299_dim

    #(C) (-) dephosphorylation of CRAF at pS338(NtA motif)

      RAF(iso~C,ras,dif,NtA~P1) -> \
      RAF(iso~C,ras,dif,NtA~P0)  q_C_S338p_cyt

    #(A) (-) dephosphorylation of ARAF at pS299 (NtA motif)

      RAF(iso~A,ras,dif,NtA~P1) -> \
      RAF(iso~A,ras,dif,NtA~P0)  q_A_S299p_cyt

  # --- RAF & 14-3-3 INTERACTIONS----------------------------------------------------------
  #RAF BINDING AND DISSOCIATION WITH N-TERMINAL FTT BINDING SITE (N_ftt)------------------------------------

  #(C) CRAF & 14-3-3 binding at S259 (step 1a), CRAF is monomeric

    RAF(iso~C,ras,N_ftt~P1,C_ftt,dif) + FTT(iso~A,raf,dim!9).FTT(raf,dim!9) -> \
    RAF(iso~C,ras,N_ftt~P1!4,C_ftt,dif).FTT(iso~A,raf!4,dim!9).FTT(raf,dim!9)  b_FC_S259p

    #(A) ARAF & 14-3-3 binding at S214 (step 1a), ARAF is monomeric

      RAF(iso~A,ras,N_ftt~P1,C_ftt,dif) + FTT(raf,dim!9).FTT(raf,dim!9) -> \
      RAF(iso~A,ras,N_ftt~P1!4,C_ftt,dif).FTT(raf!4,dim!9).FTT(raf,dim!9) b_FA_S214p

    #(C) CRAF--14-3-3 dissociation from S259p (rev. step 1a)

      RAF(iso~C,N_ftt!4).FTT(raf!4,dim!9).FTT(raf,dim!9) -> \
      RAF(iso~C,N_ftt) + FTT(raf,dim!9).FTT(raf,dim!9)    u_FC_S259p

    #(A) ARAF--14-3-3 dissociation from S214p (rev. step 1a)

      RAF(iso~A,N_ftt!4).FTT(raf!4,dim!9).FTT(raf,dim!9) -> \
      RAF(iso~A,N_ftt) + FTT(raf,dim!9).FTT(raf,dim!9)    u_FA_S214p

  #+++ RAF INTRAMOLECULAR (DE)CROSSLINKING BY 14-3-3 +++++++++++++++++++++++++++++++++++++++++++++++++++++++++
  # -------RAF (DE)CROSSLINKING (N-->C) - 14-3-3 BOUND TO N_FTT ----------------------------------------------------
  #(C/A) C/ARAF crosslinking by 14-3-3 from N-terminus to C-terminus (NtA~P0)
  #NtA~P1 prevents binding, i.e., keeps A/CRAF open

    #(C)  CRAF crosslinking from N_ftt to  C_ftt

       RAF(iso~C,N_ftt~P1!4,C_ftt~P1,NtA~P0).FTT(raf!4,dim!9).FTT(iso~A,raf,dim!9) -> \
      RAF(iso~C,N_ftt~P1!4,C_ftt~P1!5,NtA~P0).FTT(raf!4,dim!9).FTT(iso~A,raf!5,dim!9)  b_FC_NC_intra_P0

    #(A) ARAF crosslinking from N_ftt to C_ftt

      RAF(iso~A,N_ftt~P1!4,C_ftt~P1,NtA~P0).FTT(raf!4,dim!9).FTT(iso~A,raf,dim!9) -> \
      RAF(iso~A,N_ftt~P1!4,C_ftt~P1!5,NtA~P0).FTT(raf!4,dim!9).FTT(iso~A,raf!5,dim!9)  b_FA_NC_intra_P0

  #(C/A) C/ARAF decrosslinkimg 14-3-3 from N-terminus to C-terminus

      #(C) CRAF decrosslinking from C_ftt to N_ftt (ring opening)

      RAF(iso~C,N_ftt!4,C_ftt!5).FTT(raf!4,dim!9).FTT(raf!5,dim!9) -> \
      RAF(iso~C,N_ftt!4,C_ftt).FTT(raf!4,dim!9).FTT(raf,dim!9)      u_FC_CN_intra

                #(A) ARAF decrosslinking from C_ftt to _N_ftt (ring opening)

      RAF(iso~A,N_ftt!4,C_ftt!5).FTT(raf!4,dim!9).FTT(raf!5,dim!9) -> \
      RAF(iso~A,N_ftt!4,C_ftt).FTT(raf!4,dim!9).FTT(raf,dim!9)      u_FA_CN_intra

  # ++++++++++ MEK DIMERIZATION +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

      MEK(iso~mek1,dim) + MEK(iso~mek1,dim) <-> MEK(iso~mek1,dim!1).MEK(iso~mek1,dim!1)  b_MEK11,u_MEK11
      MEK(iso~mek2,dim) + MEK(iso~mek2,dim) <-> MEK(iso~mek2,dim!1).MEK(iso~mek2,dim!1)  b_MEK22,u_MEK22
      MEK(iso~mek1,dim) + MEK(iso~mek2,dim) <-> MEK(iso~mek1,dim!1).MEK(iso~mek2,dim!1)  b_MEK12,u_MEK12

  # ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

  # ===== Processes relevant to signal transduction in a stimulated cell =======

  # --- [1] EGFR and RAS activation --------------------------------------------

    # -- Receptor activity:
    # (signal+/signal-) EGFR & EGF binding/dissociation
    #
      EGFR(egf~I) <-> EGFR(egf~A)  a_EGFR,i_EGFR

    # Active EGFR--SOS binding/unbinding:

      EGFR(egf~A,sos) + SOS(rem,egfr,S~P0) <-> \
      EGFR(egf~A,sos!1).SOS(rem,egfr!1,S~P0) b1,u1a

    # Inactive EGFR--SOS unbinding:

      EGFR(egf~I,sos!1).SOS(rem,egfr!1) -> \
      EGFR(egf~I,sos) + SOS(rem,egfr)   u1b

    # -- SOS interactions with RAS:
    # SOS--inactive RAS binding/unbinding => moderate allosteric upregulation
    # of SOS's GEF activity:

      SOS(rem,egfr!+) + RAS(sos,dim,raf,nt~GDP) <-> \
      SOS(rem!1,egfr!+).RAS(sos!1,dim,raf,nt~GDP) b2a_f,u2a

    # SOS--active RAS binding/unbinding => strong allosteric upregulation of
   # SOS's GEF activity:

      SOS(rem,egfr!+) + RAS(sos,dim,raf,nt~GTP) <-> \
      SOS(rem!1,egfr!+).RAS(sos!1,dim,raf,nt~GTP) b2b,u2b

    # SOS complexed with inactive RAS (and thus allosterically moderately upregulated)
    # helps another RAS with nucleotide exchange:

      SOS(rem!1,egfr!+).RAS(sos!1,dim,raf,nt~GDP) + RAS(sos,dim,raf,nt~GDP) -> \
      SOS(rem!1,egfr!+).RAS(sos!1,dim,raf,nt~GDP) + RAS(sos,dim,raf,nt~GTP) k2a_f

    # SOS complexed with active RAS (and thus allosterically strongly upregulated)
    # helps another RAS with nucleotide exchange:

      SOS(rem!1,egfr!+).RAS(sos!1,dim,raf,nt~GTP) + RAS(sos,dim,raf,nt~GDP) -> \
      SOS(rem!1,egfr!+).RAS(sos!1,dim,raf,nt~GTP) + RAS(sos,dim,raf,nt~GTP) k2b

  # -- RasGAP & RAS interactions:

  #  Catalytic activation of G-protein => inhibition of signaling.
  #  Michaelis--Menten-like kinetics introduces nonlinearity.
  #  (This is not exactly M--M, as the active complex cannot dissociate
  #  until the substrate is transformed.)

      RasGAP(ras) + RAS(sos,dim,raf,nt~GTP) -> \
      RasGAP(ras!1).RAS(sos,dim,raf,nt~GTP!1) b3_f

      RasGAP(ras!1).RAS(sos,nt~GTP!1) -> \
      RasGAP(ras!1).RAS(sos,nt~GDP!1) k3

      RasGAP(ras!1).RAS(sos,nt~GDP!1) -> \
      RasGAP(ras) + RAS(sos,nt~GDP)   u3

    # -- RAS_GTP homodimerization
      RAS(sos,dim,raf,nt~GTP) + RAS(sos,dim,raf,nt~GTP) <-> \
      RAS(sos,dim!8,raf,nt~GTP).RAS(sos,dim!8,raf,nt~GTP)   b4_f,u4

    #--- [2] RAS--RAF BINDING/DISSOCIATION ------------------------------------------------------------------

    #(B) (+) active RAS dimer & BRAF binding

      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8) + RAF(iso~B,ras,N_ftt~P0,dif) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8).RAF(iso~B,ras!2,N_ftt~P0,dif)  b_GB

    #(B) (+) active RAS dimer & BRAF binding
    # RAS binding leads to immediate dephosphorylation at N-terminus

    RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8) + RAF(iso~B,ras,N_ftt~P1,dif) -> \
    RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8).RAF(iso~B,ras!2,N_ftt~P0,dif)  b_GB

    #(B)  (+) active RAS dimer & BRAF--BRAF dimer binding

    RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8,raf) + RAF(iso~B,ras,dif!2).RAF(iso~B,ras,dif!2) -> \
    RAS(sos,nt~GTP,dim!8,raf!3).RAS(sos,nt~GTP,dim!8,raf!4).RAF(iso~B,ras!3,dif!2).RAF(iso~B,ras!4,dif!2)  b_GB

    #(B) (-) RAS--BRAF dissociation
    #(DIF state in BRAF is specified to prevent dissociation of BRAF complexed with CRAF)

      RAS(nt~GTP,raf!1).RAF(iso~B,ras!1,dif) -> \
      RAS(nt~GTP,raf) + RAF(iso~B,ras,dif)    u_GB_GTP

    #(C/A) (+) active RAS dimer & CRAF/ARAF binding  (CRAF/ARAF-N_ftt is 14-3-3-free)
    #RAS binding leads to immediate dephosphorylation at N-terminus

          #(C) (+) active RAS dimer & CRAF binding  (CRAF-N_ftt is 14-3-3-free)

      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8) + RAF(iso~C,ras,dif,N_ftt~P0,C_ftt) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8).RAF(iso~C,ras!2,dif,N_ftt~P0,C_ftt) b_GC

          #(A) (+) active RAS dimer & ARAF binding  (ARAF-N_ftt is 14-3-3-free)

      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8) + RAF(iso~A,ras,dif,N_ftt~P0,C_ftt) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8).RAF(iso~A,ras!2,dif,N_ftt~P0,C_ftt) b_GA

  #(C/A) (+) active RAS dimer & CRAF/ARAF binding  (CRAF/ARAF-N_ftt is 14-3-3-free)
  #RAS binding leads to immediate dephosphorylation at N-terminus

        #(C) (+) active RAS dimer & CRAF binding  (CRAF-N_ftt is 14-3-3-free AND phosphorylated)

      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8) + RAF(iso~C,ras,dif,N_ftt~P1,C_ftt) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8).RAF(iso~C,ras!2,dif,N_ftt~P0,C_ftt) b_GC

        #(A) (+) active RAS dimer & CRAF binding  (CRAF-N_ftt is 14-3-3-free AND phosphorylated)

      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8) + RAF(iso~A,ras,dif,N_ftt~P1,C_ftt) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8).RAF(iso~A,ras!2,dif,N_ftt~P0,C_ftt) b_GA

