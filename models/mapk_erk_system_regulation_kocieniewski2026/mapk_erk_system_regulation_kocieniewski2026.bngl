  #RAS binding leads to immediate dephosphorylation at N-terminus

  #(C) (+) active RAS dimer & BRAF--CRAF dimer binding

      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8,raf)  +  RAF(iso~B,ras,dif!2).RAF(iso~C,ras,dif!2) -> \
      RAS(sos,nt~GTP,dim!8,raf!3).RAS(sos,nt~GTP,dim!8,raf!4).RAF(iso~B,ras!3,dif!2).RAF(iso~C,ras!4,dif!2)  (b_GB+b_GC)/2

    #(A) (+) active RAS dimer & BRAF--ARAF dimer binding

      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8,raf)  +  RAF(iso~B,ras,dif!2).RAF(iso~A,ras,dif!2) -> \
      RAS(sos,nt~GTP,dim!8,raf!3).RAS(sos,nt~GTP,dim!8,raf!4).RAF(iso~B,ras!3,dif!2).RAF(iso~A,ras!4,dif!2)  (b_GB+b_GA)/2

  #(C/A) (+) active RAS dimer & CRAF(ARAF) homo- and heterodimer binding

     #(CC) (+) active RAS dimer & CRAF homodimer binding

      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8,raf)  +  RAF(iso~C,ras,dif!2).RAF(iso~C,ras,dif!2) -> \
    RAS(sos,nt~GTP,dim!8,raf!3).RAS(sos,nt~GTP,dim!8,raf!4).RAF(iso~C,ras!3,dif!2).RAF(iso~C,ras!4,dif!2)  b_GC

      #(AC) (+) active RAS dimer & ARAF--CRAF heterodimer binding

      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8,raf)  +  RAF(iso~A,ras,dif!2).RAF(iso~C,ras,dif!2) -> \
      RAS(sos,nt~GTP,dim!8,raf!3).RAS(sos,nt~GTP,dim!8,raf!4).RAF(iso~A,ras!3,dif!2).RAF(iso~C,ras!4,dif!2)  (b_GA+b_GC)/2

      #(AA) (+) active RAS dimer & ARAF homodimer binding

      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8,raf)  +  RAF(iso~A,ras,dif!2).RAF(iso~A,ras,dif!2) -> \
      RAS(sos,nt~GTP,dim!8,raf!3).RAS(sos,nt~GTP,dim!8,raf!4).RAF(iso~A,ras!3,dif!2).RAF(iso~A,ras!4,dif!2)  b_GA

  #(C/A) (-) RAS--CRAF(ARAF) dissociation

    #(C) (-) RAS--CRAF dissociation

      RAS(nt~GTP,raf!1).RAF(iso~C,ras!1,dif,N_ftt,C_ftt) -> \
      RAS(nt~GTP,raf) + RAF(iso~C,ras,dif,N_ftt,C_ftt)    u_GC_GTP

    #(A) (-) RAS--ARAF dissociation

      RAS(nt~GTP,raf!1).RAF(iso~A,ras!1,dif,N_ftt,C_ftt) -> \
      RAS(nt~GTP,raf) + RAF(iso~A,ras,dif,N_ftt,C_ftt)    u_GA_GTP

  #(C/A) (-) RAS dimer--{BRAF--CRAF/ARAF} dissociation

    #(C) (-) RAS dimer--{BRAF--CRAF} dissociation

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!3,dif!4).RAF(iso~C,ras!2,dif!4) -> \
      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8,raf) + RAF(iso~B,ras,dif!4).RAF(iso~C,ras,dif!4)   u_GBC_dim_GTP

    #(A) (-) RAS dimer--{BRAF--ARAF} dissociation

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!3,dif!4).RAF(iso~A,ras!2,dif!4) -> \
      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8,raf) + RAF(iso~B,ras,dif!4).RAF(iso~A,ras,dif!4)   u_GBA_dim_GTP

    #(B) (-) RAS dimer--{BRAF--BRAF} dissociation

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!3,dif!4).RAF(iso~B,ras!2,dif!4) -> \
      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8,raf) + RAF(iso~B,ras,dif!4).RAF(iso~B,ras,dif!4)   u_GBB_dim_GTP


