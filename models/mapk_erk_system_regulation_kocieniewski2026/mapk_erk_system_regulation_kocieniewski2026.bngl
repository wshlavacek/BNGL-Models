    #(CC) (-) RAS dimer--{CRAF--CRAF} dissociation

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~C,ras!3,dif!4).RAF(iso~C,ras!2,dif!4) -> \
      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8,raf) + RAF(iso~C,ras,dif!4).RAF(iso~C,ras,dif!4)   u_GCC_dim_GTP

    #(AC) (-) RAS dimer--{ARAF--CRAF} dissociation

