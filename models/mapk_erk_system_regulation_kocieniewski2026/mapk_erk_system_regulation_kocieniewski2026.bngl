  Molecules  RAS_gtp            RAS(nt~GTP)
  #Molecules  RAS_gtp_free       RAS(nt~GTP,raf)
  # Active RAF isoforms: dimerized, NtA-phosphorylated, and C-terminal-site phosphorylated.
  Molecules  RAF_active         RAF(iso~B,dif!+,NtA~P1,C_ftt~P1!?) RAF(iso~A,dif!+,NtA~P1,C_ftt~P1!?) RAF(iso~C,dif!+,NtA~P1,C_ftt~P1!?)
