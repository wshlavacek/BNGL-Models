begin model

#@title: MAPK/ERK system regulation (Kocieniewski and Lipniacki, 2026)

#@description: |
#  Rule-based MAPK/ERK signaling model for Homo sapiens cells that includes EGFR,
#  SOS, RAS, RasGAP, ARAF, BRAF, CRAF, MEK1, MEK2, ERK, and dimeric 14-3-3.
#  Mass-action rules encode RAF isoform regulation, RAF and MEK dimerization,
#  14-3-3-mediated RAF autoinhibition and dimer stabilization, SOS-RAS positive
#  feedback, and ERK-mediated negative feedback to SOS, RAF, and MEK. The active
#  ODE protocol reproduces the published EGF=10000 pg/ml stimulation trajectory
#  for Fig. 3a after a long unstimulated equilibration phase, yielding relaxation
#  oscillations in RAS-GTP, active RAF, MEK-PP, and ERK-PP.

#@keyword: |
#  MAPK signaling, ERK, RAF isoforms, RAS, EGFR, 14-3-3, Homo sapiens,
#  rule-based modeling, mass action, positive feedback, negative feedback,
#  relaxation oscillations, ODE

#@reference: |
#  Kocieniewski, P. and Lipniacki, T. (2026). A computational rule-based model
#  of MAPK/ERK system regulation. Scientific Reports 16:14437.
#  https://doi.org/10.1038/s41598-026-44353-3

#@organism: Homo sapiens

#@source: adapted_from_bngl

#@bng_version: >=2.9.3

#@units_convention: |
#  Source model amounts are interpreted as molecule counts per cell or per active
#  membrane fraction. Time is in seconds and the EGF dose parameter is in pg/ml.
#  The source BNGL uses population-style rate constants without an explicit cell
#  volume conversion; stochastic reinterpretation should be validated separately.

#@runtime_expectation: |
#  Network generation takes about 5 s and the active ODE protocol takes about
#  80 s with BioNetGen 2.9.3 on the curation workstation.

#@license: CC-BY-4.0

#@house_style_version: 0.1

begin parameters

  ## -- Naming convention for rate parameters (prefix characters):
  #
  #     a -- activation       <->   i -- inactivation
  #     b -- binding          <->   u -- dissociation
  #     p -- phosphorylation  <->   q -- dephosphorylation
  #     s -- synthesis        <->   d -- degradation
  #     t -- transformation
  #     m -- modification
  #     f -- a fraction or ratio or scaling

# General and Auxiliary Parameters

  EGF_MM    300       # MM dose coefficient appears in Frac

  ### Variables EGF and EGFs are set in Simulation protocol at the end of the code ###
  ### Here are only declarations and place holder values ###
  EGF       0         # EGF ligand concentration [pg/ml] during simulation;
  EGFs      10000     # source protocol dose used to define Frac before parsing

  Frac      EGFs/(EGFs+EGF_MM)        # Fraction of active membrane

  f_M1      2/3

  ### == Cell parameters: protein abundances (assumed constant except for EGF)
  EGFR_tot   6e4
  SOS_tot    2e4
  RAS_tot    3e5
  RasGAP_tot 5e4     # total level of RasGAPs (RASA1, RASA2, NF1 - not  considered explicitely)
  BRAF_tot   2e4
  CRAF_tot   5e4
  ARAF_tot   5e4
  MEK_tot    6e5     # total MEK (both MEK1 and MEK2)
  ERK_tot    1e6
  FTT_tot    1e7     # 14-3-3 protein, [F]ourteen-[T]hree-[T]hree

  #Scaling to correspond to the fraction of the activated membrane
  EGFR_tot_f EGFR_tot*Frac
  RAS_tot_f  RAS_tot*Frac
  RasGAP_tot_f   RasGAP_tot*Frac

  Param 0               # a placeholder parameter for scripting purposes

  ## Feedback Parameters ------------------------------------------------------
  # POSITIVE:

  PF        10
  PF1       PF        #Increase of recruitment of RAS-GTP to SOS(rem) domain
  PF2       PF        #Increase of RAS GEF-activity due to RAS-GTP bound to SOS(rem)

  # NEGATIVE:

  p_nfSOS      3e-8   #SOS phosphorylation at feedback sites by ERK
  q_nfSOS      1e-3   #SOS dephosphorylation at feedback sites (pseudo-first-order)

  p_nfRAF      3e-8   #A/B/CRAF phosphorylation at negative feedback sites (DIF domain)
  q_nfRAF      1e-4   #A/B/CRAF dephosphorylation at negative feedback sites (DIF domain) (pseudo-first-order)

  p_nfMEK      3e-9   #MEK1 phosphorylation at negative feedback site (NFS - T292 on MEK1)
  q_nfMEK      3e-4   #MEK1 dephosphorylation at negative feedback site (NFS - T292 on MEK1) (pseudo-first-order)


# == Kinetic rate parameters
#
#  (Reaction rules may be parametrized using the rates below with additional
#  factors -- see the respective reaction rules for final parameter values)

## = = = = = Parameters governing RAF isoforms in the quiescent state = = = = =
##(De)Phosphorylation of the A/B/CRAF N-terminal 14-3-3 binding sites

    p_B_S365       1e-1   #BRAF phosphorylation at Ser365 (first-order)
    q_B_S365p      1e-1   #BRAF dephosphorylation at Ser365 in cytoplasm (first-order)

    p_NS_AC        3e-1     #A/CRAF phosphorylation of the N-terminal FTT-binding domain
    q_NSp_AC       1e-2     #A/CRAF dephosphorylation of the N-terminal FTT-binding domain

      p_C_S259   p_NS_AC    #CRAF phosphorylation at Ser259 in cytoplasm (pseudo-first-order)
      q_C_S259p  q_NSp_AC   #CRAF dephosphorylation at Ser259 in cytoplasm (pseudo-first-order)

      p_A_S214   p_NS_AC    #ARAF phosphorylation at Ser214 in cytoplasm (pseudo-first-order)
      q_A_S214p  q_NSp_AC   #ARAF dephosphorylation at Ser214 in cytoplasm (pseudo-first-order)

##(De)Phosphorylation of A/CRAF C-terminal 14-3-3 binding site

    p_CS_AC            1e-2     #A/CRAF phosphorylation at Ser729 (first-order)
    p_CS_AC_dim        1e+2     #A/CRAF phosphorylation at Ser729 in dimer (first-order)
    q_CS_AC            3e-1     #A/CRAF dephosphorylation at Ser729 (first-order)

      p_C_S621       p_CS_AC      #CRAF phosphorylation at Ser621 (first-order)
      p_C_S621_dim   p_CS_AC_dim  #CRAF phosphorylation at Ser621 in dimer (first-order)
      q_C_S621p      q_CS_AC      #CRAF dephosphorylation at Ser621 (first-order)

      p_A_S582       p_CS_AC      #ARAF phosphorylation at Ser582 (first-order)
      p_A_S582_dim   p_CS_AC_dim  #ARAF phosphorylation at Ser582 in dimer (first-order)
      q_A_S582p      q_CS_AC      #ARAF dephosphorylation at Ser582 (first-order)

## N-terminal binding and unbinding of 14-3-3 to A/CRAF

    b_FNp_AC          1e-7  #14-3-3 binding of the phosphorylated A/CRAF N-terminal domain
    u_FNp_AC          1     #14-3-3 dissociation from the phosphorylated A/CRAF N-terminal domain

      b_FC_S259p    b_FNp_AC  #14-3-3 binding to CRAF Ser259p
      u_FC_S259p    u_FNp_AC  #14-3-3 dissociation from CRAF Ser259p

      b_FA_S214p    b_FNp_AC  #14-3-3 binding to ARAF Ser214p
      u_FA_S214p    u_FNp_AC  #14-3-3 dissociation from ARAF Ser214p

## C-terminal binding and unbinding of 14-3-3 to BRAF

    b_FB_S729p        1e-7  #14-3-3 binding to BRAF Ser729p
    u_FB_S729p        1     #14-3-3 dissociation from BRAF Ser729p

## Crosslinking by 14-3-3

  b_FR                     1e+2  #GENERIC RAF molecular crosslinking by 14-3-3 (first-order)
  u_FR                     3e-2  #GENERIC RAF 14-3-3 dissociation from C-terminal binding sites
                                 #(S621p in CRAF, S729p in BRAF, S582p in ARAF) (first-order)

 # (1) Intramolecular crosslinking of RAF monomers via 14-3-3
 #     (accounts for the direction of crosslinking (N -> C vs C -> N) and the NtA phosphorylation status

    b_FR_intra                        b_FR
    b_FB_intra                    b_FR_intra
      b_FB_NC_intra              b_FB_intra
        b_FB_NC_intra_P1       b_FB_NC_intra
        b_FB_NC_intra_P0       b_FB_NC_intra
      b_FB_CN_intra              b_FB_intra
        b_FB_CN_intra_P0       b_FB_CN_intra
        b_FB_CN_intra_P1       b_FB_CN_intra

        b_FAC_intra                  b_FR_intra
          b_FAC_NC_intra          b_FAC_intra
            b_FAC_NC_intra_P0     b_FAC_NC_intra
              b_FC_NC_intra_P0    b_FAC_NC_intra_P0
              b_FA_NC_intra_P0    b_FAC_NC_intra_P0
            b_FAC_NC_intra_P1     b_FAC_NC_intra
              b_FC_NC_intra_P1    b_FAC_NC_intra_P1
              b_FA_NC_intra_P1    b_FAC_NC_intra_P1

          b_FAC_CN_intra          b_FAC_intra
            b_FAC_CN_intra_P0     b_FAC_CN_intra
              b_FC_CN_intra_P0    b_FAC_CN_intra_P0
              b_FA_CN_intra_P0    b_FAC_CN_intra_P0
            b_FAC_CN_intra_P1     b_FAC_CN_intra
              b_FC_CN_intra_P1    b_FAC_CN_intra_P1

              b_FA_CN_intra_P1    b_FAC_CN_intra_P1

 # (2) Intramolecular de-crosslinking of RAF monomers
 #     (accounts for the direction of de-crosslinking (N -> C vs C -> N)
    u_FR_intra                    u_FR
    u_FB_intra                 u_FR_intra
      u_FB_NC_intra          u_FB_intra
        u_FB_NC_intra_P0        u_FB_NC_intra
        u_FB_NC_intra_P1        u_FB_NC_intra
      u_FB_CN_intra          u_FB_intra
        u_FB_CN_intra_P0      u_FB_CN_intra
        u_FB_CN_intra_P1      u_FB_CN_intra

        u_FAC_intra                   u_FR_intra
          u_FAC_NC_intra           u_FAC_intra
               u_FC_NC_intra      u_FAC_NC_intra
                 u_FC_NC_intra_P0  u_FC_NC_intra
                 u_FC_NC_intra_P1  u_FC_NC_intra
               u_FA_NC_intra       u_FAC_NC_intra
                 u_FA_NC_intra_P0  u_FA_NC_intra
                 u_FA_NC_intra_P1  u_FA_NC_intra

          u_FAC_CN_intra           u_FAC_intra
               u_FC_CN_intra      u_FAC_CN_intra
                 u_FC_CN_intra_P0  u_FC_CN_intra
                 u_FC_CN_intra_P1  u_FC_CN_intra
               u_FA_CN_intra       u_FAC_CN_intra
                 u_FA_CN_intra_P0  u_FA_CN_intra
                 u_FA_CN_intra_P1  u_FA_CN_intra

 # (3) RAF dimer intermolecular (de)crosslinking of the C-terminal binding sites via 14-3-3
    b_FR_inter            b_FR  #intermolecular dimer crosslinking of the C-terminal binding site by 14-3-3  (first-order)
    u_FR_inter            u_FR  #intermolecular dimer de-crosslinking from a C-terminal binding site (first-order)

  # (1) Crosslinking
      b_FB_inter        b_FR_inter  #intermolecular dimer crosslinking by FTT to BRAF (first-order)

      b_FAC_inter       b_FR_inter       #intermolecular dimer crosslinking by FTT to A/CRAF (first-order)
        b_FC_inter        b_FAC_inter  #intermolecular dimer crosslinking by FTT to CRAF (first-order)
        b_FA_inter        b_FAC_inter  #intermolecular dimer crosslinking by FTT to ARAF (first-order)

  # (2) Decrosslinking
      u_FB_inter        u_FR_inter   #intermolecular dimer de-crosslinking from BRAF

      u_FAC_inter       u_FR_inter       #intermolecular dimer de-crosslinking from A/CRAF
        u_FC_inter        u_FAC_inter  #intermolecular dimer de-crosslinking from CRAF
        u_FA_inter        u_FAC_inter  #intermolecular dimer de-crosslinking from ARAF

## MEK1 and MEK2 homo- and heterodimerization ----------------------------

  b_MEK11   1e-5  # MEK1 homodimer formation
  u_MEK11   1e-3  # MEK1 dimer dissociation
  b_MEK22   1e-5  # MEK2 homodimer formation
  u_MEK22   3e-2  # MEK2 homodimer dissociation
  b_MEK12   1e-5  # MEK1 and MEK2 heterodimer formation
  u_MEK12   1e-3  # MEK1 and MEK2 heterodimer dissociation

## = = = = = rates governing signal transduction in a stimulated cell = = = = =

  # -- EGF receptor (EGFR) activation

  b_EGFR       3e-5        #"binding" of EGF to EGFR
  a_EGFR       b_EGFR*EGF  #EGFR activation upon EGF signal  [gives the critical dose about 10pg/ml]  CHANGED!!!
  i_EGFR       1e-2        #EGFR deactivation (first-order)


  # -- SOS activation via EGFR binding & positive feedback due to RAS-GTP:

  b1   1e-5         # EGFR--SOS   binding; EGFR is EGF-bound, SOS~U
  u1a  1e-2         # EGFR--SOS unbinding; EGFR is EGF-bound, SOS~U
  u1b  1e+2         # EGFR--SOS unbinding; EGFR is EGF-free,  SOS~P+; FAST

  b2a    1e-6
  b2a_f  b2a/Frac   # SOS(rem)--RAS~GDP   binding, scaled by membrane fraction
  u2a    1          # SOS(rem)--RAS~GDP unbinding
  b2b    b2a_f*PF1  # SOS(rem)--RAS~GTP   binding  - POSITIVE FEEDBACK
  u2b    1          # SOS(rem)--RAS~GTP unbinding

  k2a    1e-6
  k2a_f  k2a/Frac   # SOS med nt-exchanger activity; scaled by membrane fraction
                    # (SOS allosterically moderately upregulated by RAS~GDP)
  k2b    k2a_f*PF2  # SOS max nt-exchanger activity;
                    # (SOS allosterically strongly upregulated by RAS~GTP) - POSITIVE FEEDBACK

  # -- RasGAP activity:

  b3     3e-6
  b3_f   b3/Frac    # RasGAP--RAS(sos,dim,raf,nt~GTP)   binding, scaled by membrane fraction
  u3     1e-2       # RasGAP--RAS(sos,nt~GDP) unbinding
  k3     1e+2       # FAST RAS signaling inactivation by bound RasGAP
                    # (through RasGAP-assisted ~GTP -> ~GDP hydrolysis)

  # -- RAS homodimerization

  b4    1e-5
  b4_f  b4/Frac         # RAS(sos,nt~GTP) homodimerisation, scaled by membrane fraction
  u4    0.1             # RAS(sos,nt~GTP) dimer unbinding

  # -- RAF binding/dissociation to/from RAS

  b_GR          9e-5     #GENERIC RAS~GTP & RAF binding

    b_GB         b_GR    #RAS~GTP & BRAF binding
    b_G_AC       b_GR    #RAS~GTP & A/CRAF binding

      b_GC     b_G_AC    #RAS~GTP & CRAF binding (only when CRAF is not bound to 14-3-3)
      b_GA     b_G_AC    #RAS~GTP & ARAF binding (only when ARAF is not bound to 14-3-3)

  u_GR           1e+2     #GENERIC RAF isoform dissociation from RAS~GDP (first-order)

    u_GB         u_GR
    u_G_AC       u_GR

      u_GC     u_G_AC
      u_GA     u_G_AC

  u_GR_GTP       1e-1     #GENERIC RAF isoform dissociation from RAS~GTP (first-order)

    u_GB_GTP     u_GR_GTP
    u_G_AC_GTP   u_GR_GTP
      u_GC_GTP u_G_AC_GTP
      u_GA_GTP u_G_AC_GTP

  u_GRR_dim      10       #GENERIC RAF homodimer or heterodimer dissociation from RAS~GDP (first-order)

  u_GRR_dim_GTP  1   #GENERIC RAF homodimer or heterodimer dissociation from RAS~GTP (first-order)

    u_GBB_dim_GTP        u_GRR_dim_GTP

    u_GB_AC_dim_GTP      u_GRR_dim_GTP
      u_GBC_dim_GTP    u_GB_AC_dim_GTP
      u_GBA_dim_GTP    u_GB_AC_dim_GTP

    u_G_AC_AC_dim_GTP    u_GRR_dim_GTP
      u_GCC_dim_GTP    u_G_AC_AC_dim_GTP
      u_GAC_dim_GTP    u_G_AC_AC_dim_GTP
      u_GAA_dim_GTP    u_G_AC_AC_dim_GTP

  # -- RAFs dimerization

  b_GRR_dim         1e+2       #GENERIC dimerization of RAFs on a RAS platform

    b_GBB_dim       b_GRR_dim
    b_GB_AC_dim     b_GRR_dim

    b_GBC_dim   b_GB_AC_dim   #dimerization of RAFs on a RAS platform
    b_GBA_dim   b_GB_AC_dim   #dimerization of RAFs on a RAS platform

    b_G_AC_AC_dim   b_GRR_dim

    b_GCC_dim   b_G_AC_AC_dim    #dimerization of RAFs on a RAS platform
    b_GAC_dim   b_G_AC_AC_dim    #dimerization of RAFs on a RAS platform
    b_GAA_dim   b_G_AC_AC_dim    #dimerization of RAFs on a RAS platform

  # --RAFs "undimerization"

  f_nfDIM                 30      #Increase of dimer dissociation due to RAF dimer feedback phosphorylation of ERK
  f_GRR                   10      #Decrease of dimer dissociation on a RAS platform

  u_RR_dim                1                    #GENERIC "undimerization" of a RAF dimer in the cytoplasm when DIF domains are *not* phosphorylated (first-order)
  u_RR_dim_fast           u_RR_dim*f_nfDIM     #GENERIC "undimerization" of a RAF dimer in the cytoplasm when DIF domains are *not* phosphorylated (first-order)
  u_GRR_dim_fast          u_RR_dim_fast/f_GRR

    u_BB_dim              u_RR_dim         #"undimerization" of a BB dimer in the cytoplasm (DIF *not* phosphorylated 1-st order)
    u_BB_dim_fast         u_RR_dim_fast    #"undimerization" of BB dimer in the cytoplasm DIF *not* phosphorylated 1-st order)
    u_GBB_dim_fast        u_GRR_dim_fast   #"undimerization" of a BB dimers on RAS platform (DIF *phosphorylated* 1-st order)

    u_B_AC_dim            u_RR_dim         #"undimerization" of a B-C/A heterodimer in the cytoplasm (DIF *not* phosphorylated)
      u_BC_dim          u_B_AC_dim       #"undimerization" of a BC heterodimer in the cytoplasm (DIF *not* phosphorylated)
      u_BA_dim          u_B_AC_dim       #"undimerization" of a BA heterodimer in the cytoplasm (DIF *not* phosphorylated)

    u_B_AC_dim_fast       u_RR_dim_fast      #"undimerization" of B-C/A heterodimer dimer in the cytoplasm (DIF *phosphorylated*)
      u_BC_dim_fast     u_B_AC_dim_fast    #"undimerization" of BA heterodimer dimer in the cytoplasm  (DIF *phosphorylated*)
      u_BA_dim_fast     u_B_AC_dim_fast    #"undimerization" of BC heterodimer dimer in the cytoplasm  (DIF *phosphorylated*)

    u_GB_AC_dim_fast      u_GRR_dim_fast    #"undimerization" of a B-C/A heterodimer on RAS platform (DIF *phosphorylated* (first-order))
      u_GBC_dim_fast    u_GB_AC_dim_fast  #"undimerization" of a B-C heterodimer on RAS platform (DIF *phosphorylated* (first-order))
      u_GBA_dim_fast    u_GB_AC_dim_fast  #"undimerization" of a B-A heterodimer on RAS platform (DIF *phosphorylated* (first-order))

  u_AC_AC_dim           u_RR_dim          #"undimerization" of C/A RAF dimers in the cytoplasm  (DIF *not* phosphorylated)
    u_CC_dim          u_AC_AC_dim       #"undimerization" of CC RAF homodimers in the cytoplasm  (DIF *not* phosphorylated)
    u_AC_dim          u_AC_AC_dim       #"undimerization" of AC RAF heterodimers in the cytoplasm  (DIF *not* phosphorylated)
    u_AA_dim          u_AC_AC_dim       #"undimerization" of AC RAF homodimers in the cytoplasm  (DIF *not* phosphorylated)

  u_AC_AC_dim_fast      u_RR_dim_fast     #"undimerization" of C/A RAF dimer in the cytoplasm (DIF *phosphorylated*)
    u_CC_dim_fast     u_AC_AC_dim_fast  #"undimerization" of CC RAF homodimers dimer in the cytoplasm (DIF *phosphorylated*)
    u_AC_dim_fast     u_AC_AC_dim_fast  #"undimerization" of AC RAF heterodimers dimer in the cytoplasm (DIF *phosphorylated*)
    u_AA_dim_fast     u_AC_AC_dim_fast  #"undimerization" of AA RAF homodimers dimer in the cytoplasm (DIF *phosphorylated*)

  u_G_AC_AC_dim_fast    u_GRR_dim_fast      #"undimerization" of C/A RAF homo and heterodimers on RAS platform (DIF *phosphorylated*)
    u_GCC_dim_fast    u_G_AC_AC_dim_fast  #"undimerization" of CC RAF homodimers on RAS platform (DIF *phosphorylated*)
    u_GAC_dim_fast    u_G_AC_AC_dim_fast  #"undimerization" of AC RAF heterodimers on RAS platform (DIF *phosphorylated*)
    u_GAA_dim_fast    u_G_AC_AC_dim_fast  #"undimerization" of AA RAF homodimers on RAS platform (DIF *phosphorylated*)

  u_GBB_dim             u_GRR_dim_fast/f_nfDIM

  u_GB_AC_dim           u_GRR_dim_fast/f_nfDIM
    u_GBC_dim         u_GB_AC_dim
    u_GBA_dim         u_GB_AC_dim

  u_G_AC_AC_dim         u_GRR_dim_fast/f_nfDIM
    u_GCC_dim         u_G_AC_AC_dim
    u_GAC_dim         u_G_AC_AC_dim
    u_GAA_dim         u_G_AC_AC_dim

#********************************************************************************************************************************

    p_NtA_dim_AC       1e-1          #Phosphorylation of the C/ARAF NtA domain (on RAS)
        p_C_S338_dim   p_NtA_dim_AC  #CRAF RAS-induced phosphorylation on Ser338 (in the NtA motif) (first-order)
      p_A_S299_dim   p_NtA_dim_AC  #ARAF RAS-induced phosphorylation on Ser299 (in the NtA motif) (first-order)

    q_NtA_cyt_AC       1e-1          #Dephosphorylation of the C/ARAF NtA domain
      q_C_S338p_cyt  q_NtA_cyt_AC  #dephosphorylation on Ser338 (in the NtA motif) (first-order)
      q_A_S299p_cyt  q_NtA_cyt_AC  #ARAF dephosphorylation on Ser299 (in the NtA motif) (first-order)

  # -- MEK and ERK activation -------------------------------------------------

  p_RM        1e-5     #GENERIC phosphorylation of MEK1/2 on AL (activation loop) by RAF kinases

    p_RM_B      p_RM     #Phosphorylation of MEK1/2 on AL (activation loop) by BRAF
    p_RM_AC     p_RM     #Phosphorylation of MEK1/2 on AL (activation loop) by A/CRAF
      p_RM_A  p_RM_AC  #Phosphorylation of MEK1/2 on AL (activation loop) by CRAF
      p_RM_C  p_RM_AC  #Phosphorylation of MEK1/2 on AL (activation loop) by ARAF

  f_M2E           5            #MEK2/MEK1 catalytic activity ratio
  p_M1E           5e-7         #phosphorylation of ERK on AL by MEK1
  p_M2E           p_M1E*f_M2E  #phosphorylation of ERK on AL by MEK2

  q_al_MEK        3e-3   #dephosphorylation of MEK activation loop sites (pseudo-first-order)
  q_al_ERK        1e-2   #dephosphorylation of ERK activation loop sites (pseudo-first-order)

  q_MP            1e+2   #MEK dephosphorylation at activation site after negative feedback phosphorylation by ERK (first-order)

end parameters

begin molecule types

  # EGF receptor with inactive and active receptor states and an SOS binding site.
  EGFR(egf~I~A,sos)

  # SOS guanine nucleotide exchange factor with EGFR, RAS-rem, and feedback sites.
  SOS(egfr,rem,S~P0~P1~P2~P3~P4)

  # RAS GTPase with SOS, dimerization, RAF binding, and GDP/GTP nucleotide state.
  RAS(sos,dim,raf,nt~GDP~GTP)

  # Aggregate RasGAP activity for RASA1, RASA2, and NF1.
  RasGAP(ras)

  # Generalized RAF molecule covering ARAF, BRAF, and CRAF isoforms.
  RAF(iso~C~B~A,ras,N_ftt~P0~P1,dif~P0~P1,NtA~P0~P1,C_ftt~P0~P1)

  # MEK kinase covering MEK1 and MEK2, dimerization, feedback, and activation sites.
  MEK(iso~mek1~mek2,dim,NFS~P0~P1,al~P0~P1~P2)

  # ERK kinase with inactive, singly phosphorylated, and doubly phosphorylated states.
  ERK(al~P0~P1~P2)

  # 14-3-3 monomer with RAF binding, dimerization, and minimal isoform state.
  FTT(iso~A~B,raf,dim)

end molecule types

begin seed species

  EGFR(egf~I,sos)                                EGFR_tot_f  # molecules
  SOS(egfr,rem,S~P0)                             SOS_tot  # molecules
  RAS(sos,dim,raf,nt~GDP)                        RAS_tot_f  # molecules
  RasGAP(ras)                                    RasGAP_tot_f  # molecules
  RAF(iso~A,ras,N_ftt~P0,dif~P0,NtA~P0,C_ftt~P0) ARAF_tot  # molecules
  RAF(iso~C,ras,N_ftt~P0,dif~P0,NtA~P0,C_ftt~P0) CRAF_tot  # molecules
  RAF(iso~B,ras,N_ftt~P0,dif~P0,NtA~P1,C_ftt~P1) BRAF_tot  # molecules
  MEK(iso~mek1,dim,NFS~P0,al~P0)                 MEK_tot*f_M1  # molecules
  MEK(iso~mek2,dim,NFS~P0,al~P0)                 MEK_tot*(1-f_M1)  # molecules
  ERK(al~P0)                                     ERK_tot  # molecules
  FTT(iso~A,raf,dim!9).FTT(iso~A,raf,dim!9)      FTT_tot  # molecules

end seed species

begin observables

# Here we define a selection of molecular species the levels of which we trace.

  # Signaling cascade activity
  #Molecules  EGFR_A             EGFR(egf~A)
  #Molecules  EGFR_SOS           EGFR(sos!+)
  #Molecules  SOS_RAS_GDP        SOS(rem!1,egfr!+).RAS(sos!1,dim,raf,nt~GDP)
