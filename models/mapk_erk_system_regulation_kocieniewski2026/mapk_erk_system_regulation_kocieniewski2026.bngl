      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8,raf) + RAF(iso~A,ras,dif!4).RAF(iso~C,ras,dif!4)   u_GAC_dim_GTP

    #(AA) (-) RAS dimer--{ARAF--ARAF} dissociation

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~A,ras!3,dif!4).RAF(iso~A,ras!2,dif!4) -> \
      RAS(sos,nt~GTP,dim!8,raf).RAS(sos,nt~GTP,dim!8,raf) + RAF(iso~A,ras,dif!4).RAF(iso~A,ras,dif!4)   u_GAA_dim_GTP


  # --- [3] RAF--RAF dimerization, RAF activation -------------------------------------------------------------
  # +++ DIMERS ON RAS PLATFORMS++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

  ## (+) RAFs homo- and heterodimerizaton on RAS platform

    #(B) {BRAF--BRAF} homodimerization on RAS

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!2,dif~P0).RAF(iso~B,ras!3,dif~P0) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!2,dif~P0!7).RAF(iso~B,ras!3,dif~P0!7) b_GBB_dim

  #(C/A) {BRAF--C/ARAF} heterodimerization on RAS

    #(C) {BRAF--CRAF} heterodimerization on RAS

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!2,dif~P0).RAF(iso~C,ras!3,dif~P0) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!2,dif~P0!7).RAF(iso~C,ras!3,dif~P0!7) b_GBC_dim

    #(A) {BRAF--ARAF} heterodimerization on RAS

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!2,dif~P0).RAF(iso~A,ras!3,dif~P0) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!2,dif~P0!7).RAF(iso~A,ras!3,dif~P0!7) b_GBA_dim

  #(C/A) {C/ARAF--C/ARAF} homo- and heterodimerization on RAS

    #(CC) {CRAF--CRAF} homodimerization on RAS

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~C,ras!2,dif~P0).RAF(iso~C,ras!3,dif~P0) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~C,ras!2,dif~P0!7).RAF(iso~C,ras!3,dif~P0!7) b_GCC_dim

    #(AC) {ARAF--CRAF} heterodimerization on RAS

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~A,ras!2,dif~P0).RAF(iso~C,ras!3,dif~P0) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~A,ras!2,dif~P0!7).RAF(iso~C,ras!3,dif~P0!7) b_GAC_dim

    #(AA) {ARAF--ARAF} homodimerization on RAS

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~A,ras!2,dif~P0).RAF(iso~A,ras!3,dif~P0) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~A,ras!2,dif~P0!7).RAF(iso~A,ras!3,dif~P0!7) b_GAA_dim

# (-) RAF dimers "undimerization" on RAS platform due to negative feedback phosphorylation on DIF
# (B) {BRAF--BRAF} dissociation on RAS platform due to negative feedback phosphorylation on DIF

    RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!2,dif~P1!7).RAF(iso~B,ras!3,dif~P1!7) -> \
    RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!2,dif~P1).RAF(iso~B,ras!3,dif~P1)     u_GBB_dim_fast  exclude_reactants(1,RAF(iso~B,C_ftt!5,dif!8).RAF(iso~B,C_ftt!6,dif!8).FTT(raf!5,dim!9).FTT(raf!6,dim!9))

  #(C/A) {BRAF--C/ARAF} dissociation on RAS platform due to negative feedback phosphorylation on DIF

  #(C) {BRAF--CRAF} dissociation (negative feedback)

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!2,dif~P1!7).RAF(iso~C,ras!3,dif~P1!7) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!2,dif~P1).RAF(iso~C,ras!3,dif~P1)     u_GBC_dim_fast  exclude_reactants(1,RAF(iso~B,C_ftt!5,dif!8).RAF(iso~C,C_ftt!6,dif!8).FTT(raf!5,dim!9).FTT(raf!6,dim!9))

    #(A) {BRAF--ARAF} dissociation (negative feedback)

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!2,dif~P1!7).RAF(iso~A,ras!3,dif~P1!7) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~B,ras!2,dif~P1).RAF(iso~A,ras!3,dif~P1)     u_GBA_dim_fast  exclude_reactants(1,RAF(iso~B,C_ftt!5,dif!8).RAF(iso~A,C_ftt!6,dif!8).FTT(raf!5,dim!9).FTT(raf!6,dim!9))

  #(C/A) {C/ARAF--C/ARAF} dissociation on RAS platform due to negative feedback phosphorylation on DIF

    #(CC)  {CRAF--CRAF} dissociation (NF)

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~C,ras!2,dif~P1!7).RAF(iso~C,ras!3,dif~P1!7) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~C,ras!2,dif~P1).RAF(iso~C,ras!3,dif~P1)     u_GCC_dim_fast  exclude_reactants(1,RAF(C_ftt!5,dif!8).RAF(C_ftt!6,dif!8).FTT(raf!5,dim!9).FTT(raf!6,dim!9))

    #(CA) {CRAF--ARAF} dissociation (NF)

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~A,ras!2,dif~P1!7).RAF(iso~C,ras!3,dif~P1!7) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~A,ras!2,dif~P1).RAF(iso~C,ras!3,dif~P1)     u_GAC_dim_fast  exclude_reactants(1,RAF(C_ftt!5,dif!8).RAF(C_ftt!6,dif!8).FTT(raf!5,dim!9).FTT(raf!6,dim!9))

      #(CC) {ARAF--ARAF} dissociation (NF)

      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~A,ras!2,dif~P1!7).RAF(iso~A,ras!3,dif~P1!7) -> \
      RAS(sos,nt~GTP,dim!8,raf!2).RAS(sos,nt~GTP,dim!8,raf!3).RAF(iso~A,ras!2,dif~P1).RAF(iso~A,ras!3,dif~P1)     u_GAA_dim_fast  exclude_reactants(1,RAF(C_ftt!5,dif!8).RAF(C_ftt!6,dif!8).FTT(raf!5,dim!9).FTT(raf!6,dim!9))

# +++ DIMERS IN THE CYTOPLASM +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

  #(B) (-) {BRAF--BRAF} "undimerization" in the cytoplasm

    RAF(iso~B,ras,dif!8).RAF(iso~B,ras,dif!8) -> \
    RAF(iso~B,ras,dif) + RAF(iso~B,ras,dif)   u_BB_dim

  #(C/A) (-) {BRAF--C/ARAF} hetordimers "undimerization" in the cytoplasm
  #(C) {BRAF--CRAF} dissociation in the cytoplasm

    RAF(iso~B,ras,dif!8).RAF(iso~C,ras,dif!8) -> \
    RAF(iso~B,ras,dif) + RAF(iso~C,ras,dif)   u_BC_dim

  #(A) {BRAF--ARAF} dissociation in the cytoplasm

    RAF(iso~B,ras,dif!8).RAF(iso~A,ras,dif!8) -> \
    RAF(iso~B,ras,dif) + RAF(iso~A,ras,dif)   u_BA_dim

  #(A/C) (-) {A/CRAF--A/CRAF} "undimerization" in the cytoplasm

        #(CC)

    RAF(iso~C,ras,dif!8).RAF(iso~C,ras,dif!8) -> \
    RAF(iso~C,ras,dif) + RAF(iso~C,ras,dif)   u_CC_dim

        #(AC)

    RAF(iso~A,ras,dif!8).RAF(iso~C,ras,dif!8) -> \
    RAF(iso~A,ras,dif) + RAF(iso~C,ras,dif)   u_AC_dim

        #(AA)

    RAF(iso~A,ras,dif!8).RAF(iso~A,ras,dif!8) -> \
    RAF(iso~A,ras,dif) + RAF(iso~A,ras,dif)   u_AA_dim

  #(B) (-) {BRAF--BRAF} "undimerization" in the cytoplasm due to the negative feedback

    RAF(iso~B,ras,dif~P1!8).RAF(iso~B,ras,dif~P1!8) -> \
    RAF(iso~B,ras,dif~P1) + RAF(iso~B,ras,dif~P1)   u_BB_dim_fast

  #(C/A) (-) {BRAF--C/ARAF} heterodimers "undimerization" in the cytoplasm due to the negative feedback

    #(C) {BRAF--CRAF} hetordimers "undimerization" in the cytoplasm due to the negative feedback

    RAF(iso~B,ras,dif~P1!8).RAF(iso~C,ras,dif~P1!8) -> \
    RAF(iso~B,ras,dif~P1) + RAF(iso~C,ras,dif~P1)   u_BC_dim_fast

    #(A) {BRAF--ARAF} hetordimers "undimerization" in the cytoplasm due to the negative feedback

    RAF(iso~B,ras,dif~P1!8).RAF(iso~A,ras,dif~P1!8) -> \
    RAF(iso~B,ras,dif~P1) + RAF(iso~A,ras,dif~P1)   u_BA_dim_fast                                            #3

  #(C/A) (-) {BRAF--C/ARAF} "undimerization" in the cytoplasm due to the negative feedback

        #(CC)

      RAF(iso~C,ras,dif~P1!8).RAF(iso~C,ras,dif~P1!8) -> \
      RAF(iso~C,ras,dif~P1) + RAF(iso~C,ras,dif~P1)   u_CC_dim_fast

    #(AC)
      RAF(iso~A,ras,dif~P1!8).RAF(iso~C,ras,dif~P1!8) -> \
      RAF(iso~A,ras,dif~P1) + RAF(iso~C,ras,dif~P1)   u_AC_dim_fast

   #(AA)
      RAF(iso~A,ras,dif~P1!8).RAF(iso~A,ras,dif~P1!8) -> \
      RAF(iso~A,ras,dif~P1) + RAF(iso~A,ras,dif~P1)   u_AA_dim_fast

  # ---RAF STABILIZATION BY 14-3-3-----INTERMOLECULAR (DE)CROSSLINKING----------------------------------------
  # +++INTERMOLECULAR CROSSLINKING++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

  #  (+) RAF dimers stabilization by 14-3-3 (cross-linking)
  #(B) Dimer crosslinking to BRAF (from BRAF)

    RAF(iso~B,C_ftt!5,dif!8).RAF(iso~B,dif!8,C_ftt~P1).FTT(raf!5,dim!9).FTT(iso~A,raf,dim!9) -> \
    RAF(iso~B,C_ftt!5,dif!8).RAF(iso~B,dif!8,C_ftt~P1!6).FTT(raf!5,dim!9).FTT(iso~A,raf!6,dim!9)  b_FB_inter

  #(C/A) Dimer crosslinking to BRAF from C/ARAF

  #(C) Dimer crosslinking to BRAF from CRAF

      RAF(iso~B,C_ftt!5,dif!8).RAF(iso~C,dif!8,C_ftt~P1).FTT(raf!5,dim!9).FTT(iso~A,raf,dim!9) -> \
      RAF(iso~B,C_ftt!5,dif!8).RAF(iso~C,dif!8,C_ftt~P1!6).FTT(raf!5,dim!9).FTT(iso~A,raf!6,dim!9) b_FC_inter

    #(A) Dimer crosslinking to BRAF from ARAF

      RAF(iso~B,C_ftt!5,dif!8).RAF(iso~A,dif!8,C_ftt~P1).FTT(raf!5,dim!9).FTT(iso~A,raf,dim!9) -> \
      RAF(iso~B,C_ftt!5,dif!8).RAF(iso~A,dif!8,C_ftt~P1!6).FTT(raf!5,dim!9).FTT(iso~A,raf!6,dim!9) b_FA_inter

  # +++ INTERMOLECULAR DE-CROSSLINKING ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
  # (-) undoing: RAF dimers stabilization by 14-3-3 (cross-linking)

  # (B) 14-3-3 De-crosslinking from BRAF-C_ftt

    RAF(iso~B,dif!8,C_ftt!5).RAF(iso~B,dif!8,C_ftt!6).FTT(raf!5,dim!9).FTT(raf!6,dim!9) -> \
    RAF(iso~B,dif!8,C_ftt!5).RAF(iso~B,dif!8,C_ftt).FTT(raf!5,dim!9).FTT(raf,dim!9)      u_FB_inter

  # (C/A) 14-3-3 De-crosslinking from C/ARAF-C_ftt

    #(C) 14-3-3 De-crosslinking from CRAF-C_ftt

      RAF(iso~B,dif!8,C_ftt!5).RAF(iso~C,dif!8,C_ftt!6).FTT(raf!5,dim!9).FTT(raf!6,dim!9) -> \
      RAF(iso~B,dif!8,C_ftt!5).RAF(iso~C,dif!8,C_ftt).FTT(raf!5,dim!9).FTT(raf,dim!9)      u_FC_inter

    #(A) 14-3-3 De-crosslinking from ARAF-C_ftt

      RAF(iso~B,dif!8,C_ftt!5).RAF(iso~A,dif!8,C_ftt!6).FTT(raf!5,dim!9).FTT(raf!6,dim!9) -> \
      RAF(iso~B,dif!8,C_ftt!5).RAF(iso~A,dif!8,C_ftt).FTT(raf!5,dim!9).FTT(raf,dim!9)      u_FA_inter

  # ---- [4] MEK and ERK activation/deactivation ----------------------------------------------------------------

  ## (+) MEK phoshorylation by RAF subunit

  #Both subunits are phosphorylated on NtA

   RAF(dif!1,NtA~P1,C_ftt~P1!?).RAF(dif!1,NtA~P1,C_ftt~P1!?) + MEK(al~P0) -> \
    RAF(dif!1,NtA~P1,C_ftt~P1!?).RAF(dif!1,NtA~P1,C_ftt~P1!?) + MEK(al~P1)  2*2*p_RM

    RAF(dif!1,NtA~P1,C_ftt~P1!?).RAF(dif!1,NtA~P1,C_ftt~P1!?) + MEK(al~P1) -> \
    RAF(dif!1,NtA~P1,C_ftt~P1!?).RAF(dif!1,NtA~P1,C_ftt~P1!?) + MEK(al~P2)  2*1*p_RM

  #Only one subunit is phosphorylated on NtA

    RAF(dif!1,NtA~P1,C_ftt~P1!?).RAF(dif!1,NtA~P0,C_ftt~P1!?) + MEK(al~P0) -> \
    RAF(dif!1,NtA~P1,C_ftt~P1!?).RAF(dif!1,NtA~P0,C_ftt~P1!?) + MEK(al~P1)  2*p_RM

    RAF(dif!1,NtA~P1,C_ftt~P1!?).RAF(dif!1,NtA~P0,C_ftt~P1!?) + MEK(al~P1) -> \
    RAF(dif!1,NtA~P1,C_ftt~P1!?).RAF(dif!1,NtA~P0,C_ftt~P1!?) + MEK(al~P2)  1*p_RM

  ## (-) MEK dephosphorylation

    MEK(al~P2,NFS~P0) -> MEK(al~P1,NFS~P0)  2*q_al_MEK
    MEK(al~P1,NFS~P0) -> MEK(al~P0,NFS~P0)  1*q_al_MEK

    MEK(al~P2,NFS~P1) -> MEK(al~P1,NFS~P1)  2*q_MP
    MEK(al~P1,NFS~P1) -> MEK(al~P0,NFS~P1)  1*q_MP

    MEK(al~P2).MEK(NFS~P1) -> MEK(al~P1).MEK(NFS~P1)  2*q_MP
    MEK(al~P1).MEK(NFS~P1) -> MEK(al~P0).MEK(NFS~P1)  1*q_MP

  ## (+) ERK phosphorylation by MEK

    MEK(iso~mek1,al~P2) + ERK(al~P0)  -> \
    MEK(iso~mek1,al~P2) + ERK(al~P1)  2*p_M1E

   MEK(iso~mek1,al~P2) + ERK(al~P1)  -> \
   MEK(iso~mek1,al~P2) + ERK(al~P2)  1*p_M1E

    MEK(iso~mek2,al~P2) + ERK(al~P0)  -> \
    MEK(iso~mek2,al~P2) + ERK(al~P1)  2*p_M2E

    MEK(iso~mek2,al~P2) + ERK(al~P1)  -> \
    MEK(iso~mek2,al~P2) + ERK(al~P2)  1*p_M2E

  # (-) ERK dephosphorylation

    ERK(al~P2) -> ERK(al~P1)  2*q_al_ERK
    ERK(al~P1) -> ERK(al~P0)  1*q_al_ERK


  ## --- [5] Negative feedbacks -------------------------------------------------

  # (-) SOS feedback phosphorylation by ppERK

    ERK(al~P2) + SOS(egfr,S~P0) -> \
    ERK(al~P2) + SOS(egfr,S~P1)  4*p_nfSOS

    ERK(al~P2) + SOS(egfr,S~P1) -> \
    ERK(al~P2) + SOS(egfr,S~P2)  3*p_nfSOS

    ERK(al~P2) + SOS(egfr,S~P2) -> \
   ERK(al~P2) + SOS(egfr,S~P3)  2*p_nfSOS

    ERK(al~P2) + SOS(egfr,S~P3) -> \
    ERK(al~P2) + SOS(egfr,S~P4)  1*p_nfSOS

  # (+) SOS dephosphorylation

    SOS(egfr,S~P4) -> SOS(egfr,S~P3)  4*q_nfSOS
    SOS(egfr,S~P3) -> SOS(egfr,S~P2)  3*q_nfSOS
    SOS(egfr,S~P2) -> SOS(egfr,S~P1)  2*q_nfSOS
    SOS(egfr,S~P1) -> SOS(egfr,S~P0)  1*q_nfSOS

  # (-) MEK feedback phosphorylation by ERK at Thr292

    ERK(al~P2) + MEK(iso~mek1,NFS~P0) -> \
    ERK(al~P2) + MEK(iso~mek1,NFS~P1)  p_nfMEK

  # (+) MEK dephosphorylation on Thr292

    MEK(iso~mek1,NFS~P1) -> MEK(iso~mek1,NFS~P0)  q_nfMEK

  # (-) RAF dimer feedback phosphorylation by ppERK at dimerizatin domain (DIF)

    ERK(al~P2) + RAF(dif~P0!8).RAF(dif~P0!8) -> \
    ERK(al~P2) + RAF(dif~P1!8).RAF(dif~P1!8)  p_nfRAF

  # (+) RAFs dephosphorylation at DIF

    RAF(dif~P1) -> RAF(dif~P0)  q_nfRAF

end reaction rules

end model

begin actions
  generate_network({overwrite=>1})  # 609 species, 9088 reactions

  # EGF=10000 pg/ml stimulation after unstimulated equilibration.

  #@protocol: |
  #  Phase 1 equilibrates the model for 360000 s with EGF set to 0 while EGFs
  #  remains at 10000 pg/ml to define the stimulated membrane fraction used by
  #  parameters scaled by Frac. Phase 2 switches EGF to 10000 pg/ml and simulates
  #  6 h of stimulation from the equilibrated state. This sequential protocol is
  #  intentionally stateful, matching the source BNGL action block.

  #@figure: Fig. 3a in Kocieniewski and Lipniacki (2026)

  setParameter("EGFs",10000)
  setParameter("EGF",0)
  simulate({method=>"ode",suffix=>"ode",t_end=>360000,n_steps=>360,rtol=>1e-9})

  setParameter("EGF",10000)
  simulate({method=>"ode",suffix=>"ode",t_end=>6*3600,n_steps=>6*3600/10,rtol=>1e-9})
end actions
