  DNA50(site!1~cdsb).Ku(dna!1,cs,cys~ox) -> DNA50(site~cdsb) + Ku(dna,cs,cys~ox)   kdku4

  #Senescent Shift Rules

  # p21-driven senescence counter (explicit re-encoding of the published
  # NFsim PLUS/MINUS integer-operator counter; see header #@note).
  # Increment int 1->10 while p21 is high (kplus):
  Sen(int~1,State~normal) -> Sen(int~2,State~normal) kplus()
  Sen(int~2,State~normal) -> Sen(int~3,State~normal) kplus()
  Sen(int~3,State~normal) -> Sen(int~4,State~normal) kplus()
  Sen(int~4,State~normal) -> Sen(int~5,State~normal) kplus()
  Sen(int~5,State~normal) -> Sen(int~6,State~normal) kplus()
  Sen(int~6,State~normal) -> Sen(int~7,State~normal) kplus()
  Sen(int~7,State~normal) -> Sen(int~8,State~normal) kplus()
  Sen(int~8,State~normal) -> Sen(int~9,State~normal) kplus()
  Sen(int~9,State~normal) -> Sen(int~10,State~normal) kplus()
  # Decrement int 10->1 while p21 is low; the Sen_Min guard in kminus
  # blocks decrementing below 1 (kminus):
  Sen(int~2,State~normal) -> Sen(int~1,State~normal) kminus()
  Sen(int~3,State~normal) -> Sen(int~2,State~normal) kminus()
  Sen(int~4,State~normal) -> Sen(int~3,State~normal) kminus()
  Sen(int~5,State~normal) -> Sen(int~4,State~normal) kminus()
  Sen(int~6,State~normal) -> Sen(int~5,State~normal) kminus()
  Sen(int~7,State~normal) -> Sen(int~6,State~normal) kminus()
  Sen(int~8,State~normal) -> Sen(int~7,State~normal) kminus()
  Sen(int~9,State~normal) -> Sen(int~8,State~normal) kminus()
  Sen(int~10,State~normal) -> Sen(int~9,State~normal) kminus()
  Sen(int~10,State~normal) -> Sen(int~10,State~sen) ksen

  Ku(dna,cs,cys~?) -> Sink() kKuDown() * kKustop()
  PARP(dna,liIII) -> Sink() kParpDown() * kParpstop()

end reaction rules

end model

begin actions

  #@note: |
  #  Published protocol: the study simulated the model NETWORK-FREE with NFsim,
  #  as an ensemble of ~50 stochastic single-cell runs of 2400 min (40 h) each
  #  (SI file s011 ran 50 x simulate_nf, t_end=2400, n_steps=2400, gml=1e9).
  #  The block below runs one representative single-cell trajectory of that
  #  protocol at 10-min output resolution (n_steps=240) to keep the committed
  #  reference lean; run_dolan2015.py reproduces the full multi-seed ensemble
  #  and the three-engine (BNG NFsim / bngsim NFsim / bngsim RuleMonkey)
  #  network-free agreement cross-check. gml is set to the 32-bit max per house
  #  style (the published 1e9 is likewise far above the ~2500-molecule count).

  #@protocol: |
  #  Single-cell stochastic time course over 2400 min (40 h) of chronic
  #  background-ROS DNA damage, network-free (NFsim). ROS holds near
  #  kROS/kdROS = 10 molecules; DSBs and damage foci appear transiently; p53,
  #  p21 and the Ku70/80, PARP-1, DNA-PKcs, Ligase III/IV repair pools are
  #  tracked once per 10 min. Under normal background ROS no cell enters early
  #  senescence (Senescent_Counter stays 0).

  #@figure: Fig. 4 in Dolan et al. (2015)

  simulate({method=>"nf",suffix=>"nfr",t_start=>0,t_end=>2400,n_steps=>240,\
    gml=>2147483647})

end actions
