  #Senesent Feedback

  #Ku Redox

  Ku(dna,cs,cys~red) + ROS() -> Ku(dna,cs,cys~ox) + ROS() kox
  Ku(dna,cs,cys~ox)  -> Ku(dna,cs,cys~red) kred

