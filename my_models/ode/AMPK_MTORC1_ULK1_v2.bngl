#ATG101_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^ATG101_iBAQ1_HEK293 # copies per cell
RB1CC1_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^RB1CC1_iBAQ1_HEK293 # copies per cell
ULK1_cpc_HEK293   = iBAQ1_to_cpc_HEK293*10^ULK1_iBAQ1_HEK293   # copies per cell

AMBRA1_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^AMBRA1_iBAQ1_HEK293 # copies per cell

BECN1_cpc_HEK293  = iBAQ1_to_cpc_HEK293*10^BECN1_iBAQ1_HEK293  # copies per clll

# Special considerations are required to estimate copy numbers for PRKAG2, ATG13 and ATG101
# because of missing data. For these proteins, we will use their reported iBAQ3 values 
# and an iBAQ3-to-cpc conversion factor based on the LFQ1 and LFQ3 values reported for 
# ULK1 and ATG101, respectively. LFQ values are supposed to be comparable across experiments.
# We use this equation to find a factor that converts iBAQ3 values into copy numbers:
#  iBAQ1_to_cpc*iBAQ1/LFQ1=iBAQ3_to_cpc*iBAQ3/LFQ3.
PRKAG2_iBAQ3_HEK293 4.497869 # dimensionless
ATG13_iBAQ3_HEK293  5.289053 # dimensionless
ATG101_iBAQ3_HEK293 5.615771 # dimensionless
ATG101_LFQ3_HEK293  6.828795 # dimensionless
ULK1_LFQ1_HEK293    6.613694 # dimensionless

iBAQ3_to_cpc_HEK293=iBAQ1_to_cpc_HEK293*\
(10^((ATG101_LFQ3_HEK293-ULK1_LFQ1_HEK293)-(ATG101_iBAQ3_HEK293-ULK1_iBAQ1_HEK293))) 

PRKAG2_cpc_HEK293 = iBAQ3_to_cpc_HEK293*10^PRKAG2_iBAQ3_HEK293 # copies per cell
ATG13_cpc_HEK293  = iBAQ3_to_cpc_HEK293*10^ATG13_iBAQ3_HEK293  # copies per cell
ATG101_cpc_HEK293 = iBAQ3_to_cpc_HEK293*10^ATG101_iBAQ3_HEK293 # copies per cell

