Molecules MTORtot MTOR()
Molecules RPTORtot RPTOR()
Molecules MLST8tot MLST8()

Molecules lysosomalRHEB_GTP RHEB(G~GTP!?,loc~lys)
Molecules lysosomalRHEB_GDP RHEB(G~GDP!?,loc~lys)

#Molecules rapa_freeFKBP1A FKBP1A(FKBP~0!?)
