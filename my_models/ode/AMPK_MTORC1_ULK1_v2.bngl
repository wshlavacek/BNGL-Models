# bottom of "database of measured protein copy numbers" section
#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

###################################################
# cell line-specific protein copy number settings #
###################################################

# binding partner of rapamycin
FKBP1A_cpc = FKBP1A_cpc_U2OS

# components of MTOR complex 1 (MTORC1)
MTOR_cpc  = MTOR_cpc_U2OS 
RPTOR_cpc = RPTOR_cpc_U2OS
MLST8_cpc = MLST8_cpc_U2OS

# effectors of MTORC1-mediated regulation of translation
RPS6KB1_cpc  = RPS6KB1_cpc_U2OS
EIF4EBP1_cpc = EIF4EBP1_cpc_U2OS

# components of the Ragulator complex, part of the amino acid-sensing machinery
LAMTOR1_cpc = LAMTOR1_cpc_U2OS
LAMTOR2_cpc = LAMTOR2_cpc_U2OS
LAMTOR3_cpc = LAMTOR3_cpc_U2OS
LAMTOR4_cpc = LAMTOR4_cpc_U2OS
LAMTOR5_cpc = LAMTOR5_cpc_U2OS

# Rag proteins (components of the amino acid-sensing machinery)
RRAGA_cpc = RRAGA_cpc_U2OS
RRAGC_cpc = RRAGC_cpc_U2OS

# components of the growth factor-sensing machinery
RHEB_cpc  = RHEB_cpc_U2OS
TSC2_cpc   = TSC2_cpc_U2OS

# subunits of AMPK (a component of the energy-sensing machinery)
#  comments:
#   - We consider both isoforms of the AMPK beta subunit.
PRKAA1_cpc = PRKAA1_cpc_U2OS 
PRKAB1_cpc = PRKAB1_cpc_U2OS 
PRKAB2_cpc = PRKAB2_cpc_U2OS 
PRKAG1_cpc = PRKAG1_cpc_U2OS 

# LKB1 (a component of the energy-sensing machinery)
STK11_cpc  = STK11_cpc_U2OS 

# components of the ULK1 complex
ATG13_cpc  = ATG13_cpc_U2OS 
ATG101_cpc = ATG101_cpc_U2OS 
RB1CC1_cpc = RB1CC1_cpc_U2OS 
ULK1_cpc   = ULK1_cpc_U2OS  

# effectors of ULK1-mediated regulation of autophagy
AMBRA1_cpc = AMBRA1_cpc_U2OS
BECN1_cpc  = BECN1_cpc_U2OS

##########################################
# abundances of small-molecule compounds #
##########################################

#################
# ATP abundance #
#################

# ATP concentration
#  comments:
#   - Fang et al. (2016) reported an ATP concentration of 3.7 mM in HeLa cells.
#   - We will assume that the total concentration of ATP is 3.7 mM for all cell lines of interest.
#   - We assume that ATP concentration is roughly constant across conditions of interest.
ATP_conc 3.7e-3 # M
ATP_cpc=ATP_conc*(NA*Vcyt) # copies per cell

#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# top of "input parameters" section

####################
# input parameters #
####################
#---
# input parameters:
#  - AA_conc_uM
#  - growth_factor_conc_pM
#  - glucose_conc_mM
#  - AZD8055_isPresent (True or False) and AZD8055_conc_nM
#    if(AZD8055_isPresent==True,AZD8055_conc_nM,0)
#  - rapamycin_isPresent (True or False) and rapamycin_conc_nM
#    if(rapamycin_isPresent==True,rapamycin_conc_nM,0)
#---

############################
# amino acid concentration #
############################

# the effective external concentration of amino acids 
#  comments:
#   - This concentration determines the abundance of Rag dimers containing 
#     one copy of GTP-loaded RagA and one copy of GDP-loaded RagC.
AA_conc_uM 100 # uM

###############################
# growth factor concentration #
###############################

# the external growth factor concentration (pM)
#  comments:
#   - This concentration determines the abundance of lysosomal GTP-loaded RHEB.
growth_factor_conc_pM 1000 # pM

#########################
# glucose concentration #
#########################

# the external glucose concentration (mM)
#  comments:
#   - This concentration determines the [AMP]:[ATP] ratio.
glucose_conc_mM 5 # mM

############################################################################
# AZD8055_isPresent (True or False) and AZD8055 concentration (if present) #
############################################################################

# AZD8055 indicator
#  comments:
#   - Set to 0 if AZD8055 is absent.
#   - Set to 1 if AZD8055 is present.
AZD8055_isPresent 0 # Boolean (0=False or 1=True)

# the external AZD8055 concentration (if AZD8055 is present)
#  comments:
#   - AZD8055 is an ATP-competitive inhibitor of MTOR kinase activity.
AZD8055_conc_nM 100 # nM

################################################################################
# rapamycin_isPresent (True or False) and rapamycin concentration (if present) #
################################################################################

# rapamycin indicator
#  comments:
#   - Set to 0 if rapamycin is absent.
#   - Set to 1 if rapamycin is present.
rapamycin_isPresent 0 # Boolean (0=False or 1=True)

# the external rapamycin concentration (if rapamycin is present)
#  comments:
#   - Rapamycin is an inhibitor of MTORC1 kinase activity.
#   - In this model, the mechanism of rapamycin-mediated inhibition of MTORC1
#     is as follows. Rapamycin in complex with FKBP12 binds to the FRB domain
#     in MTOR and hinders RAPTOR-tethered substrate access to MTOR's catalytic
#     cleft.
rapamycin_conc_nM 10 # nM 

# bottom of "input parameters" section
#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

#####################################
# parameters for amino acid sensing #
#####################################
#---
# parameters for amino acid sensing
#  coments:
#   - These parameters convert a specified amino acid concentration into
#     abundance of Rag dimers containing one copy of GTP-loaded RagA and one copy
#     of GDP-loaded RagC.
#---

# amino acid concentration 
#AA_conc_uM 100 # uM

# amino acid concentration that yields 50% activation of RagC/D GAP
EC50_AA_uM 25 # uM

# rate constant for transition from GDP- to GTP-loading of RagC/D
kRagCD_exchange 0.1 # /s

# maximum pseudo first-order rate constant for transition from GTP- to GDP-loading of RagC/D
kRagCD_AA_regulated_GAP_activity_max 1 # /s

# pseudo first-order rate constant for transition from GTP- to GDP-loading of RagC/D (RRAGC)
kRagCD_AA_regulated_GAP_activity=\
kRagCD_AA_regulated_GAP_activity_max*AA_conc_uM/(AA_conc_uM+EC50_AA_uM) # /s

########################################
# parameters for growth factor sensing #
########################################
#---
# parameters for growth factor sensing
#  comments:
#   - These parameters convert a specified growth factor concentration into
#     abundance of lysosomal GTP-loaded RHEB.
#---

# growth factor concentration
#growth_factor_conc_pM 1000 # pM

# concentration of growth factor that yields 50% inhibition of TSC2 GAP activity directed at lysosomal RHEB
IC50_growth_factor_pM 10 # pM

# rate constant for transition from GDP- to GTP-loading of RHEB
kRHEB_exchange 0.1 # /s

# maximum pseudo first-order rate constant for transition from GTP- to GDP-loading of RHEB
kRHEB_TSC2_GAP_activity_max 1 # /s

# pseudo first-order rate constant for transition from GTP- to GDP-loading of RHEB
kRHEB_TSC2_GAP_activity=\
kRHEB_TSC2_GAP_activity_max*IC50_growth_factor_pM/(growth_factor_conc_pM+IC50_growth_factor_pM) # /s

# fraction of lysosomal RHEB bound to GTP
fracLysosomalRHEB_GTP=kRHEB_exchange/(kRHEB_exchange+kRHEB_TSC2_GAP_activity) # dimensionless
fracLysosomalRHEB_GDP=1-fracLysosomalRHEB_GTP # dimensionless

# fraction of all RHEB localized to lysosomes (RHEB trafficking is not explicitly considered)
fracRHEB_lys 0.05 # dimensionless

# distribution of lysosomal RHEB between the GDP-loaded (inactive) and GTP-loaded (active) states
fracRHEB_lysGTP=fracRHEB_lys*fracLysosomalRHEB_GTP
fracRHEB_lysGDP=fracRHEB_lys*fracLysosomalRHEB_GDP

##################################
# parameters for glucose sensing #
##################################

###############################################
# setpoint [AMP]:[ATP] and [ADP]:[ATP] ratios #
###############################################

# setpoint [AMP]:[ATP] ratio
#  comments:
#   - We assume that energy sensing is tuned to detect changes in [AMP]:[ATP]
#     ratio centered around a setpoint ratio.
#   - Gowans et al. (2013) measured or estimated the following concentrations in G361 cells:
#     [ATP] = 4.53 mM, [ADP] = 426 uM, and [AMP] = 42.3 uM.
#     Thus, in these cells, the [AMP]:[ATP] ratio is 0.0093.
AMP_ATP_ratio_setpoint 0.01 # dimensionless

# setpoint [ADP]:[ATP] ratio
#  comments:
#   - We assume that the reaction AMP+ATP<->ADP+ADP, catalyzed by adenylate kinase, 
#     is at equilibrium with an equilibrium constant of ~1, meaning that the 
#     following relation holds: [AMP]*[ATP]=[ADP]^2.
ADP_ATP_ratio_setpoint=sqrt(AMP_ATP_ratio_setpoint) # dimensionless

###########################################################################################
# parameters for translating glucose concentration into a value for the [AMP]:[ATP] ratio #
###########################################################################################

# external glucose concentration (mM)
#glucose_conc_mM 5 # mM

glucose_conc=glucose_conc_mM*1e-3 # M
glucose_cpc=glucose_conc*(NA*Vecf) # copies per cell

# external glucose concentration corresponding to the cell's setpoint [AMP]:[ATP] ratio
glucose_conc_setpoint 5e-3 # M

glucose_cpc_setpoint=glucose_conc_setpoint*(NA*Vecf) # copies per cell

# rate of ATP synthesis required for homeostasis, which equals the rate of consumption
#  comments:
#   - This setting is based on the estimated ATP consumption rate of 
#     Flamholz et al. (2014).
#   - We assume that this rate of ATP synthesis/consumption is constant 
#     across conditions of interest.
ATP_synth_rate 5e7*f # copies of ATP consumed (and synthesized from glucose) per cell per s

# apparent rate constant for synthesis of ATP from glucose and ADP
#  comments:
#   - We assume ATP_synth_rate=kATP_synth*[external glucose]*[internal ADP].
kATP_synth=\
ATP_synth_rate/(glucose_cpc_setpoint*ATP_cpc*ADP_ATP_ratio_setpoint) # /(molecule/cell)/s

# [ADP]:[ATP] ratio for the specified external glucose concentration
#  comments:
#   - The formula below can also be written as follows:
#     ADP_ATP_ratio=ADP_ATP_ratio_setpoint*glucose_cpc_setpoint/glucose_cpc.
#     In other words, we are simply taking the [ADP]:[ATP] ratio to be
#     inversely proportional to the external glucose concentration. The ratio is 
#     high when glucose concentration is low; the ratio is low when glucose concentration
#     is high. This relationship is consistent with measurements of how [ADP]:[ATP] ratio
#     depends on glucose concentration (Detimary et al., 1996) - see bottom panel of Fig. 1.
ADP_ATP_ratio=ATP_synth_rate/(kATP_synth*glucose_cpc*ATP_cpc) # dimensionless

# [AMP]:[ATP] ratio for the specified external glucose concentration
#  comments:
#   - We assume that the reaction AMP+ATP<->ADP+ADP, catalyzed by adenylate kinase, 
#     is at equilibrium with an equilibrium constant of ~1, meaning that the 
#     following relation holds: [AMP]*[ATP]=[ADP]^2.
AMP_ATP_ratio=ADP_ATP_ratio*ADP_ATP_ratio # dimensionless

AMP_conc=AMP_ATP_ratio*ATP_conc # M
AMP_cpc=AMP_conc*(NA*Vcyt) # copies per cell

#############################################################
# parameters for AZD8055 inhibition of MTOR kinase activity #
#############################################################

# AZD8055 concentation (nM), if AZD8055 is present
#  comments:
#   - the initial external concentration of AZD8055 (if AZD8055 is present)
#   - AZD8055 is an ATP-competitive inhibitor of MTOR (Chresta et al., 2010).
#   - https://pubchem.ncbi.nlm.nih.gov/compound/azd8055
#   - Martin et al. (2013) used a dose of 100 nM of AZD8055 to inhibit MTOR and induce autophagy.
#   - Do not set the AZD8055 concentration to 0. 
#     Rather, set AZD8055_isPresent to 0 for the case where AZD8055 is absent.
#AZD8055_conc_nM 100 # nM
AZD8055_conc=AZD8055_conc_nM*1e-9 # M

AZD8055_cpc=AZD8055_conc*(NA*Vecf) # copies per cell

# affinities of AZD8055 and ATP for the ATP-binding site in MTOR
#  comments:
#   - affinity = 1/KD, where KD is the equilibrium dissociation constant
#   - Using an in vitro kinase activity assay, Chresta et al. (2010) measured 
#     IC50 values at different doses of ATP for AZD8055-mediated inhibition of 
#     MTOR kinase domain-catalyzed phosphorylation of a peptide from RPS6KB1 (p70 S6K1).
#   - See Figure 1B in Chresta et al. (2010).
#   - KI = KD (for AZD8055 binding to MTOR) and KM (the Michaelis constant for ATP) were
#     determined using Equation (5) in Cheng and Prusoff (1973): IC50 = KI*([ATP]/KM-1).
#   - KM was determined to be 15 uM (from the x-intercept).
#   - KI was determined to be 1.3 nM (from the slope = KI/KM).
#   - Kang et al. (2013) measured kcat values for MTORC1 substrates between 2 and 5 per min
#     (0.03 to 0.08 per s). Comparable estimates of kcat were obtained by Tao et al. (2010).
#   - We assume that the value of the dissociation rate constant for ATP binding to MTOR 
#     is much larger than the value of kcat. Thus, KD for ATP binding to MTOR is approximately KM.
#   - Chresta et al. (2010) observed that phosphorylation of S235/S236 in RPS6 was reduced by 50%
#     at an AZD8055 concentration of approximately 30 nM. See Figure 2A.
#   - We will assume an EC50 of 30 nM for MTORC1 substrates.
#   - We will assume that the EC50 is determined by KI, KM, and the free fraction of ATP in a cell.
KD_AZD8055_MTOR 1.3e-9 # M
kf_AZD8055_MTOR 1e6 # /M/s (not to be used in reaction rules block)
kr_AZD8055_MTOR=kf_AZD8055_MTOR*KD_AZD8055_MTOR # /s
KD_ATP_MTOR 15e-6 # M
kf_ATP_MTOR 1e7 # /M/s (not to be used in reaction rules block)
kr_ATP_MTOR=kf_ATP_MTOR*KD_ATP_MTOR # /s
EC50_AZD8055_MTORC1substrate 30e-9 # M
freefractionATP=(KD_ATP_MTOR/ATP_conc)*(1+EC50_AZD8055_MTORC1substrate/KD_AZD8055_MTOR)

# parameters appearing in approximate rate laws for ATP<->AZD8055 exchange
kpA=kf_ATP_MTOR*ATP_conc*freefractionATP # /s
kmA=kr_ATP_MTOR # /s
KA=kpA/kmA # dimensionless
kpB=kf_AZD8055_MTOR*AZD8055_conc # /s
kmB=kr_AZD8055_MTOR # /s
KB=kpB/kmB # dimensionless

# We set the abundances of MTOR(PIKK~0), MTOR(PIKK~ATP), and MTOR(PIKK~AZD8055) 
# based on the following considerations:
#  - The total abundances of ATP, AZD8055, and MTOR are conserved (on time scales of interest).
#  - The number of copies of AZD8055 per cell is determined by the initial external
#    concentration of AZD8055.
#  - Transport of AZD8055 into and out of a cell is fast, such that
#    the internal and external concentrations of *free* AZD8055 are identical.
#  - Binding of ATP and AZD8055 to the ATP-binding site in MTOR is in equilibrium, such that
#    [ATP]*[MTOR]=KD_ATP_MTOR*[ATP.MTOR] and 
#    [AZD8055]*[MTOR]=KD_AZD8055_MTOR*[AZD8055.MTOR].
#  - ATP is available in excess, such that MTOR does not significantly deplete the pool of free ATP.
#  - Only a fraction of total ATP is free.
# Given the assumptions above, the abundances of MTOR(PIKK~0), MTOR(PIKK~ATP), and MTOR(PIKK~AZD8055)
# can be found by solving a quadratic equation: x^2+b*x+c=0, where x = [MTOR(PIKK~0)]/MTOR_cpc.
# There are four dimensionless parameters (p1 to p4) that appear in the b and c parameters of the
# quadratic equation. All of these parameters (p1, p2, p3, p4, b, and c) are defined below.

# volume ratio Vecf:Vcyt 
p1=Vecf/Vcyt # dimensionless

# [ATP]/KM 
p2=freefractionATP*ATP_cpc/(KD_ATP_MTOR*(NA*Vcyt)) # dimensionless

# [AZD8055]/KI
p3=AZD8055_cpc/(KD_AZD8055_MTOR*(NA*Vcyt)) # dimensionless

# abundance ratio [MTOR]:[AZD8055]
p4=MTOR_cpc/AZD8055_cpc # dimensionless

# parameter -b in x^2+b*x+c=0
minusb=(p4-1)/(p4*(1+p2))-(1+p1)/(p3*p4) # dimensionless

# parameter -c in x^2+b*x+c=0
minusc=(1+p1)/(p4*p3*(1+p2)) # dimensionless

# solution of quadratic equation x^2+b*x+c=0
#  fraction of free PIKK
fracPIKK_0=0.5*minusb+sqrt((0.25*minusb^2)+minusc) 
#  fraction of PIKK bound to ATP
fracPIKK_ATP=fracPIKK_0*p2
#  fraction of PIKK bound to AZD8055
fracPIKK_AZD8055=fracPIKK_0*p3/(1+p1+fracPIKK_0*p3*p4)

#################################################################
# parameters for rapamycin inhibition of MTORC1 kinase activity #
#################################################################

# rapamycin concentration (nM), if rapamycin is present
#  comments:
#   - the initial external concentration of rapamycin (if rapamycin is present)
#   - Rapamycin, in complex with FKBP1A (aka FKBP12), binds the FRB domain in MTOR.
#   - https://pubchem.ncbi.nlm.nih.gov/compound/5284616
#   - Martin et al. (2013) used a dose of 100 nM of rapamycin to inhibit MTOR and induce autophagy.
#   - Do not set the concentration of rapamycin to 0 here to consider the case 
#     where rapamycin is absent. Rather, set rapamycin_isPresent to 0.
#rapamycin_conc_nM 10 # nM 
rapamycin_conc=rapamycin_conc_nM*1e-9 # M

rapamycin_cpc=rapamycin_conc*(NA*Vecf) # copies per cell

#rapamycin_cpc_HEK293     = rapamycin_conc*(NA*Vecf_HEK293)     # copies per cell
#rapamycin_cpc_U2OS       = rapamycin_conc*(NA*Vecf_U2OS)       # copies per cell
#rapamycin_cpc_HeLa_S3    = rapamycin_conc*(NA*Vecf_HeLa_S3)    # copies per cell
#rapamycin_cpc_HeLa_Kyoto = rapamycin_conc*(NA*Vecf_HeLa_Kyoto) # copies per cell

# affinity of rapamycin for FKBP1A (aka FKBP12)
#  comments:
#   - affinity = 1/KD, where KD is the equilibrium dissociation constant
#   - Banaszynski et al. (2005) measured a KD of 0.2 nM for binding of rapamycin to FKBP12.
KD_FKBP1A_rapamycin 0.2e-9 # M

# We set the abundances of FKBP1A(FKBP~0) and FKBP1A(FKBP~rapamycin)
# based on the following considerations:
#  - The total abundances of rapamycin and FKBP1A are conserved (on time scales of interest).
#  - The number of copies of rapamycin per cell is determined by the initial external
#    concentration of rapamycin.
#  - Transport of rapamycin into and out of a cell is fast, such that
#    the internal and external concentrations of *free* rapamycin are identical.
#  - Binding of rapamycin to FKBP1A is in equilibrium, such that 
#    [rapamycin]*[FKBP1A(FKBP~0)]=KD_FKBP1A_rapamycin*[FKBP1A(FKBP~rapamycin)].
# Given the assumptions above, the abundances of FKBP1A(FKBP~0) and FKBP1A(FKBP~rapamycin)
# can be found by solving a quadratic equation: y^2+d*y+e=0, where 
# y=[FKBP1A(FKBP~0)]/FKBP1A_cpc. There are three dimensionless parameters
# (p1, p5 and p6) that appear in the d and e parameters of the quadratic equation. The p1 
# parameter (a volume ratio) is defined above. The p5, p6, d and e parameters are defined below.

# [rapamycin]/KD
p5=rapamycin_cpc/(KD_FKBP1A_rapamycin*(NA*Vcyt)) # dimensionless

# abundance ratio [FKBP1A]:[rapamycin] 
p6=FKBP1A_cpc/rapamycin_cpc # dimensionless

# dimensionless parameter -d in y^2+d*y+e=0
minusd=1-1/p6-(1+p1)/(p5*p6)

# dimensionless parameter -e in y^2+d*y+e=0
minuse=(1+p1)/(p5*p6)

# solution of quadratic equation y^2+d*y+e=0

# fraction of free FKBP1A
fracFKBP1A_0=0.5*minusd+sqrt((0.25*minusd^2)+minuse)

#################################################
# parameters of rate laws associated with rules #
#################################################

#---
# Rate constants:
#  One should specify a rate constant for a bimolecular association reaction under the 
#  assumption that the reaction is of the form A+B->product(s) and that association is 
#  mediated by one and only one binding site in A and by one and only one binding site 
#  in B. BioNetGen automatically adds symmetry numbers and statistical factors as needed 
#  to correct for indistinguishable reactants [in A+A->product(s) reactions] and reaction
#  path degeneracy (viz., reactions involving a reactant with multiple copies of a binding site).
#---

#####################################################################
# parameters for rapamycin-FKBP12 binding to the FRB domain in MTOR #
#####################################################################

# rate constants for FKBP12-bound rapamycin binding to the FRB domain in MTOR
#  comments:
#   - Banaszynski et al. (2005) measured a KD of 12 nM for 
#     rapamycin-FKBP12 interaction with the FRB domain.
#   - The half-life for dissocation of the FRB domain from 
#     rapamycin-FKBP12 is roughly 60 s (Banaszynski et al., 2005).
#     Thus, the dissociation rate constant is approximately 0.01 per s.
KD_FRB_rapaFKBP 12e-9*(NA*Vcyt) # M converted to molecule/cell
kr_FRB_rapaFKBP 0.01 # /s
kf_FRB_rapaFKBP=kr_FRB_rapaFKBP/KD_FRB_rapaFKBP # /(molecule/cell)/s

#####################################
# parameters for assembly of MTORC1 #
#####################################

# MTOR interaction with MLST8
#  comments:
#   - Binding of MLST8 to MTOR appears to be tighter than binding of RPTOR to MTOR
#     (Kim et al., 2003).
#   - For the parameter settings below, the KD is 62.5 nM and the bond lifetime is ~1.3 min.
kf_MLST8_MTOR 2e5/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kr_MLST8_MTOR 0.0125 # /s

# MTOR interaction with RPTOR
#  comments: 
#   - Binding of RPTOR to MTOR appears to be looser than binding of MLST8 to MTOR
#     (Kim et al., 2003).
#   - For the parameter settings below, the KD is 625 nM and the bond lifetime is ~0.27 min.
kf_MTOR_RPTOR 1e5/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kr_MTOR_RPTOR 0.0625 # /s

# positive cooperativity in binding of MLST8 and RPTOR to MTOR
#  comments:
#   - Based on the findings of Kim et al. (2003) and Kakumoto et al. (2015), 
#     we will assume that MLST8 and RPTOR bind MTOR with positive cooperativity.
#   - The enhancement of RPTOR affinity for MTOR caused by MLST8 binding to MTOR is a factor phi.
#   - The enhancement of MLST8 affinity for MTOR caused by RPTOR binding to MTOR must be the same
#     for satisfaction of detailed balance.
phi_MLST8_MTOR_RPTOR 100 # dimensionless
phi_kf_MLST8_MTOR_RPTOR=sqrt(phi_MLST8_MTOR_RPTOR) # dimensionless
phi_kr_MLST8_MTOR_RPTOR=1/sqrt(phi_MLST8_MTOR_RPTOR) # dimensionless

# MTOR homodimerization
#  comments:
#   - For the parameter settings below, the KD is 1 nM and the bond lifetime is ~2.8 hours.
kf_MTOR_MTOR 1e5/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kr_MTOR_MTOR 1e-4 # /s

##########################################################
# parameters for phosphorylation of substrates by MTORC1 #
##########################################################

# rate constants for interaction of RPTOR's RNC domain with the TOS motif in an MTORC1 substrate
kf_RNC_TOS 1e6/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kr_RNC_TOS 0.1 # /s

# hyperphosphorylated 4E-BP1 dissociates from RAPTOR more rapidly 
#  than hypophosphorylated or partially phosphorylated 4E-BP1 
#  This reduces the affinity of the hyperphosphorylated form of 4EBP1 for RAPTOR relative
#  the hypophosphorylated form.
factor_pS65 10 # dimensionless

# parameters for MTOR-catalyzed phosphorylation of a substrate 
# bound to a copy of RPTOR in association with the catalytic copy of MTOR
#  comments:
#   - The substrate is taken to interact with the catalytic cleft of MTOR
#     at a high effective concentration (eps) because of tethering to RPTOR.
#   - If the FRB domain of MTOR is bound by rapamycin-FKBP12, access of the substrate
#     to the catalytic cleft of MTOR is hindered. We introduce a steric hindrance factor (phi)
#     to characterize the reduction in access. The value of phi is 1 in the absence of steric
#     hindrance caused by rapamycin-FKBP12 binding to the FRB domain.
#   - Docking of a tethered substrate in MTOR's catalytic cleft is taken to occur via 
#     a pseudo first-order process S_tethered->S_docked having rate = phi*kp1*eps, 
#     where kp1 is the bimolecular association rate constant for binding of the substrate to MTOR. 
# effective concentration of tethered substrate
eps 1e-5*(NA*Vcyt) # M converted to molecule/cell
# KM/(effective concentration of tethered substrate)
#  Kang et al. (2013) found that rapamycin-sensitive substrates have larger Michaelis constants
#  than rapamycin-resistant substrates.
KM_MTOR_sensitive 10 # dimensionless, >>1 for a rapamycin-sensitive substrate
KM_MTOR_resistant 0.1 # dimensionless, <<1 for a rapamycin-resistant substrate
# steric hindrance factor
phi 0.1 # dimensionless
# kcat (when MTOR is activated by GTP-loaded RHEB)
kcat_MTOR 1.9 # /s
# 1/km1 is the lifetime of substrate docking (in the absence of catalysis)
km1_MTOR_substrate 0.1 # /s
# bimolecular association rate constant for docking of a tethered substrate in the catalytic cleft
kp1_MTOR_tetheredSub_s=(km1_MTOR_substrate+kcat_MTOR)/(eps*KM_MTOR_sensitive) # /(molecule/cell)/s
kp1_MTOR_tetheredSub_r=(km1_MTOR_substrate+kcat_MTOR)/(eps*KM_MTOR_resistant) # /(molecule/cell)/s

###################################################################
# parameters for dephosphorylation of MTORC1-phosphorylated sites #
###################################################################

# rate constant for dephosphorylation of MTORC1 substrates via a pseudo first-order process
# assumed to be mediated by phosphatases that are available in excess and constitutively active
#  k = 0.002 /s corresponds to a lifetime of ~8 min (and a half-life of ~6 min).
k_dephosphorylation 0.002 # /s

#####################################
# parameters for Ragulator assembly #
#####################################

# rate constants for reversible dimerization of Ragulator components LAMTOR2-5
kf_LAMTOR23 1e6/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kr_LAMTOR23 0.005 # /s
kf_LAMTOR45 1e6/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kr_LAMTOR45 0.005 # /s
kf_LAMTOR55 5e5/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kr_LAMTOR55 0.01 # /s

# rate constants for LAMTOR1 interactions with LAMTOR2/4
kf_LAMTOR12 1e6/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kr_LAMTOR12 0.1 # /s
kf_LAMTOR14 1e6/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kr_LAMTOR14 0.1 # /s

#################################################################
# parameters for Rag dimerization and Rag-Ragulator interaction #
#################################################################

# rate constants for reversible dimerization of RagA and RagC
kf_RagAC 1e6/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kr_RagAC 1 # /s

# rate constants for reversible Rag-Ragulator interaction
kf_RagAC_Ragulator 1e6/(NA*Vcyt) # /M/s
kr_RagAC_Ragulator 0.001 # /s

###################################################
# parameters for RagA-RagC interaction with RPTOR #
###################################################

# rate constants for cytosolic RAPTOR binding to lysosomal RagA(GTP)-RagC(GDP)-Ragulator complexes
kf_RAPTOR_RagAC 2e5/(NA*Vcyt) # /M/s
kr_RAPTOR_RagAC 0.02 # /s

# rate constants for MTORC1-mediated crosslinking of RagA(GTP)-RagC(GDP)-Ragulator complexes
kpx_RAPTOR_RagAC=(Vcyt/Vlys)*(eta_cyt/eta_lys)*kf_RAPTOR_RagAC
kmx_RAPTOR_RagAC=kr_RAPTOR_RagAC

# rate constants for RHEB interaction with MTORC1 on lysosomes
kf_MTORC1_RHEB (Vcyt/Vlys)*(eta_cyt/eta_lys)*2e5/(NA*Vcyt) # /M/s
kr_MTORC1_RHEB 0.2 # 1 /s

# rate constants for AMPK assembly reactions
#   beta subunit reversibly binds the alpha subunit
kf_BA_AMPK 1e6/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kr_BA_AMPK 0.001 # /s
#   beta subunit reversibly binds the gamma subunit
kf_BG_AMPK 1e6/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kr_BG_AMPK 0.005 # /s

###################
# AMPK parameters #
###################

# molecular weights of AMPK subunit isoforms (from UniProt)
mwt_AMPKa1 64009 # g/mol
mwt_AMPKa2 62320 # g/mol
mwt_AMPKb1 30382 # g/mol
mwt_AMPKb2 30302 # g/mol
mwt_AMPKg1 37579 # g/mol
mwt_AMPKg2 63066 # g/mol
mwt_AMPKg3 54258 # g/mol

# molecular weights of the 12 different isoforms of heterotrimeric AMPK
mwt_AMPKa1b1g1=mwt_AMPKa1+mwt_AMPKb1+mwt_AMPKg1 # g/mol
mwt_AMPKa1b2g1=mwt_AMPKa1+mwt_AMPKb2+mwt_AMPKg1 # g/mol
mwt_AMPKa2b1g1=mwt_AMPKa2+mwt_AMPKb1+mwt_AMPKg1 # g/mol
mwt_AMPKa2b2g1=mwt_AMPKa2+mwt_AMPKb2+mwt_AMPKg1 # g/mol
mwt_AMPKa1b1g2=mwt_AMPKa1+mwt_AMPKb1+mwt_AMPKg2 # g/mol
mwt_AMPKa1b2g2=mwt_AMPKa1+mwt_AMPKb2+mwt_AMPKg2 # g/mol
mwt_AMPKa2b1g2=mwt_AMPKa2+mwt_AMPKb1+mwt_AMPKg2 # g/mol
mwt_AMPKa2b2g2=mwt_AMPKa2+mwt_AMPKb2+mwt_AMPKg2 # g/mol
mwt_AMPKa1b1g3=mwt_AMPKa1+mwt_AMPKb1+mwt_AMPKg3 # g/mol
mwt_AMPKa1b2g3=mwt_AMPKa1+mwt_AMPKb2+mwt_AMPKg3 # g/mol
mwt_AMPKa2b1g3=mwt_AMPKa2+mwt_AMPKb1+mwt_AMPKg3 # g/mol
mwt_AMPKa2b2g3=mwt_AMPKa2+mwt_AMPKb2+mwt_AMPKg3 # g/mol

# specific activities of AMPK isoforms measured by Rajamohan et al. (2016)
#  comments:
#   - See Figure 2 in Rajamohan et al. (2016).
#   - The substrate was a peptide, the SAMS peptide.
#   - The factor 1/6e7 converts nmol/min/mg to mol/s/g.
spAct_AMPKa1b1g1 533/(6e7) # mol/s/g
spAct_AMPKa1b2g1 400/(6e7) # mol/s/g
spAct_AMPKa2b1g1 165/(6e7) # mol/s/g
spAct_AMPKa2b2g1 219/(6e7) # mol/s/g

# isoform-specific kcat values for AMPK-catalyzed phosphorylation of the SAMS peptide 
#  comments:
#   - We can determine kcat values from the measurements of specific activity
#     summarized in Figure 2 of Rajamohan et al. (2016).
#   - The kcat values characterize AMPK catalytic activity in the absence of AMP
#     (Rajamohan et al., 2016).
#   - T-loop phosphorylation is 93-97% for a1b1,
#                               87-94% for a1b2,
#                               95-99% for a2b1, and
#                               92-94% for a2b2. See Table 1 in Rajamohan et al. (2016).
#   - The phosphoacceptor serine in the SAMS peptide corresponds to S80 in ACACA (aka S79).
kcat_AMPKa1b1g1=spAct_AMPKa1b1g1*mwt_AMPKa1b1g1 # 1.17 /s
kcat_AMPKa1b2g1=spAct_AMPKa1b2g1*mwt_AMPKa1b2g1 # 0.88 /s
kcat_AMPKa2b1g1=spAct_AMPKa2b1g1*mwt_AMPKa2b1g1 # 0.36 /s
kcat_AMPKa2b2g1=spAct_AMPKa2b2g1*mwt_AMPKa2b2g1 # 0.48 /s

# catalytic subunit isoform-specific fold-increase in AMPK activity when the AID is absent
# compared to when the AID is present
#  comments:
#   - See Figure 2 in Rajamohan et al. (2016).
#   - In both cases (-/+ AID), the non-catalytic subunits of AMPK are missing, as is 
#     the C-terminal end of the catalytic subunit downstream of the AID.
#foldincrease_AIDremoval_AMPKa1 408/177 # dimensionless (2.3-fold increase)
#foldincrease_AIDremoval_AMPKa2 104/21 # dimensionless (5.0-fold increase)

# isoform-specific fold-increase in AMPK activity when the AMPK regulatory subunit 
# is incubated with highest considered concentration of AMP
#  comments:
#   - See Figure 4 and Table 3 in Rajamohan et al. (2016).
#   - NB: the predicted effect of allosteric activation depends on how catalysis is modeled.
#     At low [substrate]:[enzyme] ratio, the Michaelis-Menten rate law overestimates the effect.
#     Do not use this rate law.
allosteric_foldincrease_AMPbinding_AMPKa1b1g1 1.67 # dimensionless
allosteric_foldincrease_AMPbinding_AMPKa1b2g1 2.02 # dimensionless
allosteric_foldincrease_AMPbinding_AMPKa2b1g1 2.00 # dimensionless
allosteric_foldincrease_AMPbinding_AMPKa2b2g1 2.16 # dimensionless

# maximal AMP-induced fold-increase in LKB1 activity at the T-loop in AMPKalpha
#  comments:
#   - See panels A, B and C in Figure 2 of Gowans et al. (2013).
LKB1_activity_foldincrease_AMPbinding_AMPK 2.8 # dimensionless

# Michaelis constants for AMPK-catalyzed phosphorylation of the SAMS peptide
#  comments:
#   - See Table 1 in Rajamohan et al. (2016).
#   - These KM values characterize AMPK catalytic activity in the absence of AMP
#     (Rajamohan et al., 2016).
#   - The phosphoacceptor serine in the SAMS peptide corresponds to S80 in ACACA (aka S79).
KM_AMPKa1b1g1 26.67*1e-6 # M
KM_AMPKa1b2g1 32.27*1e-6 # M
KM_AMPKa2b1g1 121.4*1e-6 # M
KM_AMPKa2b2g1 107.6*1e-6 # M

# assumed value for dissociation rate constant
kr_substrate_AMPKa1 0.1 # /s
kr_substrate_AMPKa2 0.1 # /s

kf_substrate_AMPKa1b1g1=((kr_substrate_AMPKa1+kcat_AMPKa1b1g1)/KM_AMPKa1b1g1)/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kf_substrate_AMPKa1b2g1=((kr_substrate_AMPKa1+kcat_AMPKa1b2g1)/KM_AMPKa1b2g1)/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kf_substrate_AMPKa2b1g1=((kr_substrate_AMPKa2+kcat_AMPKa2b1g1)/KM_AMPKa2b1g1)/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s
kf_substrate_AMPKa2b2g1=((kr_substrate_AMPKa2+kcat_AMPKa2b2g1)/KM_AMPKa2b2g1)/(NA*Vcyt) # /M/s converted to /(molecule/cell)/s

# relative rate constants for pseudo first-order dephosphorylation 
# of the AMPKalpha T-loop in the absence of AMP (no shielding)
#  comments:
#   - See Figure 6 and Table 1 in Rajamohan et al. (2016).
#   - We will assume that the rate law for dephosphorylation is 
#     (kcat_Pase/KM_Pase)_isoform*[Pase]_total*[pAMPK],
#     where phosphatase efficiency, measured by kcat_Pase/KM_Pase, is AMPK isoform specific.
krel_dephosTloop_AMPKa1b1g1 1145/1145 # dimensionless 
krel_dephosTloop_AMPKa1b2g1 1145/1966 # dimensionless (1.7-fold slower)
krel_dephosTloop_AMPKa2b1g1 1145/39.87 # dimensionless (29-fold faster)
krel_dephosTloop_AMPKa2b2g1 1145/56.84 # dimensionless (20-fold faster)

kfast_dephosT_AMPK 0.1 # /s

kfast_dephosT_AMPKa1b1g1=kfast_dephosT_AMPK*krel_dephosTloop_AMPKa1b1g1 # /s
kfast_dephosT_AMPKa1b2g1=kfast_dephosT_AMPK*krel_dephosTloop_AMPKa1b2g1 # /s
kfast_dephosT_AMPKa2b1g1=kfast_dephosT_AMPK*krel_dephosTloop_AMPKa2b1g1 # /s
kfast_dephosT_AMPKa2b2g1=kfast_dephosT_AMPK*krel_dephosTloop_AMPKa2b2g1 # /s

# rate constant for dephosphorylation when the T-loop is maximally shielded
#  comments:
#   - See Figure 7 in Rajamohan et al. (2016).
kslow_dephosT_AMPKa1b1g1 0.62e-4 # /s (corresponds to 80% protection after 60 min)
kslow_dephosT_AMPKa1b2g1 0.45e-4 # /s (corresponds to 85% protection after 60 min)
kslow_dephosT_AMPKa2b1g1 1.7e-4  # /s (corresponds to 55% protection after 60 min)
kslow_dephosT_AMPKa2b2g1 2.2e-4  # /s (corresponds to 45% protection after 60 min)

# apparent equilibrium dissociation constants for high-affinity binding of AMP to AMPK isoforms
#  comments:
#   - See Table 2 in Rajamohan et al. (2016).
#   - We take the results from the +Mg2+ and +staurosporine experiment (line 7 in Table 2).
#   - We assume that the measured KD reflects both binding of AMP to Site 3 and also a conformation
#     change (clamping of RIM2 down on AMP docked in Site 3), which prevents AMP dissociation.
#     Under these assumptions, KD_apparent=KD/(1+Kclamp), where Kclamp/(1+Kclamp) is the fraction
#     of AMP docked at Site 3 that is bound by RIM2.
appKD_AMP_AMPKa1b1g1 2.4e-6 # M
appKD_AMP_AMPKa1b2g1 0.9e-6 # M
appKD_AMP_AMPKa2b2g1 1.5e-6 # M
# estimated equilibrium dissociation constant
#  comments:
#   - Rajamohan et al. (2016) did not characterize AMP binding to the a2b1g1 isoform of AMPK.
#   - Measured KD's for high-affinity binding of AMP to the a1b1g1, a1b2g1 and a2b2g1 isoforms
#     were similar, ranging from 0.9 to 2.4 uM.
#   - We will calculate the KD for AMP-a2b1g1 binding as an average of the measured KD's listed above.
appKD_AMP_AMPKa2b1g1=(appKD_AMP_AMPKa1b1g1+appKD_AMP_AMPKa1b2g1+appKD_AMP_AMPKa2b2g1)/3 # M

# equilibrium clamping constant based on allosteric activation assay
#  comments:
#   - See Figure 4 and Table 3 in Rajamohan et al. (2016).
# Kclamp=0.5*(-1+sqrt(1+4*(1+a+b)/(2*a))), 
# where a = AC50/appKD_AMP and b = (KM_ATP/KD_ATP)*(KD_ATP_Mg/KD_ATP_Mg_Stau)
# AC50 is from Table 3 in Rajamohan et al. (2016).
# appKD_AMP is from line 1 in Table 2 in Rajamohan et al. (2016).
# KM_ATP is from Table 1 in Rajamohan et al. (2016).
# KD_ATP, KD_ATP_Mg, and KD_ATP_Mg_Stau are from lines 3, 6, and 9 in Table 2 in Rajamohan et al. (2016).
#Kclamp_AMPKa1b1g1  2.0 # dimensionless (67% of AMP docked in Site 3 is engaged by the RIM2 clamp.)
#Kclamp_AMPKa1b2g1  4.9 # dimensionless (83% of AMP docked in Site 3 is engaged by the RIM2 clamp.)
#Kclamp_AMPKa2b1g1  6.6 # dimensionless (87% of AMP docked in Site 3 is engaged by the RIM2 clamp.)
#Kclamp_AMPKa2b2g1 16   # dimensionless (94% of AMP docked in Site 3 is engaged by the RIM2 clamp.)

# equilibrium clamping constant based on phosphatase protection assay
#  comments:
#   - See Figure 7 and Table 3 in Rajamohan et al. (2016).
# Kclamp=0.5*(-1+sqrt(1+4*(1+a)/(2*a))),
# where a = pEC50/appKD_AMP
# pEC50 is from Table 3 in Rajamohan et al. (2016).
# appKD_AMP is from line 1 in Table 2 in Rajamohan et al. (2016).
Kclamp_AMPKa1b1g1 1.6 # dimensionless (62% of AMP docked in Site 3 is engaged by the RIM2 clamp.)
Kclamp_AMPKa1b2g1 2.3 # dimensionless (70% of AMP docked in Site 3 is engaged by the RIM2 clamp.)
Kclamp_AMPKa2b1g1 3.6 # dimensionless (78% of AMP docked in Site 3 is engaged by the RIM2 clamp.)
Kclamp_AMPKa2b2g1 5.4 # dimensionless (84% of AMP docked in Site 3 is engaged by the RIM2 clamp.)

# equilibrium dissociation constants for (apparent single-site) binding of Mg2+ATP to AMPK isoforms
# in the presence of staurosporine, which binds the ATP-binding site in the kinase domain
#  comments:
#   - See Table 2 (line 9) in Rajamohan et al. (2016).
KD_ATP_AMPKa1b1g1 300e-6 # M
KD_ATP_AMPKa1b2g1 400e-6 # M
KD_ATP_AMPKa2b2g1 133e-6 # M
# estimated equilibrium dissociation constant
#  comments:
#   - Rajamohan et al. (2016) did not characterize Mg2+ATP binding to the a2b1g1 isoform of AMPK.
#   - Measured KD's for binding of Mg2+ATP to the a1b1g1, a1b2g1 and a2b2g1 isoforms
#     were similar, ranging from 133 to 400 uM.
#   - We will calculate the KD for Mg2+ATP-a2b1g1 binding as an average of the measured KD's listed above.
KD_ATP_AMPKa2b1g1=(KD_ATP_AMPKa1b1g1+KD_ATP_AMPKa1b2g1+KD_ATP_AMPKa2b2g1)/3

# pseudo first-order rate constants for AMPKgamma state changes
#  comments:
#   - These rate constants characterize state changes at Site 3 in the regulatory subunit of AMPK.
#   - The reverse rate constant should be set to values that are sufficiently large enough to ensure
#     quasi equilibrium.
#  ~0 <-> ~ATP
kmInh 10 # /s
kpInh_AMPKa1b1g1=kmInh*ATP_conc/KD_ATP_AMPKa1b1g1 # /s
kpInh_AMPKa1b2g1=kmInh*ATP_conc/KD_ATP_AMPKa1b2g1 # /s
kpInh_AMPKa2b1g1=kmInh*ATP_conc/KD_ATP_AMPKa2b1g1 # /s
kpInh_AMPKa2b2g1=kmInh*ATP_conc/KD_ATP_AMPKa2b2g1 # /s
#  ~0 <-> ~AMP
kmAct 10 # /s
kpAct_AMPKa1b1g1=kmAct*AMP_conc/(appKD_AMP_AMPKa1b1g1*(1+Kclamp_AMPKa1b1g1)) # /s
kpAct_AMPKa1b2g1=kmAct*AMP_conc/(appKD_AMP_AMPKa1b2g1*(1+Kclamp_AMPKa1b2g1)) # /s
kpAct_AMPKa2b1g1=kmAct*AMP_conc/(appKD_AMP_AMPKa2b1g1*(1+Kclamp_AMPKa2b1g1)) # /s
kpAct_AMPKa2b2g1=kmAct*AMP_conc/(appKD_AMP_AMPKa2b2g1*(1+Kclamp_AMPKa2b2g1)) # /s
#  ~AMP <-> ~AMP_RIM2
kmX 10 # /s
kpX_AMPKa1b1g1=kmX*Kclamp_AMPKa1b1g1 # /s
kpX_AMPKa1b2g1=kmX*Kclamp_AMPKa1b2g1 # /s
kpX_AMPKa2b1g1=kmX*Kclamp_AMPKa2b1g1 # /s
kpX_AMPKa2b2g1=kmX*Kclamp_AMPKa2b2g1 # /s

# parameters for LKB1-catalyzed phosphorylation of AMPK via Michaelis-Menten mechanism
#  comments:
#   - AMP binding to AMPK promotes phosphorylation of AMPK's T-loop by LKB1.
#   - The mechanism by which AMP binding to AMPK increases LKB1-mediated phosphorylation
#     of AMPK's T-loop is unknown.
#   - We will assume that clamping of AMP docked at Site 3 in the regulatory subunit leads
#     to better exposure of the T-loop, decreasing the Michaelis constant for LKB1-catalyzed
#     phosphorylation. We will assume that phosphorylated T-loop (but not unphosphorylated T-loop)
#     is shielded when AMP occupying Site 3 is bound to the RIM2.

# maximum concentration of unphosphorylated T-loop in AMPKalpha
inactiveAMPK_max_conc 100e-9 # M (100 nM)
# [inactiveAMPK]_max/([inactiveAMPK]_max+KM_LKB1_hi)=fracVmax_LKB1
# fracVmax_LKB1 must be less than 1/LKB1_activity_foldincrease_AMPbinding_AMPK (=1/2.8)
fraction_LKB1 0.28 # dimensionless, 0<fraction_LKB1<1
fracVmax_LKB1=fraction_LKB1*(1/LKB1_activity_foldincrease_AMPbinding_AMPK) # dimensionless
KM_LKB1_hi=inactiveAMPK_max_conc*(-1+1/fracVmax_LKB1) # M (900 nM)
KM_LKB1_lo=inactiveAMPK_max_conc*(-1+1/fraction_LKB1) # M (260 nM)
# (inactiveAMPK_max_conc+KM_LKB1_hi)/(inactiveAMPK_max_conc+KM_LKB1_lo)
# = LKB1_activity_foldincrease_AMPbinding_AMPK
# kcat for LKB1-catalyzed phosphorylation of AMPK's T-loop threonine
#  comments:
#   - We assume that kcat is not affected by AMP binding to AMPK.
kcat_AMPK_LKB1 0.9 # /s
# dissociation rate constant for LKB1cat-AMPK_Tloop binding
kr_AMPK_LKB1 0.1 # /s
# association rate constant for LKB1cat-AMPK_Tloop binding
#  comments:
#   - We assume that AMP binding to AMPK enhances LKB1's ability to associate
#     with its substrate in AMPK's T-loop.
#  slow association (T-loop is less exposed)
kf_AMPK_LKB1_slow=((kcat_AMPK_LKB1+kr_AMPK_LKB1)/KM_LKB1_hi)/(NA*Vcyt) # /M/s (1.1e6 /M/s) converted to /(molecule/cell)/s
#  fast association (T-loop is more exposed because of allosteric activation by AMP)
kf_AMPK_LKB1_fast=((kcat_AMPK_LKB1+kr_AMPK_LKB1)/KM_LKB1_lo)/(NA*Vcyt) # /M/s (3.8e6 /M/s) converted to /(molecule/cell)/s

# pseudo first-order rate constant for dephosphorylation of S792 in RPTOR
k_dephos_RPTOR_pS792 0.5 # /s

# pseudo first-order rate constant for dephosphorylation of S1387 in TSC2
k_dephos_TSC2_pS1387 0.001 # /s

# Stjepanovic et al. (2014) measured a KD of 100 nM for interaction of the yeast proteins Atg1 and Atg13.
KD_ATG13_ULK1 100e-9*(NA*Vcyt) # M converted to molecules per cell
kr_ATG13_ULK1 0.1 # /s
kf_ATG13_ULK1=kr_ATG13_ULK1/KD_ATG13_ULK1 # /(molecule/cell)/s

KD_ATG13_RB1CC1 10e-9*(NA*Vcyt) # M converted to molecules per cell
kr_ATG13_RB1CC1 0.01 # /s
kf_ATG13_RB1CC1=kr_ATG13_RB1CC1/KD_ATG13_RB1CC1 # /(molecule/cell)/s

KD_ATG13_ATG101 50e-9*(NA*Vcyt) # M converted to molecules per cell
kr_ATG13_ATG101 0.05 # /s
kf_ATG13_ATG101=kr_ATG13_ATG101/KD_ATG13_ATG101 # /(molecule/cell)/s

KD_RB1CC1_ULK1 10e-9*(NA*Vcyt) # M converted to molecules per cell
kr_RB1CC1_ULK1 0.1 # /s
kf_RB1CC1_ULK1=kr_RB1CC1_ULK1/KD_RB1CC1_ULK1 # /(molecule/cell)/s

# effective concentration of a free binding site in an acyclic ATG13-RB1CC1-ULK1 ternary complex
iso_ARU 10e-6*(NA*Vcyt) # M converted to molecules per cell

# RPTOR binds ULK1 at S317 and MTORC1 phosphorylates ULK1 at S758 and ULK1-bound ATG13 at S259
KD_RPTOR_ULK1 10e-9 # M
kr_RPTOR_ULK1 0.02 # /s
kcat_MTORC1_ULK1 0.2 # /s (kcat >> kr)
kcat_MTORC1_ULK1_ATG13 0.2 # /s
kf_RPTOR_ULK1=(kcat_MTORC1_ULK1/KD_RPTOR_ULK1)/(NA*Vcyt)
max_frac_ULK1_pS758 0.5 # dimensionless (0<max_frac<1)
max_frac_ATG13_pS259 0.5
k_dephos_ULK1_pS758=(-1+1/max_frac_ULK1_pS758)*kcat_MTORC1_ULK1*(MTOR_cpc/(NA*Vcyt))/KD_RPTOR_ULK1
k_dephos_ATG13_pS259=(-1+1/max_frac_ATG13_pS259)*kcat_MTORC1_ULK1_ATG13*(MTOR_cpc/(NA*Vcyt))/KD_RPTOR_ULK1

# AMPK binds ULK1 at S758 and phosphorylates ULK1 at S317 and S556
KD_AMPK_ULK1 10e-9 # M
kr_AMPK_ULK1 0.02 # /s
kf_AMPK_ULK1=(kr_AMPK_ULK1/KD_AMPK_ULK1)/(NA*Vcyt)
kcat_AMPK_ULK1 1 # /s (kcat >> kr)
max_frac_ULK1_pS317 0.9 # dimensionless (0<max_frac<1)
max_frac_ULK1_pS556 0.99 # dimensionless (0<max_frac<1)
k_dephos_ULK1_pS317=(-1+1/max_frac_ULK1_pS317)*kcat_AMPK_ULK1*(PRKAA1_cpc/(NA*Vcyt))/KD_AMPK_ULK1
k_dephos_ULK1_pS556=(-1+1/max_frac_ULK1_pS556)*kcat_AMPK_ULK1*(PRKAA1_cpc/(NA*Vcyt))/KD_AMPK_ULK1

# ULK1 autophosphorylation (autocatalytic positive feedback)
KM_ULK1_ULK1 10e-9 # M
km1_ULK1_ULK1 1 # /s
kcat_ULK1_ULK1_fast 1 # /s
kcat_ULK1_ULK1_slow 0.2 # /s
kp1_ULK1_ULK1=((kcat_ULK1_ULK1_fast+km1_ULK1_ULK1)/KM_ULK1_ULK1)/(NA*Vcyt)
max_frac_ULK1_pT180 0.8 # dimensionless (0<max_frac<1)
k_dephos_ULK1_pT180=(-1+1/max_frac_ULK1_pT180)*kcat_ULK1_ULK1_fast*(ULK1_cpc/(NA*Vcyt))/KM_ULK1_ULK1

# ULK1 phosphorylates AMBRA1 via Michaelis-Menten mechanism
KM_ULK1_AMBRA1 100e-9 # M
km1_ULK1_AMBRA1 0.1 # /s
kcat_ULK1_AMBRA1 5 # /s 
kp1_ULK1_AMBRA1=((kcat_ULK1_AMBRA1+km1_ULK1_AMBRA1)/KM_ULK1_AMBRA1)/(NA*Vcyt)
max_frac_pAMBRA1 0.5 # dimensionless (0<max_frac<1)
k_dephos_pAMBRA1=(-1+1/max_frac_pAMBRA1)*kcat_ULK1_AMBRA1*(ULK1_cpc/(NA*Vcyt))/KM_ULK1_AMBRA1

# ULK1 phosphorylates Beclin-1 via Michaelis-Menten mechanism
KM_ULK1_BECN1 100e-9 # M
km1_ULK1_BECN1 0.1 # /s
kcat_ULK1_BECN1 5 # /s
kp1_ULK1_BECN1=((kcat_ULK1_BECN1+km1_ULK1_BECN1)/KM_ULK1_BECN1)/(NA*Vcyt)
max_frac_pBECN1 0.5 # dimensionless (0<max_frac<1)
k_dephos_pBECN1=(-1+1/max_frac_pBECN1)*kcat_ULK1_BECN1*(ULK1_cpc/(NA*Vcyt))/KM_ULK1_BECN1

# ULK1 phosphorylates AMPK via Michaelis-Menten mechanism (negative feedbacK)
KM_ULK1_AMPK 100e-9 # M
km1_ULK1_AMPK 0.02 # /s
kcat_ULK1_AMPK 0.2 # /s 
kp1_ULK1_AMPK=((kcat_ULK1_AMPK+km1_ULK1_AMPK)/KM_ULK1_AMPK)/(NA*Vcyt)
max_frac_AMPK_pDock 0.99 # dimensionless (0<max_frac<1)
k_dephos_AMPK_pDock=(-1+1/max_frac_AMPK_pDock)*kcat_ULK1_AMPK*(ULK1_cpc/(NA*Vcyt))/KM_ULK1_AMPK
max_frac_AMPK_pSite3 0.99 # dimensionless (0<max_frac<1)
k_dephos_AMPK_pSite3=(-1+1/max_frac_AMPK_pDock)*kcat_ULK1_AMPK*(ULK1_cpc/(NA*Vcyt))/KM_ULK1_AMPK

# ULK1 phosphorylates RAPTOR via Michaelis-Menten mechanism (part of MTORC1-ULK1 mutual repression circuit)
KM_ULK1_RPTOR 10e-9 # M
km1_ULK1_RPTOR 0.02 # /s
kcat_ULK1_RPTOR 0.2 # /s 
kp1_ULK1_RPTOR=((kcat_ULK1_RPTOR+km1_ULK1_RPTOR)/KM_ULK1_RPTOR)/(NA*Vcyt)
max_frac_RPTOR_pS855_S859 0.5 # dimensionless (0<max_frac<1)
k_dephos_RPTOR_pS855_S859=(-1+1/max_frac_RPTOR_pS855_S859)*kcat_ULK1_RPTOR*(ULK1_cpc/(NA*Vcyt))/KM_ULK1_RPTOR

############################################
# parameters for simulations of knockdowns #
############################################

# rate constant for degradation of LAMTOR protein (for simulation of LAMTOR knockdowns)
kdeg_LAMTOR 0 # /s

# rate constant for clearance of free MLST8 (to simulate MLST8 knockdown)
kdeg_MLST8 0 # /s

# rate constant for degradation of (free) ATG13 (used to simulated ATG13 knockdown)
kdeg_ATG13 0 # /s

end parameters

begin molecule types

FKBP1A(FKBP~0~rapamycin)
#---
# FKBP1A: FK506-binding protein 1A (aka FKBP12, 12 kDa FK506-binding protein)
#  Uniprot entry: http://www.uniprot.org/uniprot/P62942
#  comments:
#   - 108 amino acids (P62942-1)
#   - FKBP1A binds rapamycin (Bierer et al., 1990).
#   - The KD for binding of FKBP1A to rapamycin is 0.2 nM 
#     (Bierer et al., 1990; Banaszynski et al., 2005).
#   - FKBP1A-rapamycin interacts with MTOR (Brown et al., 1994; Sabatini et al., 1994).
#   - FKBP1A-rapamycin binds the FRB domain in MTOR (Chen et al., 1995). In the ternary complex,
#     rapamycin simultaneously contacts both FKBP1A and the FRB domain (PDB ID: 1FAP) 
#     (Choi et al., 1996).
#   - The KD for binding of the FKBP1A-rapamycin complex to the FRB domain is 12 nM 
#     (Banaszynski et al., 2005).
#   - Binding of FKBP1A-rapamycin to the FRB domain likely inhibits MTOR's kinase activity by 
#     hindering substrate access to the catalytic cleft of MTOR's kinase domain (Aylett et al., 2016).
#   - There are conflicting reports in the literature about whether rapamycin disrupts
#     the interaction between MTOR and RPTOR. Some reports indicate that rapamycin does NOT disrupt
#     MTOR-RPTOR interaction (Hara et al., 2002; Jacinto et al., 2004; Yadav et al., 2013; Aylett et al., 2016).
#     Others indicate that rapamycin does disrupt MTOR-RPTOR interaction (Kim et al., 2002; Oshiro et al., 2004;
#     Yip et al., 2010; Jain et al., 2014).
#  states:
#   - 0: free
#   - rapamycin: bound to rapamycin (aka sirolimus)
#                https://pubchem.ncbi.nlm.nih.gov/compound/5284616
#---

MTOR(HEAT_horn,HEAT_step,FAT,PIKK~0~ATP~AZD8055,FRB,N_LBE,LBE_FATC)
#---
# MTOR: mechanistic target of rapamycin
#  UniProt entry: http://www.uniprot.org/uniprot/P42345
#  comments:
#   - 2549 amino acids (P42345-1)
#   - MTOR is a serine/threonine-specific protein kinase.
#   - It is the catalytic component of MTOR complexes 1 and 2.
#   - contains 32 HEAT repeats
#     http://pfam.sanger.ac.uk/family/HEAT
#     The HEAT repeat is so named because it is found in 
#     (H)untingin, (E)longation factor 3, protein phosphatase 2(A) and yeast (T)OR1.
#   - contains 16 tetratricopeptide repeat (TPR) motifs
#     http://pfam.xfam.org/family/PF00515
#   - contains a FAT domain
#     http://pfam.xfam.org/family/PF02259
#     The FAT domain is so named because it is found in
#     (F)RAP, (A)TM and (T)RRAP.
#   - contains a PI3/PI4-family kinase domain (but lacks lipid kinase activity)
#     http://pfam.xfam.org/family/PF00454.23
#   - contains an FRB domain
#     http://pfam.xfam.org/family/PF08771
#   - contains a FATC domain
#     http://pfam.xfam.org/family/PF02260
#     The FATC domain is so named because it is found in the C-terminal regions of FRAP, ATM and TRRAP.
#  components:
#   HEAT_horn: N-terminal part of HEAT domain
#    comments:
#     - a highly curved, superhelical alpha-solenoid consisting of HEAT repeats
#     - named the "horn" by Aylett et al. (2016)
#     - named the "spiral" by Baretic et al. (2016)
#     - larger than the bridge
#     - In an MTOR homodimer, the N-terminal tip of the horn in one copy of MTOR contacts 
#       the FAT domain in the second copy of MTOR (Aylett et al., 2016).
#     - MTOR homodimerization likely requires HEAT domain stabilization by RPTOR (Aylett et al., 2016).
#   HEAT_step: junction of the "horn" and "bridge" alpha-solenoids
#    comments:
#     - named the "step" by Aylett et al. (2016)
#     - At the step, the C-terminal part of the horn contacts the ARM domain in RPTOR (Aylett et al., 2016).
#     - At the step, the N-terminal part of the bridge contacts the RNC domain in RPTOR (Aylett et al., 2016).
#   HEAT_bridge: C-terminal part of the HEAT domain
#    comments:
#     - a linear alpha-solenoid consisting of HEAT repeats
#     - named the "bridge" by Aylett et al. (2016)
#     - smaller than the horn
#     - The bridge is located between the horn and the FAT domain (Aylett et al., 2016).
#     - MTOR homodimerization likely requires HEAT domain stabilization by RPTOR (Aylett et al., 2016).
#   FAT: FAT domain
#    comments:
#     - consists of HEAT repeats and TPR motifs
#     - a C-shaped alpha-solenoid domain that clamps the kinase domain (Yang et al., 2013)
#     - In an MTOR homodimer, the FAT domain in one copy of MTOR contacts 
#       the N-terminal tip of the horn in the second copy of MTOR (Aylett et al., 2016).
#   PIKK: PI3K-related serine/threonine-specific protein kinase (PIKK) domain
#    states:
#     - 0: the ATP-binding site is free 
#     - ATP: bound to ATP 
#     - AZD8055: bound to the ATP-competitive inhibitor AZD8055
#                https://pubchem.ncbi.nlm.nih.gov/compound/azd8055
#    comments:
#     - consists of canonical kinase N- and C-lobes, which are modified by inserts (Yang et al., 2013)
#     - There is a large insert in the N-lobe, the FRB domain (Yang et al., 2013).
#     - There are four inserts in the C-lobe, including the LBE sequence and 
#       part of the FATC domain (Yang et al., 2013).
#     - RHEB binds the N-lobe of the MTOR kinase domain (aa 2148-2300) (Long et al., 2005).
#       This region is downstream of the FRB domain and encompasses the LBE sequence (Yang et al., 2013).
#     - Yadav et al. (2013) confirmed direct interaction between RHEB and MTOR.
#     - MTOR binds RHEB independently of RHEB's GDP/GTP loading status; however,
#       only GTP-loaded RHEB activates MTOR kinase activity (Long et al., 2005; Avruch et al., 2009).
#   FRB: FKBP12-rapamycin binding (FRB) domain
#    comments:
#     - binds rapamycin in complex with FKBP1A (aka FKBP12)
#     - may serve as a secondary recruitment site for some MTOR substrates (Yang et al., 2013)
#   N_LBE: aa 2148-2300, a region containing most of the N-lobe of the kinase domain and the LBE sequence
#    comments:
#     - region in MTOR (aa 2148-2300) that interacts with RHEB (Long et al., 2005)
#     - This region starts downstream of the FRB domain and just upstream of a beta strand
#       in the N-lobe of the kinase domain and encompasses the LBE sequence (Yang et al., 2013).
#   LBE_FATC: LST8-binding element (LBE) and FATC domain
#    comments:
#     - The "LBE" sequence is an ~40 aa insert (residues 2258-2296) in the 
#       C-lobe of the kinase domain (Yang et al., 2013).
#     - The LBE sequence and a residue from the FATC domain contacts MLST8 (Yang et al., 2013).
#     - The LBE sequence, the FATC domain, and MLST8, together, may play a role in stabilizing the
#       folded structure of the kinase domain's activation loop (Yang et al., 2013).
#     - The yeast structure of Baretic et al. (2016) suggests that MLST8 also contacts
#       an LST8-binding loop (LBL), which corresponds to aa 2510-2516 (near the C-terminal end of the kinase).
#---

RPTOR(RNC,RNC_ARM,ARM,S792~0~P,S855_S859~0~P,WD40)
#---
# RPTOR: regulatory-associated protein of MTOR (aka RAPTOR)
#  UniProt entry: http://www.uniprot.org/uniprot/Q8N122
#  comments:
#   - 1335 amino acids (Q8N122-1)
#   - RPTOR is a scaffold protein.
#   - RPTOR regulates the substrate specificity of MTORC1.
#   - contains an N-terminal domain conserved among Raptor family members, 
#     part of which assembles into a fold that resembles a caspase (Aylett et al., 2016)
#     http://pfam.xfam.org/family/PF14538
#   - contains an armadillo (ARM) domain based on a cryo-EM structure of human MTORC1,
#     a crystal structure of Raptor from C. thermophilum, and sequence alignment (Aylett et al., 2016)
#   - The ARM domain is composed of armadillo (ARM) repeats.
#     http://pfam.xfam.org/family/PF00514
#   - contains a WD40 domain composed of WD40 repeats that assemble into a beta-propeller structure
#     http://pfam.xfam.org/family/PF00400
#   - WD40 repeats are so named because they tend to consist of ~40 aa and end with a WD dipeptide.
#  components:
#   RNC: RAPTOR N-terminal caspase-like (RNC) domain (encompassed by the Raptor N-terminal conserved domain)
#    comments:
#     - The RNC domain binds the TOS motif, which is found in MTORC1 substrates. 
#       Several TOS motifs have been characterized:
#       FRLDI, aa 966-970 in LARP1 (Fonseca et al., 2015);
#       FVMDE, aa 129-133 in AKTS1 (aka PRAS40) (Oshiro et al., 2007; Fonseca et al., 2007);
#       FEMDI, aa 114-118 in EIF4EBP1 (aka 4E-BP1) (Schalm and Blenis, 2002);
#       FEMDI, aa 116-120 in EIF4EBP2 (aka 4E-BP2) (Bidinosti et al., 2010);
#       FEMDI, aa 96-100 in EIF4EBP3 (aka 4E-BP3);
#       FEMDI, aa 1164-1168 in TBC1D4 (aka AS160) (Geraghty et al., 2007);
#       FDMDL, aa 757-761 in STAT3 (Lee et al., 2008);
#       FDLDL, aa 5-9 in RPS6KB2 (aka S6K2); 
#       FDIDE, aa 89-93 in EIF2S2 (aka eIF2-beta) (Gandin et al., 2016);
#       FDIDI, aa 199-203 in HK2 (aka hexokinase type II) (Roberts et al., 2014);
#       FDIDL, aa 28-32 in RPS6KB1 (aka S6K1) (Schalm et al., 2003);
#       FPATV, aa 591-595 in ESR1 (aka estrogen receptor, ER-alpha) (Alayev et al., 2015);
#       FETML, aa 323-327 in EIF3F (Csibi et al., 2010);
#       FEVQV, aa 265-269 in PLD2 (Ha et al., 2006);
#       FVMEF, aa 425-429 in PRKCD (aka PKC-delta) (Lee et al., 2008);
#       FVMEY, aa 484-488 in PRKCE (aka PKC-epsilon) (Lee et al., 2008);
#       FVMVL, aa 99-103 in HIF1A (aka HIF1-alpha) (Land and Tee, 2007);
#       FPMEL, aa 26-30 in STAT3 (Lee et al., 2008);
#       FDMEI, aa 109-113 in GTF3C5 (aka TFIIIC63) (Kantidakis et al., 2010); and
#       FDVEL, aa 474-478 in SIRT1 (aka Sirtuin 1) (Back et al., 2011).
#     - Aylett et al. (2016) identified residues 57-394 (338 amino acids) as corresponding
#       to a caspase-like structure.
#     - The active site in caspases, a family of cysteine-dependent aspartate-directed proteases, 
#       is conserved in RNC; this site consists of residues H153 and G154 (Aylett et al., 2016).
#     - Aylett et al. (2016) proposed that the H153/G154 site may be the part of the RNC domain
#       responsible for recruiting TOS motif-containing substrates to MTORC1.
#     - Coffman et al. (2014) identifed a region spanning residues 89-180 in RPTOR as being 
#       in close proximity to EIF4EBP1 (aka 4EBP1), a substrate of MTORC1.
#     - Mutations of the N-terminal conserved domain disupt RPTOR interaction with EIF4EBP1 (aka 4EBP1)
#       (Dunlop et al., 2009).
#     - Sequences upstream of the caspase fold are conserved among Raptor family members (Aylett et al., 2016).
#     - Part of the RNC domain contacts MTOR's HEAT domain - see below.
#   RNC_ARM: the parts of the RNC and ARM domains that contact MTOR's HEAT domain at its "step" structure
#    comments:
#     - The "step" is the junction of two alpha-solenoids, the "horn" and the "bridge," 
#       which together compose the HEAT domain in MTOR (Aylett et al., 2016).
#     - At the step, part of the ARM domain contacts the C-terminal part of the horn (Aylett et al., 2016).
#     - At the step, part of the RNC domain contacts the N-terminal part of the bridge (Aylett et al., 2016).
#     - RPTOR preferentially interacts with MTOR's HEAT domain (Kim et al., 2002).
#     - Mutations in RPTOR's N-terminal conserved domain negatively affect RPTOR interaction with MTOR (Kim et al., 2002).
#     - There is some uncertainty about how RPTOR is positioned within MTORC1.
#       Aylett et al. (2016) propose a model wherein RPTOR contacts one and only one copy of MTOR.
#       Baretic et al. (2016) suggest that RPTOR instead makes contact with both copies of MTOR in MTORC1.
#   ARM: armadillo (ARM) domain
#    comments:
#     - Aylett et al. (2016) identified residues 401-689 (289 amino acids) as corresponding
#       to an alpha-solenoid structure composed of ARM repeats.
#     - Part of the ARM domain contacts MTOR's HEAT domain - see above.
#     - Sekiguchi et al. (2014) demonstrated that a fragment of Kog1p from S. cerevisiae (aa 661-1156)
#       interacts with both Gtr1p and Gtr2p. The human homologs of Kog1p, Gtr1p, and Gtr2p are 
#       RPTOR, RRAGA/B, and RRAGC/D. Fragment 661-1156 from Kog1p corresponds to fragment 528-971 from RPTOR,
#       which encompasses a C-terminal region of RPTOR's ARM domain and most of the intrinsically disorded region
#       between the ARM domain and the WD40 domain.
#     - Sekiguchi et al. (2014) determined that residues V797 and R798 in Kog1p are important 
#       for interaction with Gtr1p. These residues are conserved and correspond to V615 and R616 in RPTOR, which
#       are located in the ARM domain.
#   S722: serine 722
#    states:
#     - 0: unmodified
#     - P: phosphorylated, LRSVS(pS)YGNI
#    comments:
#     - located in intrinsically disordered region
#     - substrate of AMPK (Gwinn et al., 2008)
#     - AMPK Motif Analyzer (Schaffer et al., 2015) assigns an AMPK motif match score of 2.5 
#       (a high confidence match score is >1.0).
#     - pS722 and/or pS792 interacts with 14-3-3 proteins (Gwinn et al., 2008).
#     - RSK phosphorylates S719, S721, and S722 in RAPTOR (Carriere et al., 2008).
#   S792: serine 792
#    states:
#     - 0: unmodified
#     - P: phosphorylated, MRRAS(pS)YSSL
#    comments:
#     - located in intrinsically disordered region
#     - substrate of AMPK (Gwinn et al., 2008)
#     - AMPK Motif Analyzer (Schaffer et al., 2015) assigns an AMPK motif match score of 4.0 
#       (a high confidence match score is >1.0).
#     - pS722 and/or pS792 interacts with 14-3-3 proteins (Gwinn et al., 2008).
#     - Phosphorylation of S792 inhibits MTORC1 kinase activity but does not inhibit interaction of 
#       RPTOR with MTOR (Gwinn et al., 2008).
#     - S792 is a possible substrate of ULK1 (Dunlop et al., 2011). 
#       See the ULK1 consensus phosphorylation motif (Egan et al., 2015).
#   S855: serine 855
#    states: 
#     - 0: unmodified
#     - P: phosphorylated, VLDTS(pS)LTQS
#    comments:
#     - located in intrinsically disordered region
#     - S855 is a possible substrate of ULK1 (Dunlop et al., 2011).
#       See the ULK1 consensus phosphorylation motif (Egan et al., 2015).
#   S859: serine 859
#    states:
#     - 0: unmodified
#     - P: phosphorylated, SSLTQ(pS)APAS
#    comments:
#     - located in intrinsically disordered region
#     - S859 is a possible substrate of ULK1 (Dunlop et al., 2011).
#       See the ULK1 consensus phosphorylation motif (Egan et al., 2015).
#     - S859 is a possible substrate of GSK3B (Stretton et al., 2015).
#     - Priming phosphorylation at S863 appears to be a prerequisite for phosphorylation of S859
#       by GSK3B (Stretton et al., 2015). Priming phosphorylation of S863 may also
#       be important for phosphorylation of additional sites in RPTOR (Foster et al., 2010).
#     - Phosphorylation of S859 promotes interaction of RPTOR with MTOR (Stretton et al., 2015).
#   S863: serine 863
#    states:
#     - 0: unmodified
#     - P: phosphorylated, QSAPA(pS)PTNK
#    comments:
#     - Priming phosphorylation of S863 is required for phosphorylation of S859 by GSK3 
#       (Stretton et al., 2015). Priming phosphorylation of S863 may be important for phosphorylation
#       of additional sites in RAPTOR (Foster et al., 2010).
#     - Phosphorylation of S863 interferes in RPTOR interaction with Rag GTPases (Yuan et al., 2015).
#     - S863 is a substrate of NLK (Yuan et al., 2015) and JNK.
#     - S863 may or may not be a substrate of MTORC1. Stretton et al. (2015) observed that S863 is 
#       phosphorylated in a nutrient dependent manner consistent with this site being a substrate of
#       MTORC1; however, MTORC1 inhibitors did not affect phosphorylation of S863.
#     - Mutation of this site (S863A) reduces MTORC1 activity (Wang et al., 2009).
#   WD40: WD40 domain
#    comments:
#     - Aylett et al. (2016) identified residues 1001-1335 (335 amino acids) as corresonding
#       to a 7-bladed beta-propeller structure composed of seven WD40 repeats.
#     - interacts with RHEB (Long et al., 2005)
#     - Yadav et al. (2013) confirmed direct interaction between RHEB and RPTOR.
#---

MLST8(WD40)
#---
# MLST8: mammalian lethal with Sec13 8 (aka GbetaL, G protein beta subunit-like)
#  UniProt entry: http://www.uniprot.org/uniprot/Q9BVC4
#  comments:
#   - 326 amino acids (Q9BVC4-1)
#   - MLST8 is a component of MTOR complexes 1 and 2 (Kim et al., 2003).
#   - However, MLST8 is not required for MTORC1 function (Guertin et al., 2006).
#   - consists of seven WD40 repeats, similar to beta subunits of heterotrimeric G protein complexes
#   - The WD40 repeats assemble into a 7-bladed beta-propeller structure (Yang et al., 2013).
#     http://pfam.xfam.org/family/PF00400
#   - WD40 repeats are so named because they typically consist of ~40 aa and end with a WD dipeptide.
#  components:
#   WD40_mtor: the part of the WD40 domain that interacts with MTOR
#    comments:
#     - The narrow part of the beta-propeller structure contacts MTOR (Yang et al., 2013).
#     - The MLST8-MTOR interface involves six of the seven WD40 repeats in MLST8,
#       both helices and the intervening loop of the LBE sequence in MTOR, and a single residue 
#       from the FATC domain in MTOR (Yang et al., 2013).
#   WD40_rheb: the part of the WD40 domain that interacts with RHEB
#    comments:
#     - interacts with RHEB (Long et al., 2005) 
#---

RPS6KB1(TOS,T389~0~P)
#---
# RPS6KB1: ribosomal protein S6 kinase beta-1 (aka S6K1), isoform alpha II (p70 S6K1)
#  UniProt entry: http://www.uniprot.org/uniprot/P23443
#  comments:
#   - 502 amino acids (P23443-2)
#   - The P23443-2 sequence (p70 S6K1) is the same as that of P23443-1 (p85 S6K1) 
#     except that residues 1-23 are missing.
#   - S6K1 is a serine/threonine-specific protein kinase.
#   - contains a TOR signaling (TOS) motif (aa 5-9): FDIDL
#   - contains a protein kinase domain (aa 68-329)
#   - The activation loop (aka T-loop) phosphorylation site is T229, 
#     which is a substrate of PDPK1 (aka PDK1).
#   - contains an AGC-kinase C-terminal tail sequence (aa 330-400)
#   - contains a turn motif (TM)
#   - contains a hydrophobic motif (HM) (aa 385-394): FLGFTYVAPS
#   - contains a substrate of MTORC1: T389 (aka T412 in isoform alpha I, p85 S6K1)
#   - contains an FRB-binding motif (FBM) (aa 393-398 and aa 399-410): PSVLES and VKEKFSFEPKIR
#     See Fig. 4d and Supplementary Fig. 8 in Yang et al. (2013).
#   - contains a C-terminal autoinhibitory pseudosubstrate domain (aa 401-502)
#  components:
#   TOS: TOR signaling (TOS) motif
#    comments:
#     - The TOS motif is important for activation of S6K1 (Schalm and Blenis, 2002).
#     - The TOS motif binds RPTOR (aka RAPTOR) (Nojima et al., 2003).
#   T389: threonine 389
#    states:
#     - 0: unmodified
#     - P: phosphorylated, FLGF(pT)YVAP
#    comments:
#     - T389 is a substrate of MTORC1 (Burnett et al., 1998; Isotani et al., 1999).
#     - Phosphorylation of T389 contributes to activation of S6K1 by allowing the
#       phosphorylated hydrophic motif (HM), in which T389 resides, to interact with a hydrophobic
#       pocket in the N-lobe of the kinase domain.
#---

EIF4EBP1(T37_T46~0~P,S65_T70~0~P,TOS)
#---
# EIF4EBP1: eukaryotic translation initiation factor 4E-binding protein 1 (aka 4E-BP1)
#  UniProt entry: http://www.uniprot.org/uniprot/Q13541
#  comments:
#   - contains a sequence (aa 13-16) known as the RAIP motif: RAIP
#   - Mutation of the RAIP motif still permits 4E-BP1 binding to RPTOR (Dunlop et al., 2009).
#   - contains rapamycin-resistant substrates of MTORC1: T37 and T46
#   - contains a sequence (aa 54-60) known as the YxxxxLPhi motif: YDRKFLM
#   - The YxxxxLPhi motif is responsible for interaction with EIF4E.
#   - contains rapamycin-sensitive substrates of MTORC1: S65 and T70
#   - contains a TOR signaling (TOS) motif (aa 114-118): FEMDI
#   - The intrinsically disordered hypophosphorylated form of 4E-BP1 binds EIF4E 
#     in competition with EIF4G1/3.
#   - The hyperphosphorylated form of 4E-BP1 folds into a structure that is incompetent 
#     for interaction with EIF4E.
#   - Coffman et al. (2014) used chemical crosslinking to identify residues in 4E-BP1 (aa 56-72) 
#     and RPTOR (aa 89-180) that are near each other during EIF4EBP1-RPTOR interaction.
#  components:
#   T37_T46: threonine 37 and 46
#    states:
#     0: unmodified
#     P: phosphorylated, DYST(pT)PGGT and LFST(pT)PGGT
#   S65_T70: serine 65 and threonine 70
#    states: 
#     0: unmodified
#     P: phosphorylated, ECRN(pS)PVTK and PVTK(pT)PPRD
#    comments:
#     - Phosphorylation of T37/T46 is required for phosphorylation of S65/T70 
#       (Gingras et al., 1999; 2001).
#     - Hyperphosphorylated 4EBP1 binds RAPTOR less tightly than hypophosphorylated RAPTOR
#       (Eguchi et al., 2006).
#   TOS: TOR signaling (TOS) motif
#    comments:
#     - The TOS motif mediates interaction of 4E-BP1 with RPTOR 
#       (Schalm et al., 2003; Nojima et al., 2003).
#---

# Ragulator components

LAMTOR1(Helix,Cloop)
#---
# LAMTOR1: Ragulator complex protein LAMTOR1 (aka lipid raft adaptor protein p18)
#  UniProt entry: http://www.uniprot.org/uniprot/Q6IAA8
#  comments:
#   - 161 amino acids (Q6IAA8-1)
#   - LAMTOR1 anchors the Ragulator complex to membranes 
#     (Sancak et al., 2010; Bar-Peled et al., 2012).
#   - similar to yeast (Sc) Ego1p (aka Meh1p)
#   - N-myristoylation at G2
#   - palmitoylation at C3 and C4
#   - contains a late endosomes/lysosomes (LE/Lys) targeting motif: aa 21-23 (LLL)
#   - contains a LAMTOR1-like domain (http://pfam.xfam.org/family/PF15454): aa 18-85
#   - phosphorylation at Y40
#  components:
#   Helix: putative LAMTOR4/5 binding site (aa 126-144)
#    comments:
#     - LAMTOR4 and LAMTOR5 are structurally similar to yeast (Sc) Ego2p, which binds
#       the most C-terminal alpha-helix in Ego1p (Powis et al., 2015). 
#     - There are two candidates for a LAMTOR4/5 binding site in LAMTOR1.
#        1) The sequence SSILAKTASNIIDVSAADS (aa 55-73) aligns with the part of Ego1p (aka Meh1p)
#           in contact with Ego2p (Powis et al., 2015). See PDB entry 4XPM. A motif, LxKxxSNI, is
#           conserved in these human and yeast sequences.
#        2) Secondary structure prediction (Jpred 4) indicates that FSDLQQVSRIAAYAYSALS (aa 126-144)
#           may fold into an alpha-helix. This sequence lies immediately upstream of the putative
#           LAMTOR2/3 binding site in LAMTOR1 (see below), which is consistent with the 4XPM structure.
#       The second candidate seems more likely because Ego1p (aka Meh1p) and LAMTOR1 both contain
#       an N-terminal LAMTOR1-like domain (aa 18-85 in LAMTOR1). This domain in Ego1p does not overlap 
#       with the C-terminal Ego2p-Ego3p binding region. 
#   Cloop: putative LAMTOR2/3 binding site (aa 143-158)
#    comments:
#     - LAMTOR2 and LAMTOR3 are structurally similar to yeast (Sc) Ego3p (aka Slm4p), which binds
#       a (mostly) disordered region of Ego1p located at the C-terminus (Powis et al., 2015).
#     - The sequence LSQIRVDAKEELVVQF (aa 143-158) aligns with the part of Ego1p (aka Meh1p)
#       in contact with Ego3p (Powis et al., 2015). See PDB entry 4XPM.
#     - Secondary structure prediction (Jpred 4) indicates that LVVQF (aa 154-158) may fold into 
#       a beta-strand, which is consistent with the 4XPM structure.
#     - The putative binding site is also consistent with the 4XPM structure in that it is located
#       at the C-terminus and secondary structure prediction (Jpred 4) indicates that it may be mostly
#       disordered.
#---

LAMTOR2(RB,Gdistal)
#---
# LAMTOR2: Ragulator complex protein LAMTOR2 (aka endosomal adaptor protein p14)
#  UniProt entry: http://www.uniprot.org/uniprot/Q9Y2Q5
#  comments:
#   - 125 amino acids (Q9Y2Q5-1)
#   - a component of the Ragulator complex (Sancak et al., 2010; Bar-Peled et al., 2012)
#   - heterodimerizes with LAMTOR3 (aka MP1) (Kurzbauer et al., 2004; Lunin et al., 2004);
#     see PDB entries 1VET and 1VEU.
#   - similar to yeast (Sc) Ego3p (aka Slm4p) (cf. PDB entries 1VET and 4FTX)
#     (Zhang et al., 2012)
#   - consists mostly of a roadblock (RB) domain (http://pfam.xfam.org/family/PF03259)
#   - A roadblock (RB) domain is found in LAMTOR2/3/4/5 and RRRAGA/B/C/D.
#   - See annotation of LAMTOR1.
#  components:
#   RB: roadblock (RB) domain
#    comments:
#     - RB domains commonly dimerize and together form a platform that binds a G domain 
#       (Levine et al., 2013). They are structurally similar to longin domains.
#     - RB dimers (e.g., the LAMTOR2/3 heterodimer) can be viewed as having two faces:
#        1) the face comprising the G domain platform that is typical of RB dimers, and
#        2) the opposite face (Levine et al., 2013).
#       We will refer to these faces, to which each member of an RB dimer contributes,
#       as the "G-proximal" face and the "G-distal" face. Typically, two alpha-helices are 
#       present on the G-proximal face (one from each RB domain), and four alpha-helices are 
#       present on the G-distal face (a pair from each RB domain). See PDB entries 3T1R  and 
#       3T1S and Miertzschke M et al. (2011). 
#     - Representation of RB dimers is somewhat problematic because their binding sites,
#       the G-proximal and G-distal faces, are discontinuous (i.e., composed of residues from 
#       each member of the dimer). To cope with this difficulty, we will adopt the following 
#       convention for LAMTOR2/3 and LAMTOR4/5 heterodimers. We will consider each RB domain-
#       containing protein (LAMTOR2,3,4 and 5) to have two components:
#        1) an RB component, which mediates RB domain dimerization, and
#        2) either a Gproximal or Gdistal component, which represents one of the two binding
#           sites of an RB dimer.
#       Thus, for each pair of interacting RB domains, both will be endowed with an RB 
#       component, one will be endowed with a Gproximal component, and the other will be endowed 
#       with a complementary Gdistal component. It should be understood that the binding sites 
#       represented by Gproximal and Gdistal components are not present in monomeric RB domain-
#       containing dimers. Rather, these binding sites are features of RB dimers.
#     - The roadblock domain in LAMTOR2 is evident from the LAMTOR2 sequence (Pfam), which is not 
#       the case for LAMTOR3/4/5.
#   Gdistal: G-distal face of the LAMTOR2-LAMTOR3 heterodimer
#    comments:
#     - assumed cognate binding site for the putative LAMTOR2/3 binding site in LAMTOR1, a
#       partially disordered region at the C terminus of LAMTOR1.
#     - Arbitrarily, in accordance with the convention explained above, the Gdistal component 
#       of the LAMTOR2-LAMTOR3 heterodimer is assigned to LAMTOR2. The Gproximal component is
#       assigned to LAMTOR3.
#     - It seems likely that the G-distal face of the LAMTOR2-LAMTOR3 heterodimer mediates
#       interaction with LAMTOR1, because in the Ego1p-Ego2p-Ego3p crystal structure (Powis et al.,
#       2015), the C-terminal end (i.e., the C-loop) of Ego1p (corresponding to LAMTOR1) contacts 
#       G-distal elements of Ego2p and Ego3p (corresponding to LAMTOR4/5 and LAMTOR2/3). Furthermore,
#       mutation (N67A/N68A/K70A/M71A) of the second alpha-helix of Ego3p, which is situated
#       on the G-proximal face of the Ego3p-Ego3p homodimer (PDB entry 4FTX), disrupts Ego3p 
#       interaction with Gtr1p and Gtr2p, but not Ego3p interaction with Ego1p (Zhang et al., 2012).
#---

LAMTOR3(RB,Gproximal)
#---
# LAMTOR3: Ragulator complex protein LAMTOR3 [aka MEK-binding partner 1 (MP1)]
#  UniProt entry: http://www.uniprot.org/uniprot/Q9UHA4
#  comments:
#   - 124 amino acids (Q9UHA4-1)
#   - a component of the Ragulator complex (Sancak et al., 2010; Bar-Peled et al., 2012)
#   - heterodimerizes with LAMTOR3 (aka MP1) (Kurzbauer et al., 2004; Lunin et al., 2004);
#     see PDB entries 1VET and 1VEU.
#   - similar to yeast (Sc) Ego3p (aka Slm4p) (cf. PDB entries 1VET and 4FTX)
#     (Zhang et al., 2012)
#   - consists mostly of a roadblock (RB) domain (evident from structure but not sequence)
#   - See annotation of LAMTOR1 and LAMTOR2.
#  components:
#   RB: roadblock (RB) domain
#    comments:
#     - mediates interaction with LAMTOR2
#   Gproximal: G-proximal face of the LAMTOR2-LAMTOR3 heterodimer
#    comments:
#     - one of two parts of an assumed cognate binding site for the G-distal face of a 
#       RagA/B-RagC/D heterodimer
#     - The second part of the assumed binding site is the G-proximal face of a LAMTOR4-
#       LAMTOR5 heterodimer.
#     - We assume that formation of the RagA/B-RagC/D binding site requires colocalization
#       of LAMTOR2/3 and LAMTOR4/5 on LAMTOR1.
#     - Arbitrarily, in accordance with the convention explained in the annotation of LAMTOR2's
#       RB domain, the Gproximal component of the LAMTOR2-LAMTOR3 heterodimer is assigned to 
#       LAMTOR3. The Gdistal component is assigned to LAMTOR2.
#     - Mutation (N67A/N68A/K70A/M71A) of the second alpha-helix of Ego3p, which is situated
#       on the G-proximal face of the Ego3p-Ego3p homodimer (PDB entry 4FTX), disrupts Ego3p 
#       interaction with Gtr1p and Gtr2p, but not Ego3p interaction with Ego1p (Zhang et al., 2012).
#       Furthermore, the G-distal face of Ego3p interacts with the C-loop of Ego1p (Powis et al., 
#       2015). Thus, it seems likely that the G-proximal face of the LAMTOR2-LAMTOR3 heterodimer 
#       is involved in interaction with RagA/B-RagC/D heterodimers.
#---

LAMTOR4(RB,Gdistal)
#---
# LAMTOR4: Ragulator complex protein LAMTOR4 (aka C7orf59)
#  UniProt entry: http://www.uniprot.org/uniprot/Q0VGL1
#  comments:
#   - 99 amino acids (Q0VGL1-1)
#   - a component of the Ragulator complex (Bar-Peled et al., 2012)
#   - heterodimerizes with LAMTOR5 (Bar-Peled et al., 2012)
#   - similar to LAMTOR5 and yeast (Sc) Ego2p (aka Ycr075w-ap) and Ego4p (aka Ynr034w-ap),
#     from structure-guided sequence analysis (Levine et al., 2013)
#   - consists of a roadblock (RB) domain; missing an alpha-helix normally present in RB domains
#     (Levine et al., 2013)
#   - See annotation of LAMTOR1-3.
#  components:
#   RB: roadblock (RB) domain
#    comments:
#     - mediates interaction with LAMTOR5
#   Gdistal: G-distal face of the LAMTOR4-LAMTOR5 heterodimer
#    comments:
#     - assumed cognate binding site for the putative LAMTOR4/5 binding site in LAMTOR1, an
#       alpha-helix near the C terminus of LAMTOR1 that is upstream of the putative LAMTOR2/3 
#       binding site.
#     - Arbitrarily, in accordance with the convention explained in the annotation of LAMTOR2's
#       RB domain, the Gdistal component of the LAMTOR4-LAMTOR5 heterodimer is assigned to 
#       LAMTOR4. The Gproximal component is assigned to LAMTOR5.
#---

LAMTOR5(RB,Gproximal)
#---
# LAMTOR5: Ragulator complex protein LAMTOR5 (aka HBXIP)
#  UniProt entry: http://www.uniprot.org/uniprot/O43504
#  comments:
#   - 91 amino acids (O43504-1)
#   - a component of the Ragulator complex (Bar-Peled et al., 2012)
#   - heterodimerizes with LAMTOR4 (Bar-Peled et al., 2012)
#   - homodimerizes (Garcia-Saez et al., 2011) (PDB entries 3MSH and 3MS6)
#   - similar to LAMTOR4 and yeast (Sc) Ego2p (aka Ycr075w-ap) and Ego4p (aka Ynr034w-ap)
#     (Levine et al., 2013); see PDB entries 2GRG (Wu et al.) and 4XPM
#     (Powis et al., 2015)
#   - consists of a roadblock (RB) domain (evident from structure but not sequence);
#     missing an alpha-helix normally present in RB domains (Levine et al., 2013)
#   - See annotation for LAMTOR1-4.
#  components:
#   RB: roadblock (RB) domain
#    comments:
#     - mediates interaction with LAMTOR4 and itself
#   Gproximal: G-proximal face of the LAMTOR4-LAMTOR5 heterodimer
#    comments:
#     - one of two parts of an assumed cognate binding site for the G-distal face of a 
#       RagA/B-RagC/D heterodimer
#     - The second part of the assumed binding site is the G-proximal face of a LAMTOR2-
#       LAMTOR3 heterodimer.
#     - We assume that formation of the RagA/B-RagC/D binding site requires colocalization
#       of LAMTOR2/3 and LAMTOR4/5 on LAMTOR1.
#     - Arbitrarily, in accordance with the convention explained in the annotation of LAMTOR2's
#       RB domain, the Gproximal component of the LAMTOR4-LAMTOR5 heterodimer is assigned to 
#       LAMTOR5. The Gdistal component is assigned to LAMTOR4.
#---

# Rag GTPases

RRAGA(G~0~GDP~GTP,RB,GdistalA)
#---
# RRAGA: Ras-related GTP-binding protein A (aka RagA)
#  UniProt entry: http://www.uniprot.org/uniprot/Q7L523
#  comments:
#   - 313 amino acids (Q7L523-1)
#   - Rag proteins are involved in amino acid sensing by MTORC1
#     (Sancak et al., 2008; Kim et al., 2008).
#   - RagA/B heterodimerizes with RagC/D (Sekiguchi et al., 2001; Sancak et al., 2008).
#   - RagA/B participates, as a member of a RagA/B-RagC/D heterodimer, in recruitment of 
#     MTORC1 to lysosomes through interaction with RAPTOR (Sancak et al., 2008) and the 
#     Ragulator complex (Sancak et al., 2010; Bar-Peled et al., 2012).
#   - Rag proteins contain an N-terminal Ras-family G domain (Schurmann et al., 1995).
#   - Rag proteins contain a C-terminal roadblock (RB) domain, 
#     which is evident from structure but not sequence.
#   - RagA/B, RagC/D, and yeast (Sc) Gtr1p and Gtr2p are similar (Schurmann et al., 1995;
#     Sekiguchi et al., 2001)
#   - RagA (RRAGA) is most similar to RagB (RRAGB); RagA/B is functionally similar to Gtr1p.
#   - RagC (RRAGC) is most similar to RagD (RRAGD); RagC/D is functionally similar to Gtr2p.
#   - See the structures of RRAGC (PDB entry 3LLU) and the Gtr1p-Gtr2p heterodimer 
#     [PDB entry 3R7W (Gong et al., 2011) and PDB entry 4ARZ (Jeong et al., 2012)].
#   - The Rag proteins have no apparent intrinsic GTPase activity (Oshiro et al., 2014).
#  components:
#   G: guanine nucleotide binding domain
#    states:
#     - 0: apo G domain
#     - GDP: state corresponding to a GDP-locked G domain conformation
#     - GTP: state corresponding to a GTP-locked G domain conformation
#    comments:
#     - Both G domains in a RagA/B-RagC/D heterodimer are important for interaction
#       with RAPTOR (Gong et al., 2011). See also Oshiro et al. (2014).
#     - Gtr2p (yeast homolog of RagC/D) and Kog1p (yeast homolog of RAPTOR) interact directly
#       (Kira et al., 2014).
#     - Sekiguchi et al. (2014) demonstrated that a fragment of Kog1p from S. cerevisiae 
#       (aa 661-1156) interacts with both Gtr1p and Gtr2p.
#     - Regions close to switch I and II in the RagA G domain are important for interaction
#       with RAPTOR (Gong et al., 2011).
#     - Two crystal structures of Gtr1p-Gtr2p heterodimers are available. In one, Gtr1p
#       and Gtr2p are both bound to GMPPNP, a nonhydrolyzable GTP analogue (Gong et al.,
#       2011). In the other, Gtr1p is bound to GTP and Gtr2p is bound to GDP (Jeong et al.,
#       2012). Comparison of the structures (PDB entries 3R7W and 4ARZ) suggests that the GDP-
#       and GTP-bound forms of RagC/D have different conformations and that this difference
#       may affect RagA/B-RagC/D interaction with RAPTOR (Jeong et al., 2012).
#     - The ability of RagA/B-RagC/D to interact with RAPTOR correlates with a "GTP-locked" 
#       RagA/B state and a "GDP-locked" or "empty" RagC/D state; conversely, the inability of 
#       RagA/B-RagC/D to interact with RAPTOR correlates with a "GDP-locked" RagA/B state and a 
#       "GTP-locked" RagC/D state (Sancak et al., 2008; Kim et al., 2008; Bar-Peled et al., 2012; 
#       2013 Tsun et al., 2013; Petit et al., 2013; Okosun et al., 2016). 
#     - Oshiro et al. (2014) have questioned the importance of Rag GTP/GDP-loading state for amino
#       acid regulation of MTORC1. However, GAPs specific for Rag proteins regulate MTORC1. For example,
#       Panchaud et al. (2013) observed that Gtr1-specific GAP activity influences TORC1 activity.
#   RB: roadblock (RB) domain
#    comments:
#     - responsible for RagA/B interaction with RagC/D (Gong et al., 2011; Jeong et al., 2012)
#     - The C-terminal end of RagA mediates interaction with RagC/D (Sekiguchi et al., 2001).
#     - RB domains commonly dimerize and thereby create a platform for binding a G domain
#       (Levine et al., 2013). Typically, this platform is composed of two alpha-helices, with
#       each member of a dimer contributing one alpha-helix. We will refer to this face of an RB
#       dimer as its G-proximal face. We will refer to the opposite face as the G-distal face. This
#       end of the RB domain is typically composed of four alpha-helices, with each member of a dimer
#       contributing a pair of alpha-helices.
#     - See annotation of the RB domain in LAMTOR2.
#   GdistalA: RagA/B part of the G-distal face of the roadblock (RB) domain dimer in RagA/B-RagC/D
#    comments:
#     - assumed cognate binding site responsible for interaction with the Ragulator complex
#     - assumed to interface with Ragulator-associated LAMTOR2-LAMTOR3
#     - Based on the structure of Gtr1p-Gtr2p (Gong et al., 2011; Jeong et al., 2012), the
#       two G domains of a RagA/B-RagC/D heterodimer are expected to be in intimate contact with
#       the G-proximal face of the dimerized RB domains in the RagA/B-RagC/D dimer. Given that
#       Rag G domains mediate interaction with RAPTOR (Gong et al., 2011), by process of elimination,
#       we assume that the G-distal face of the RB dimer interacts with the Ragulator complex. 
#       However, the Ragulator complex may also (or instead) contact the G domains in a way that does
#       not interfere with Rag-RAPTOR binding, because 1) the Ragulator has Rag GEF activity in vitro 
#       (Bar-Peled et al., 2012) and 2) guanyl nucleotide binding to Gtr1 influences Gtr1 association
#       with Ego1 (Binda et al., 2009). 
#---

RRAGC(G~0~GDP~GTP,RB,GdistalC)
#---
# RRAGC: Ras-related GTP-binding protein C (aka RagC)
#  UniProt entry: http://www.uniprot.org/uniprot/Q9HB90
#  comments:
#   - 399 amino acids (Q9HB90-1)
#   - RagC/D heterodimerizes with RagA/B (Sancak et al., 2008).
#   - RagC/D, as part of a RagA/B-RagC/D heterodimer, participates in activation
#     of MTORC1 by amino acids through interaction with RAPTOR and the Ragulator complex
#     (Sancak et al., 2008; 2010; Bar-Peled et al., 2012).
#   - contains an N-terminal Ras-family G domain
#   - contains a C-terminal roadblock (RB) domain
#   - See PDB entry 3LLU.
#   - See annotation of RRAGA.
#  components:
#   G: guanine nucleotide binding domain
#    states:
#     - 0: apo G domain
#     - GDP: state corresponding to a GDP-locked G domain conformation
#     - GTP: state corresponding to a GTP-locked G domain conformation
#    comments:
#     - mediates interaction with RAPTOR (Gong et al., 2011), provided that 
#       RagA/B is in the "GTP" and RagC/D is in the "GDP" state (Sancak et al., 2008).
#   RB: roadblock (RB) domain
#    comments:
#     - mediates RagA/B-RagC/D dimerization (Gong et al., 2011)
#     - The G-proximal face of the RB dimer interacts with the two G domains of a
#       RagA/B-RagC/D heterodimer (Gong et al., 2011). 
#   GdistalC: RagC/D part of the G-distal face of the roadblock (RB) domain dimer in RagA/B-RagC/D
#    comments:
#     - assumed cognate binding site responsible for interaction with the Ragulator complex
#     - assumed to interface with Ragulator-associated LAMTOR4-LAMTOR5
#---

RHEB(G~0~GDP~GTP,GKSSC_farnesyl,loc~lys~cyt~mem)
#---
# RHEB: Ras homolog enriched in brain, GTP-binding protein RHEB
#  UniProt entry: http://www.uniprot.org/uniprot/Q15382
#  comments:
#   - 184 amino acids (Q15382-1)
#   - Ras-family GTP-binding protein, consists of a G domain (http://pfam.xfam.org/family/PF00071)
#   - There is no known RHEB GEF; RHEB freely exchanges GTP/GDP (relative to RAS).
#   - RHEB has far less intrinsic GTPase activity than RAS.
#   - An important RHEB GAP is TSC1/TSC2/TBC1D7.
#   - RHEB interacts with a region in MTOR (aa 2148-2300) (Long et al., 2005).
#     This region includes most of the N-lobe of the kinase domain and the LBE sequence (Yang et al., 2013).
#   - MTOR binds RHEB independent of GDP/GTP loading status; however,
#     only GTP-loaded RHEB activates MTOR kinase activity (Long et al., 2005; Avruch et al., 2009).
#  components:
#   G: guanine nucleotide binding domain
#    states:
#     - 0: apo RHEB
#     - GDP: bound to GDP
#     - GTP: bound to GTP
#    comments:
#     - switch I (aa 33-41)
#     - The conformation of switch I is strongly affected by GTP binding (Yu et al., 2005).
#     - effector binding (aa 35-43)
#     - Mutations D36A, P37A, T38A, and N41A in RHEB negatively affect MTORC1 activation (Sato et al., 2009).
#     - switch II (aa 63-79)
#     - Switch II conformation is weakly affected by GTP binding (Yu et al., 2005).
#     - Switch II is important for MTOR signaling (Long et al., 2007).
#     - RAS dimerizes in a GTP-dependent fashion (Muratcioglu et al., 2015). 
#       It is unknown if RHEB does the same.
#       Two interfaces are involved in RAS dimerization: one involves the switch I region 
#       and the other involves alpha helices.
#   GKSSC_farnesyl: aa 177-181 (GKSSC) with a farnesyl group attached to C181
#    comments:
#     - farnesylated region near the C-terminus of RHEB 
#     - This region is responsible for interaction with PDE6D (Ismail et al., 2011).
#   loc: location
#    states:
#     - lys: lysosomal membrane surface (cytosolic face)
#     - cyt: cytsosol (in complex with PDE6D)
#     - mem: non-lysosomal endomembrane
#    comments:
#     - RHEB is inserted/extracted from endomembrane surfaces and shuttled through the 
#       cytosol by PDE6D.
#---

PDE6D(GDI,loc~lys~cyt~mem) 
#---
# PDE6D: retinal rod rhodopsin-sensitive cGMP 3',5'-cyclic phosphodiesterase subunit delta (aka PDEdelta)
#  UniProt entry: http://www.uniprot.org/uniprot/O43924
#  comments: 
#   - 150 amino acids (O43924-1)
#   - GDI involved in RHEB trafficking and localization
#   - binds RHEB independent on GDP/GTP loading status of RHEB (Long et al., 2005; Avruch et al., 2009).
#   - interacts with the farnesylated tail of RHEB (Ismail et al., 2011)
#   - ARL2 and ARL3 are GDFs that interact with PDE6D. When ARL2/3 is loaded with GTP, 
#     ARL2/3 displaces RHEB from PDE6D (Ismail et al., 2011).
#  components:
#   GDI: GDP-dissociation inhibitor
#    comments:
#     - The structure of PDE6D is similar to that of RhoGDI (Ismail et al., 2011).
#     - A flexible loop is responsible for interaction with RHEB (Ismail et al., 2011).
#   loc: location
#    states:
#     - lys: lysosomal membrane
#     - cyt: cytosol
#     - mem: non-lysosomal endomembrane
#    comments:
#     - RHEB is inserted/extracted from endomembrane surfaces and shuttled through the 
#       cytosol by PDE6D.
#---

TSC2(S1387~0~P)
#---
# TSC2: tuberin (aka tuberous sclerosis complex 2)
#  UniProt entry: http://www.uniprot.org/uniprot/P49815
#  comments:
#   - 1807 amino acids (P49815-1)
#   - catalyzes hydrolysis of GTP bound to RHEB
#   - part of a multimeric complex that also includes TSC1 (aka hamartin) and TBC1D7
#  components:
#   NTD: N-terminal domain (aa 1-400 or aa 54-470)
#    comments:
#     - mediates interaction with TSC1 (van Slegtenhorst et al., 1998; Li et al., 2004)
#   Tuberin: tuberin domain (aa 555-903)
#    Pfam entry: http://pfam.xfam.org/family/PF03542.12
#   S939: serine 939
#    states:
#     - 0: unmodified
#     - P: phosphorylated, RARST(pS)LNERP
#    comments:
#     - substrate of AKT (Manning et al., 2002)
#   S1387: serine 1387
#    states:
#     - 0: unmodified
#     - P: phosphorylated, LSKSS(pS)SPELQ
#    comments:
#     - substrate of AMPK (Inoki et al., 2003)
#     - priming site for GSK3B
#   S1462: serine 1462
#    states:
#     - 0: unmodified
#     - P: phosphorylated, RPRGY(pT)ISDSA
#    comments:
#     - substrate of AKT (Manning et al., 2002)
#   GAP: RapGAP-family GTPase-activating protein (GAP)
#    Pfam entry: http://pfam.xfam.org/family/PF02145
#    comments:
#     - aa 1539-1721 (Marshall et al., 2009)
#     - catalyzes hydrolysis of RHEB-bound GTP (to GDP)
#---

# AMPK subunits

PRKAA1(CAMK,T183~0~P,CTD,Dock~0~P)
#---
# PRKAA1: 5'-AMP-activated protein kinase (AMPK) catalytic subunit alpha-1
#  UniProt entry: http://www.uniprot.org/uniprot/Q13131
#  comments:
#   - 559 amino acids (Q13131-1)
#   - isoform 1 (of 2) of the catalytic subunit of AMPK (AMPKalpha) 
#   - contains a CAMK-family serine/threonine-specific kinase domain
#   - The N-lobe of the kinase domain interacts with the carbohydrate-binding module
#     in AMPKbeta.
#   - The activation loop threonine is T183 in PRKAA1 (corresponds to T172 in PRKAA2).
#   - contains an autoinhibitory domain (AID)
#   - contains RIM1 and RIM2 motifs in the linker region, where
#     RIM stands for "regulatory subunit interaction motif."
#   - RIM1 interacts with CBS2 in AMPKgamma (when Site 3 in AMPKgamma is bound to AMP).
#   - RIM2 interacts with AMP docked to Site 3 in AMPKgamma.
#   - contains a C-terminal domain (CTD)
#   - contains a S/T-rich loop
#   - contains an AKT substrate (S496 in PRKAA1 and S491 in PRKAA2) within the S/T-rich loop
#  components:
#   CAMK: Ca2+/calmodulin-dependent kinase (CAMK) domain (aa 27-279)
#   T183: activation-loop threonine 183 (correponds to T172 in PRKAA2)
#    states:
#     - 0: unmodified
#     - P: phosphorylated, EFLR(pT)SCGS
#   AID: autoinhibitory domain (AID)
#    comments:
#     - overlaps the autoinhibitory sequence (AIS), aa 302-381 (according to UniProt)
#     - folds into a compact three-helix bundle,
#       the same fold as a ubiquitin-associated (UBA) domain
#     - The C-terminal end of the AID overlaps with the N-terminal end of RIM1.
#   RIM1: regulatory subunit interaction motif 1 (RIM1) (aa 343-353)
#    comments:
#     - RIMNEAKDFYL (aa 343-353 in PRKAA1)
#     - See Xin et al. (2013).
#   RIM2: regulatory subunit interaction motif 2 (RIM2) (aa 369-379)
#    comments:
#     - RPHPERVPFLV (aa 369-379 in PRKAA1)
#     - See Xin et al. (2013) and Chen et al. (2013).
#   CTD: C-terminal domain (CTD)
#    comments:
#     - A fragment from the C-terminal end of AMPKalpha, aa 314-474 in PRKAA1, is
#       competent for binding to AMPKbeta (Iseli et al., 2005). 
#     - See the structure of human AMPK reported by Li et al. (2015).
#     - PRKAA1 contains a conserved sequence (aa 406-503) found in yeast homologs of AMPKalpha.
#       http://pfam.xfam.org/family/PF16579.2
#     - The conserved sequence is sometimes called the C-terminal adenylate sensor domain; 
#       it overlaps with the kinase associated domain 1 (KA1) sequence.
#   STloop: serine/threonine-rich loop
#    comments:
#     - contains an AKT substrate (S496 in PRKAA1 and S491 in PRKAA2)
#   Dock: hypothetical substrate docking site
#    states:
#     - 0: unmodified
#     - P: phosphorylated
#    comments:
#     - We assume that AMPK's catalytic subunit forms stable complexes with substrates
#       away from sites of phosphorylation.
#     - We assume that phosphorylation of AMPK's dock component inhibits interaction with
#       substrates.
#     - The sequence LRVRR (aa 443-447) matches LxxRR, the kinase-interacting motif (KIM),
#       which is found in all MAPK-activated protein kinases (MAPKAPKs), such as RSK (Cargnello 
#       and Roux, 2011). MAPKAPKs, like AMPK, are members of the CAMK family. The LRVRR sequence
#       is a potential interaction partner of S758 in ULK1 - see annotation of ULK1.
#     - A feature of kinases endowed with substrate docking sites (e.g., ERK) is constitutive
#       kinase-substrate interaction (Cargnello and Roux, 2011). There is evidence suggesting
#       that AMPK interacts constitutively with substrates:
#        1) AMPK and ULK1 interact (Lee et al., 2010; Egan et al., 2011; Kim et al., 2010;
#           Loffler et al., 2011; Shang et al., 2011; Mack et al., 2012). The interaction does
#           not require AMPK or ULK1 kinase activity (Mack et al., 2012). S317 in ULK1, which
#           is phosphorylated by AMPK, is distant from the region in ULK1 (aa 711-828) that mediates
#           interaction with AMPK (Kim et al., 2011).
#        2) A fragment of rat Prkaa1 (aa 289-550), which contains the AID, multiple Ulk1 substrates 
#           and the C-terminal domain, associates with an AMPK substrate; this substrate is
#           bound by Prkaa1 fragment aa 289-550 away from the sites phosphorylated by AMPK 
#           (Kuramoto et al., 2007).
#        3) A fragment of rat Prkaa1 (aa 407-550) stably associates with an AMPK substrate 
#           (Hallows et al., 2000).
#        4) AMPKalpha stably associates with an AMPK substrate (Crawford et al., 2006); 
#           a glutamic acid (E, negatively charged) in the substrate is important for the interaction.
#---

PRKAA2(CAMK,T172~0~P,CTD,Dock~0~P)
#---
# PRKAA2: 5'-AMP-activated protein kinase (AMPK) catalytic subunit alpha-2
#  UniProt entry: http://www.uniprot.org/uniprot/P54646
#  comments:
#   - 552 amino acids (P54646-1)
#   - isoform 2 of the AMPK catalytic subunit
#   - See annotation of PRKAA1.
#   - The AID, RIM1, RIM2 components are considered implicitly.
#   - The ST loop, located downstream of the C-terminal domain (CTD), is not considered.
#     It contains a substrate of AKT.
#  components:
#   CAMK: CAMK-family kinase domain
#    comments:
#   T172: threonine 172 (correspond to T183 in PRKAA1)
#    states:
#     - 0: unmodified
#     - P: phosphorylated, EFLR(pT)SCGS
#    comments:
#     - located in the T-loop (aka activation loop) of the kinase domain
#     - substrate of STK11 (aka LKB1) and CAMKK2 (aka CAMKKbeta)
#   CTD: C-terminal domain
#    comments:
#     - binds CTD_alpha in AMPKbeta
#   Dock: hypothetical substrate docking site
#    states:
#     - 0: unmodified
#     - P: phosphorylated
#    comments:
#     - We assume that AMPK's catalytic subunit forms stable complexes with substrates
#       away from sites of phosphorylation.
#     - We assume that phosphorylation of AMPK's dock component inhibits interaction with
#       substrates.
#---

PRKAB1(CTD_alpha,CTD_gamma)
#---
# PRKAB1: 5'-AMP-activated protein kinase (AMPK) subunit beta-1
#  UniProt entry: http://www.uniprot.org/uniprot/Q9Y478
#  comments:
#   - 270 amino acids (Q9Y478-1)
#   - isoform 1 (of 2) of the non-catalytic scaffold subunit of AMPK (AMPKbeta)
#   - AMPKbeta is a scaffold protein that bridges AMPKalpha (the catalytic subunit) 
#     and AMPKgamma (the non-catalytic AMP/ADP/ATP-binding regulatory subunit).
#   - contains an N-myristoylation motif (MGNxxS): aa 1-6 (MGNTSS)
#   - myristoylated at G2 (after removal of the initiator methionine) 
#     (Oakhill et al., 2010)
#   - contains a non-conserved sequence linking G2~Myr to a carbohydrate-binding module
#   - contains a carbohydrate-binding module (CBM or CBM48), which contacts the N-lobe
#     of the AMPKalpha kinase domain: aa 68-163 (aka the glycogen-binding domain)
#   - Phosphorylated S108 in the CBM interacts with two conserved lysines in the N-lobe
#     of the AMPKalpha kinase domain (Xiao et al., 2013).
#   - The cleft between the CBM and N-lobe of the AMPKalpha kinase domain forms the
#     allosteric drug and metabolite (ADaM) binding site. The ADaM site binds salicylate, 
#     which activates AMPK (Chen et al., 2009; Calabrese et al., 2014).
#   - contains a linker connecting the CBM to a C-terminal domain
#   - contains a C-terminal domain (CTD), which forms the core of the AMPK heterotrimer
#   - The CTD in AMPKbeta (aa 186-270 in PRKAB1) is responsible for interaction with 
#     AMPKalpha and AMPKgamma; the last 25 aa of the CTD (aa 246-270 in PRKAB1) is 
#     responsible for interaction with AMPKgamma (Iseli et al., 2005). See also
#     Xiao et al. (2007) and Iseli et al. (2008).
#   - Two beta-strands in AMPKbeta (V248-R256 in PRKAB1) and (Y261-P269 in PRKAB1),
#     located at the C-terminal end of the CTD, form a beta-sheet with a beta-strand
#     in AMPKgamma (S45-D52 in PRKAG1), located at the N-terminal end of the CBS1 domain
#     (Xiao et al., 2007). See also Iseli et al. (2008).
#   - The phosphorylated activation loop in AMP-bound (but not ATP-bound) AMPK is shielded 
#     from phosphatases by AMPKbeta (Xiao et al., 2011).
#  components:
#   CTD_alpha: the part of the C-terminal domain (CTD) that interacts with AMPKalpha
#    comments: 
#     - The isolated CTD, aa 186-270 in PRKAB1, is sufficient for interaction of AMPK beta
#       with both AMPKalpha and AMPKgamma (Iseli et al., 2005). 
#     - See Li et al. (2015) and PDB entry 4RER.
#   CTD_gamma: the part of the C-terminal domain (CTD) that interacts wihh AMPKgamma
#    comments:
#     - The last 25 amino acids of the CTD, aa 246-270 in PRKAB1, are sufficient for
#       interaction of AMPKbeta with AMPKgamma (Iseli et al., 2005).
#     - See also Xiao et al. (2007) and Iseli et al. (2008).
#--- 

PRKAB2(CTD_alpha,CTD_gamma)
#---
# PRKAB2: 5'-AMP-activated protein kinase (AMPK) subunit beta-2
#  UniProt entry: http://www.uniprot.org/uniprot/O43741
#  comments:
#   - 272 amino acids (O43741-1)
#   - isoform 2 of the AMPK non-catalytic scaffold subunit
#   - See annotation of PRKAB1.
#   - N-myristoylation at G2 (required) is considered implicitly.
#   - The carbohydrate-binding module (CBM or CBM48) is not considered.
#  components:
#   CTD_alpha: the part of the C-terminal domain (CTD) that interacts with AMPKalpha
#    comments:
#     - binds CTD in AMPKalpha
#   CTD_gamma: the part of the C-terminal domain (CTD) that interacts with AMPKgamma
#    comments:
#     - binds CBS1 in AMPKgamma
#---

PRKAG1(CBS1,Site3~0~P~ATP~AMP~AMP_RIM2)
#---
# PRKAG1: 5'-AMP-activated protein kinase (AMPK) subunit gamma-1
#  UniProt entry: http://www.uniprot.org/uniprot/P54619
#  comments:
#   - 331 amino acids (P54619-1)
#   - isoform 1 (of 3) of the non-catalytic regulatory subunit of AMPK (AMPKgamma)
#   - AMPKgamma binds AMP, ADP and ATP.
#   - AMPKgamma mediates allosteric regulation of the kinase domain in AMPKalpha;
#     it also regulates phosphorylation and dephosphorylation of the activation-loop 
#     threonine (T183 in PRKAA1, T172 in PRKAA2).
#   - contains an N-terminal extension (the shortest of the three gamma isoforms)
#   - contains four tandem cystathionine beta-synthase repeats (CBS1, CBS2, CBS3, and CBS4)
#   - Two CBS repeats form a Bateman domain.
#   - The adenine ring of AMP sits in a hydrophobic pocket of a CBS repeat.
#   - A conserved aspartate residue found in CBS repeats interacts with the 2' and 3'-hydroxyl 
#     groups of the ribose moiety in AMP.
#   - The conserved aspartic acids in CSB1, CBS3 and CBS4 are D90, D245 and D317 in PRKAG1.
#   - In CBS2, the conserved aspartate is replaced by arginine (R171).
#   - The four CBS repeats assemble into a disk-shaped structure.
#   - CBS1 and CBS2 together comprise a Bateman domain.
#   - The N-terminal part of CBS1 interacts with the C-terminal domain of AMPKbeta.
#   - CBS2 cannot bind adenine nucleotides.
#   - CBS2 interacts with the RIM1 motif in AMPKalpha (when Site 3 is bound to AMP).
#   - CBS3 and CBS4 together comprise a Bateman domain.
#   - CBS1, CBS3 and CBS4 are competent for binding adenine nucleotides.
#   - CBS3 (or rather Site 3, the cleft between CBS3 and CBS4) is the critical AMP binding site.
#   - Adenine nucleotides compete for binding to Site 3.
#   - The RIM2 motif in AMPKalpha clamps down on AMP when AMP occupies Site 3.
#   - CBS4 is constitutively associated with AMP
#  components:
#   CBS1: cystathionine beta-synthase repeat 1 (CBS1)
#    comments:
#     - A beta-strand at the N-terminal end of CBS1 (aa 45-52 in PRKAG1) forms a beta-sheet
#       with two beta-strands located at the C terminus of AMPKbeta (Xiao et al., 2007).
#     - See also Viana et al. (2007) and Iseli et al. (2008).
#     - CBS1 and CBS2 together comprise one of the two Bateman domains in AMPKgamma.
#   Site3: Site 3
#    states:
#     - 0: unmodified
#     - P: phosphorylated, at S260 (and/or T262) and/or S269
#    comments:
#     - Site 3 is an adenine nucleotide binding site located in the cleft between CBS3 and CBS4
#       (Xiao et al., 2007).
#     - Loffler et al. (2011) identified substrates of ULK1 in each AMPK subunit, including
#       S260/T262 and S269, which are located in the sequence of the Bateman domain formed by 
#       CBS3 and CBS4.
#     - The sequences surrounding S260 [NNLDV(pS)VTKA] and S269 [ALQHR(pS)HYFE] arguably match 
#       the ULK1 consensus phosphorylation motif defined by Egan et al. (2015).
#     - Loffler et al. (2011) reported that ULK1 phosphorylation of AMPK inhibits AMPK activity 
#       (or activation).
#---

PRKAG2(CBS1,Site3~0~P~ATP~AMP~AMP_RIM2)
#---
# PRKAG2: 5'-AMP-activated protein kinase (AMPK) subunit gamma-2
#  UniProt entry: http://www.uniprot.org/uniprot/Q9UGJ0
#  comments:
#   - 569 amino acids (Q9UGJ0-1)
#   - isoform 2 of the AMPK non-catalytic regulatory subunit
#   - contains an N-terminal extension not found in PRKAG1 or PRKAG3
#   - See annotation of PRKAG1.
#  components:
#   CBS1: cystathionine beta-synthase repeat 1 (CBS1)
#    comments:
#     - The N-terminal part of CBS1 binds CTD_gamma in AMPKbeta.
#   Site3: Site 3
#    states:
#     - 0: unmodified
#     - P: phosphorylated (assumed to inhibit interaction with AMP)
#     - ATP: bound to ATP (competitive inhibitor)
#     - AMP: bound to AMP (allosteric activator)
#     - AMP_RIM2: AMP docked at Site 3 and clamped by the RIM2
#    comments:
#     - located in the cleft between CBS3 and CBS4
#---

PRKAG3(CBS1,Site3~0~P~ATP~AMP~AMP_RIM2)
#---
# PRKAG3: 5'-AMP-activated protein kinase (AMPK) subunit gamma-3
#  UniProt entry: http://www.uniprot.org/uniprot/Q9UGI9
#  comments:
#   - 489 amino acids (Q9UGI9-1)
#   - isoform 3 of the AMPK non-catalytic regulatory subunit
#   - contains an N-terminal extension not found in PRKAG1 or PRKAG2
#   - See annotation of PRKAG1.
#  components:
#   CBS1: cystathionine beta-synthase repeat 1 (CBS1)
#    comments:
#     - The N-terminal part of CBS1 binds CTD_gamma in AMPKbeta.
#   Site3: Site 3
#    states:
#     - 0: unmodified
#     - P: phosphorylated (assumed to inhibit interaction with AMP)
#     - ATP: bound to ATP (competitive inhibitor)
#     - AMP: bound to AMP (allosteric activator)
#     - AMP_RIM2: AMP docked at Site 3 and clamped by the RIM2
#    comments:
#     - located in the cleft between CBS3 and CBS4
#---

STK11(CAMK)
#---
# STK11: serine/threonine-protein kinase 11 (STK11), aka liver kinase B1 (LKB1)
#  UniProt entry: http://www.uniprot.org/uniprot/Q15831
#  comments:
#   - 433 amino acids (Q15831-1)
#   - phosphorylates the T-loop in the catalytic subunit of AMPK
#     as part of a heterotrimeric complex composed of STK11, STRADA or STRADB, and
#     CAB39 (aka MO25alpha) or CAB39L (aka MO25beta).
#  components:
#   CAMK: CAMK-family kinase domain
#    comments:
#     - We assume that kinase activity is constitutive.
#---

# components of the ULK1 complex (ATG13-ATG101-RB1CC1-ULK1)

ATG13(HORMAb,HORMAa,S259~0~P,TLQ)
#---
# ATG13: autophagy-related protein 13
#  UniProt entry: http://www.uniprot.org/uniprot/O75143
#  comments: 
#   - 517 amino acids (O75143-1)
#   - ATG13 is a scaffold protein.
#   - contains an N-terminal HORMA domain (http://pfam.xfam.org/family/PF02301)
#   - component of the ULK1 complex
#   - interacts with ATG101, ULK1, and RB1CC1 (aka FIP200)
#   - See yeast (S. pombe) Atg13-Atg101 structure (Suzuki et al., 2015).
#   - See human ATG13 HORMA domain-ATG101 heterodimer structure (Qi et al., 2015).
#  components:
#   HORMAb: peptides encoded by exon 14 of the ATG13 gene
#    comments:
#     - responsible for interaction with RB1CC1 (aka FIP200);
#       see citation of unpublished data in the review of Wesselborg and Stork (2015)
#     - Exon 14 encodes the sequence MELEIWCLEMNE (amino acids 94-105).
#     - This sequence is found in the beta5 and beta5' strands of the HORMA domain 
#       (PBD ID: 5C50; Qi et al., 2015).
#     - The "safety belt" loop of ATG13 crosses over the beta5 strand (Qi et al., 2015).
#     - In apparent contradiction to the claim of Wesselborg and Stork (2015),
#       Jung et al. (2009) mapped the RB1CC1 binding site in ATG13 to aa 384-517 (see Figure 2c).
#   HORMAa: R133 in the alphaC helix of the HORMA domain
#    comments:
#     - responsible for interaction with ATG101 (Qi et al., 2015)
#     - R133 in ATG13 forms a salt bridge with D54 in AGT101 (Qi et al., 2015).
#     - ATG13's HORMA domain is not stable; it is stabilized by interaction with ATG101
#       (Suzuki et al., 2015; Qi et al., 2015).
#   S224: serine 224 (serine 224 in murine Atg13)
#    states:
#     - 0: unmodified
#     - P: phosphorylated
#    comments: 
#     - possible substrate of AMPK (Puente et al., 2016)
#     - Phosphorylation of S224 in murine Atg13 is regulated in response to starvation 
#       (Puente et al., 2016).
#   S259: serine 259 (serine 258 in murine Atg13)
#    states:
#     - 0: unmodified
#     - P: phosphorylated
#    comments: 
#     - substrate of MTORC1 (Puente et al., 2016)
#     - Phosphorylation of S258 in murine Atg13 is regulated in response to starvation
#       (Puente et al., 2016).
#   S355: serine 355 (serine 318 in isoform 2)
#    states:
#     - 0: unmodified
#     - P: phosphorylated
#    comments:
#     - substrate of UKL1 (Joo et al., 2011)
#     - involved in mitophagy (Joo et al., 2011)
#   S389: serine 389
#    states:
#     - 0: unmodified
#     - P: phosphorylated, TLTS(ph)LDI
#    comments:
#     - substrate of ULK1 (Egan et al., 2015)
#     - located in a region expected to be intrinsically disordered;
#       see Table 1 in Lin and Hurley (2016)
#   LIR: LC3-interacting region (LIR) motif
#    comments:
#     - amino acids 436-447 (SSGNTHDDFVMI)
#   TLQ: amino acids 515-517 (Thr-Leu-Gln)
#    comments:
#     - required for interaction with ULK1 (Hieke et al., 2015)
#     - A C-terminal fragment of ATG13 (aa 384-517) interacts with ULK1 (Jung et al., 2009).
#     - Isoforms 1 and 2 of ATG13 but not isoform 3 interact with ULK1 (Jung et al., 2009).
#     - Isoform 3 is missing aa 443-517; it also differs from isoform 1 in other ways
#       (cf. O75143-1 and O75143-3).
#     - A C-terminal fragment of human ATG13 (aa 458-517) interacts with murine Ulk1 (Fujioka et al., 2014);
#       see Supplementary Figure 2d.
#     - Tandem MIT-interacting motifs (MIMs) in yeast Atg13
#       interact with tandem MIT domains in Atg1 (Fujioka et al., 2014; Stjepanovic et al., 2014).
#     - A sequence alignment between yeast (Sc) Atg13 and human ATG13 (Fujioka et al., 2014) 
#       suggests that F466 and F470 in ATG13 are part of an N-terminal MIM; however, the
#       F466A/F470A mutant form of ATG13 (F429A/F433A for isoform 2) interacts with ULK1 (Hieke et al., 2015).
#     - L516 appears to be conserved between human and yeast (Sc) (Fujioka et al., 2014);
#       see Supplementary Figure 2c.
#     - L516 is predicted to be part of a C-terminal MIM in human ATG13 (Fujioka et al., 2014).
#     - Hieke et al. (2015) note that the TLQ peptide resembles a class I PDZ domain ligand.
#---

ATG101(HORMA)
#---
# ATG101: autophagy-related protein 101
#  UniProt entry: http://www.uniprot.org/uniprot/Q9BSB4
#  comments:
#   - 218 amino acids (Q9BSB4-1)
#   - ATG101 is a scaffold protein.
#   - component of the ULK1 complex
#   - consists entirely of a HORMA domain
#   - See yeast (S. pombe) Atg13-Atg101 structure (Suzuki et al., 2015).
#   - See ATG13 HORMA domain-ATG101 heterodimer structure (Qi et al., 2015).
#   - See PDB ID: 5C50.
#  components:
#   HORMA: HORMA domain
#    Pfam entry: http://pfam.xfam.org/family/PF02301
#   S11: serine 11
#    states:
#     - 0: unmodified
#     - P: phosphorylated, LEVS(ph)VEG
#    comments:
#     - substrate of ULK1 (Egan et al., 2015)
#     - located in loop connecting beta strand 1 and alpha helix A of HORMA domain (Qi et al., 2015)
#   WF: WF finger motif
#    comments:
#     - a protruding loop
#     - an insert
#     - not required for interaction with ATG13
#     - recruits downstream factors to autophagosome-formation site
#     - consists of tryptophan (W) and phenylalanine (F) residues
#       conserved among homologs (in Trp-Phe or Trp-Pro-Phe sequences) 
#     - The WF finger motif consists of W110 and F112 in human ATG101.
#     - The conformation of the WF finger motif (in or out) may be regulated.
#   S203: serine 2013
#    states:
#     - 0: unmodified
#     - P: phosphorylated, LGTS(ph)VTT
#    comments:
#     - substrate of ULK1 (Egan et al., 2015)
#     - located just beyond the C-terminal end of the HORMA domain (Qi et al., 2015)
#---

RB1CC1(LQFL,unknown_ULK1)
#---
# RB1CC1: RB1-inducible coiled-coil protein 1 (aka FIP200)
#  UniProt entry: http://www.uniprot.org/uniprot/Q8TDY2
#  comments:
#   - 1594 amino acids (Q8TDY2-1)
#   - component of the ULK1 complex
#  components:
#   LQFL: amino acid residues 582-585 (Leu-Gln-Phe-Leu) in human RB1CC1 
#    comments:
#     - conserved between mouse and human
#     - responsible for interaction of murine Rb1cc1 with murine Atg13 (Chen et al., 2016)
#   S943: serine 943
#    states:
#     - 0: unmodified
#     - P: phosphorylated, IMHS(ph)QNC
#    comments:
#     - substrate of ULK1 (Egan et al., 2015)
#   S986: serine 986
#    states:
#     - 0: unmodified
#     - P: phosphorylated, LEQS(ph)HLK
#    comments:
#     - substrate of ULK1 (Egan et al., 2015)
#   S1323: serine 1323
#    states:
#     - 0: unmodified
#     - P: phosphorylated, VRTS(ph)LIA
#    comments:
#     - substrate of ULK1 (Egan et al., 2015)
#   unknown_ULK1: unknown/unmapped region in RB1CC1 responsible for (direct) interaction with ULK1
#    comments:
#     - Ganley et al. (2009) determined that ULK1 interacts directly RB1CC1 (aka FIP200).
#     - Ganley et al. (2009) determined RB1CC1 and ATG13 do not compete for binding to ULK1. 
#---

ULK1(Pkinase,T180~0~P,PS,S317~0~P,S556~0~P,S758~0~P,EAT,unknown_RB1CC1)
#---
# ULK1: Unc-51-like kinase 1
#  UniProt entry: http://www.uniprot.org/uniprot/O75385
#  comments:
#   - 1050 amino acids (O75385-1)
#   - ULK1 is a human homolog of yeast Atg1.
#   - ULK1 is a serine/threonine-specific protein kinase.
#   - AMPK interacts with aa 654-828 in ULK1 by co-i.p. (Lee et al., 2010). 
#     This region lies within the PS domain and encompasses S758.
#   - This finding is consistent with the finding of Kim et al. (2011), 
#     who mapped the AMPK binding site to aa 711-828 in rodent Ulk1.
#   - RPTOR interacts with aa 279-828 in ULK1 according to Hosokawa et al. (2009) 
#     but aa 1-278 in ULK1 according to Lee et al. (2010).
#   - Kim et al. (2011) mapped the RPTOR binding site in ULK1 to the N-terminal region of ULK1.
#   - ATG13 interacts with the C-terminal region (aa 829-1051) of ULK1 (Jung et al., 2009).
#   - ULK1 has a strong preference for serine as the phosphoacceptor (Egan et al., 2015).
#   - ULK1's kinase prefers hydrophobic residues at the -3, +1 and +2 positions (Egan et al., 2015).
#   - ULK1 is a substrate of MTORC1.
#   - ULK1 contains the sequence FVMVP (aa 357-361) and the sequence FPGDL (aa 364-368).
#     These sequences resemble known TOS motifs:
#     S6K1 (FDIDL), S6K2 (FDLDL), 4E-BP1/2/3 (FEMDI), HIF1A (FVMVL), PRAS40 (FVMDE), 
#     TFIIIC63 (FDMEI) and HK-II (FDIDI).
#   - Hosokawa et al. (2009) state that a classical TOS motif is not evidently present in the ULK1 
#     and ATG13 sequences.
#  components:
#   Pkinase: protein kinase domain
#    Pfam entry: http://pfam.xfam.org/family/PF00069.21
#    comments:
#     - aa 16-278
#   T180: threonine 180
#    states:
#     - 0: unmodified
#     - P: phosphorylated, MAAT(ph)LC
#    comments:
#     - autophosphorylation site (Lazarus et al., 2015)
#     - located in the activation loop of the ULK1 kinase domain (Lazarus et al., 2015);
#       see PDB IDs: 4WNO, 4WNP 
#     - Phosphorylation of T180 is required for ULK1 kinase activity (Lazarus et al., 2015).
#   PS: proline/serine-rich (PS) domain (aka serine/proline-rich region)
#    comments:
#     - The PS domain is intrinsically disordered region. 
#     - It contains multiple substrates of AMPK and MTORC1.
#   S317: serine 317
#    states:
#     - 0: unmodified
#     - P: phosphorylated, SPPS(ph)LGE
#    comments: 
#     - S317 is a substrate of AMPK (Kim et al., 2011).
#     - Phosphorylation of S317 activates ULK1 kinase activity. 
#   S556: serine 556 (serine 555 in murine Ulk1)
#    states:
#     - 0: unmodified
#     - P: phosphorylated, RLHS(ph)APN
#    comments:
#     - S556 is a substrate of AMPK.
#     - Phosphorylation of S556 allows interaction of ULK1 with 14-3-3 (YWHA) proteins.
#   S638: serine 638 (serine 637 in murine Ulk1)
#    states:
#     - 0: unmodified
#     - P: phosphorylated, KTPS(ph)SQN
#    comments:
#     - S638 is a substrate of AMPK and MTORC1.
#     - Phosphorylation of S638 promotes interaction of ULK1 with AMPK. 
#   S758: serine 758 (serine 757 in murine Ulk1)
#    states:
#     - 0: unmodified
#     - P: phosphorylated, TVGS(ph)PPS
#    comments:
#     - S758 is a substrate of MTORC1 (Kim et al., 2011; Shang et al., 2011).
#     - A region encompassing S758 in ULK1 (aa 711-828) interacts with AMPK (Kim et al., 2011).
#     - There are conflicting reports about the effect of S758 phosphorylation
#       on AMPK-ULK1 interaction. Phosphorylation of S758 has been reported to both 
#       inhibit (Kim et al., 2011) and promote (Shang et al., 2011) AMPK-ULK1 interaction.
#     - A sequence in AMPK's catalytic subunit LRVRR (aa 443-447 in PRKAA1) matches LxxRR,
#       the kinase-interacting motif (KIM), which is a docking (D) domain-related motif 
#       found in MAPK-activated protein kinases (MAPKAPKs) (Cargnello and Roux, 2011). The 
#       KIM mediates interaction with MAP kinases that contain a common docking (CD) domain, 
#       such as ERK, p38, and JNK (Tanoue et al., 2000). Among subsequences in aa 711-828 from ULK1, 
#       the CD domain sequences in Figure 5a of Tanoue et al. (2000) best align with FTVG-SPPSGSTPP, 
#       wherein the first serine is S758. Typically, CD domains contain negatively charged and 
#       hydrophobic residues, which mediate electrostatic and hydrophobic interactions with positively 
#       charged and hydrophobic residues in D domains (Cargnello and Roux, 2011). S758 and S761 
#       in ULK1 (polar) may perhaps substitute for the two central aspartic acid (D) residues typical of 
#       CD domains and mediate interaction with the KIM in AMPK.
#     - ULK1 mutants S758D and S758C appear to bind AMPK better than S758A 
#       (Kim et al., 2011; Shang et al., 2011). The S758C mutant binds AMPK better than the S758A mutant
#       (Kim et al., 2011).
#   EAT: early autophagy targeting/tethering (EAT) domain (Popelka and Klionsky, 2015)
#    comments:
#     - Interaction of ATG13 with ULK1 depends on aa 829-1051 in ULK1 (Jung et al., 2009).
#     - The C-terminal region of ULK1 contains a conserved sequence (aa 837-1044) called DUF3543 
#       (domain of uncharacterized function 3543); see http://pfam.xfam.org/family/PF12063.4
#     - The C-terminal region of yeast Atg1 contains two MIT (microtubule interacting and transport)
#       domains (Fujioka et al., 2014); see http://pfam.xfam.org/family/PF04212
#     - The two, tandem MIT domains have been called MIT1 and MIT2 (Fujioka et al., 2014).
#     - The two, tandem MIT domains in yeast (Km) Atg1 mediate interaction with two, tandem
#       MIT-interacting motifs (MIMs) in yeast Atg13 (Fujioka et al., 2014).
#     - The DUF3543 sequence aligns with the yeast (K. marxianus) Atg1 sequence containing 
#       the two, tandem MIT domains; however, there are several insertions in the human protein ULK1.\
#   unknown_RB1CC1: unknown/unmapped region in ULK1 responsible for (direct) interaction with RB1CC1
#    comments:
#     - Ganley et al. (2009) determined that ULK1 directly interacts with RB1CC1 (aka FIP200).
#     - Ganley et al. (2009) determined that RB1CC1 and ATG13 do not compete for binding to ULK1.
#---

AMBRA1(S465_S635~0~P)
#---
# AMBRA1: activating molecule in BECN1-regulated autophagy protein 1 (AMBRA1)
#  UniProt entry: http://www.uniprot.org/uniprot/Q9C0C7
#  comments:
#   - 1298 amino acids (Q9C0C7-1)
#  components:
#   S465_S635: serine 465 and serine 635
#    states:
#     - 0: unmodified
#     - P: phosphorylated, VYT(pS)ATE and LEL(pS)SSA
#    comments:
#     - S465 and S635 are substrates of ULK1 (Egan et al., 2015).
#---

BECN1(S15~0~P)
#---
# BECN1: Beclin-1 (coiled-coil myosin-like BCL2-interacting protein)
#  UniProt entry: http://www.uniprot.org/uniprot/Q14457
#  comments:
#   - 450 amino acids (Q14457-1)
#  components:
#   S15: serine 15 (corresponds to S14 in murine Becn1)
#    states:
#     - 0: unmodified
#     - P: phosphorylated, STMQV(pS)FVCQ
#    comments:
#     - substrate of ULK1 (Russell et al., 2013)
#     - Phosphorylation of S15 is required for VPS34 (class PI3K) kinase activity 
#       (Russell et al., 2013).
#---

end molecule types

begin seed species

###################################################################
# set the abundances of rapamycin-free and rapamycin-bound FKBP12 #
###################################################################
#---
# if(rapamcyin_isPresent==1) then
#   setConcentration("FKBP1A(FKBP~0)","fracFKBP1A_0*FKBP1A_cpc")
#   setConcentration("FKBP1A(FKBP~rapamycin)","(1-fracFKBP1A_0)*FKBP1A_cpc")
# else if (rapamycin_isPresent==0) then
#   setConcentration("FKBP1A(FKBP~0)","FKBP1A_cpc")
#   setConcentration("FKBP1A(FKBP~rapamycin)",0)
# else
#   ERROR: the parameter "rapmycin_isPresent" must be set to either 0 or 1
# end if
# We are assuming that rapamycin-FKBP12 binding is at equilibrium.
#---

FKBP1A(FKBP~0) FKBP1A_cpc*((1-rapamycin_isPresent)*(1-fracFKBP1A_0)+fracFKBP1A_0)
FKBP1A(FKBP~rapamycin) FKBP1A_cpc*(rapamycin_isPresent*(1-fracFKBP1A_0))

########################################
# abundances of core MTORC1 components #
########################################
#---
# An equilibration simulation is necessary to assemble MTORC1 and to determine
# the extent of phosphorylation at S792 and S855/S859 in Raptor.
#---

MTOR(HEAT_horn,HEAT_step,FAT,PIKK~ATP,FRB,N_LBE,LBE_FATC) MTOR_cpc
RPTOR(RNC,RNC_ARM,ARM,S792~0,S855_S859~0,WD40) RPTOR_cpc
MLST8(WD40) MLST8_cpc

#################################
# abundances of S6K1 and 4E-BP1 #
#################################
#---
# An equilibration simulation is necessary to determine the extent of phosphorylation
# at T389 in S6K1 and at T37/T46 and S65/T70 in 4E-BP1.
# S6K1 and 4E-BP1 are effectors of MTORC1-mediated regulation of translation. They are
# included in the model as reporters of MTORC1 kinase activity.
#---

RPS6KB1(TOS,T389~0) RPS6KB1_cpc
EIF4EBP1(T37_T46~0,S65_T70~0,TOS) EIF4EBP1_cpc

#####################################################
# abundances of components of the Ragulator complex #
#####################################################
#---
# An equilibration simulation is necessary to assemble the Ragulator complex.
#---

LAMTOR1(Helix,Cloop)  LAMTOR1_cpc
LAMTOR2(RB,Gdistal)   LAMTOR2_cpc
LAMTOR3(RB,Gproximal) LAMTOR3_cpc
LAMTOR4(RB,Gdistal)   LAMTOR4_cpc
LAMTOR5(RB,Gproximal) LAMTOR5_cpc

##################################################
# abundances of Rag proteins (RagA/B and RagC/D) #
##################################################
#---
# Aside from two inserts in RRAGB, the RRAGA and RRAGB sequences are nearly identical.
# The RRAGC and RRAGD sequences are also very similar. These similarities may perhaps
# explain why RRAGC and RRAGD copy numbers were typically not quantified in the mass spectrometry-
# based assays of Mann and co-workers (Geiger et al., 2012; Kulak et al., 2014; Hein et al., 2015).
# RagA can substitute for RagB (and vice versa), and the same is true for RagC and RagD.
# An equilibration simulation is necessary to determine the extent of RagA/B-RagC/D dimerization, the
# GDP/GTP-loading status of RagC/D, and the abundance of Rag-Ragulator complex. As a simplification, we
# only allow the GDP/GTP-loading status of RagC/D to change. We assume that the GDP/GTP-loading status of
# RagA/B changes coordinately with that of RagC/D within a RagA/B-RagC/D dimer. Our understanding is that
# a Rag dimer consisting of GTP-loaded RagA/B and GDP-loaded RagC/D is competent for interaction with Raptor.
# Conversely, a Rag dimer consisting of GDP-loaded RagA/Band GTP-loaded RagC/D is incompetent for interaction
# with Raptor.
#---

RRAGA(G~GTP,RB,GdistalA) RRAGA_cpc
RRAGC(G~GDP,RB,GdistalC) RRAGC_cpc

####################################################################
# set the initial abundances of GDP- and GTP-loaded lysosomal RHEB #
####################################################################
#---
# An equilibration simulation is necessary to determine the condition-dependent
# GDP/GTP-loading status of RHEB anchored to lysosomal membranes. A specified fraction of
# total RHEB (relatively abundant compared to other proteins considered here) is assumed to
# be localized to lysosomal surfaces.
#---

RHEB(G~GTP,GKSSC_farnesyl,loc~lys) RHEB_cpc*fracRHEB_lysGTP
RHEB(G~GDP,GKSSC_farnesyl,loc~lys) RHEB_cpc*fracRHEB_lysGDP

#####################
# abundance of TSC2 #
#####################
#---
# The amount of TSC2 phosphorylated at S1387 depends on AMPK activity.
# An equiliration simulation is required to determine the extent of phosphorylation at S1387.
# In this model, TSC2 is included to account, in a simple way, for AMPK-mediated enhancement 
# of TSC2 GAP activity directed at lysosomal GTP-loaded RHEB when AMPK is activated. TSC2 can
# also be viewed as a reporter of AMPK kinase activity.
#---

TSC2(S1387~0) TSC2_cpc

###############################
# abundances of AMPK subunits #
###############################
#---
# An equilibration simulation is required to assemble AMPK and to determine
# phosphorylation levels of T183 (aka T172), Dock, and Site3.
# We only consider one isoform of the alpha subunit (AMPK-alpha1), both
# isoforms of the beta subunit (AMPK-beta1 and AMPK-beta2), and one isoform
# of the gamma subunit (AMPK-gamma1). These are the subunit isoforms relevant
# in U2OS cells, judging from the protein copy number measurements of Geiger et al. (2012).
#---

PRKAA1(CAMK,T183~0,CTD,Dock~0) PRKAA1_cpc
PRKAB1(CTD_alpha,CTD_gamma) PRKAB1_cpc
PRKAB2(CTD_alpha,CTD_gamma) PRKAB2_cpc
PRKAG1(CBS1,Site3~0) PRKAG1_cpc

#####################
# abundance of LKB1 #
#####################
#---
# LKB1 abundance and kinase activity are taken to be constitutive.
# LKB1 is included in the model because AMPK kinase activity depends on LKB1-mediated
# phosphorylation of AMPK's T-loop (at T183 in PRKAA1 and at T172 in PRKAA2).
#---

STK11(CAMK) STK11_cpc

########################################
# abundance of ULK1 complex components #
########################################
#---
# An equilibration simulation is required to assembly the ULK1 complex and to
# determine ATG13 and ULK1 phosphorylation status.
#---

ATG13(HORMAb,HORMAa,S259~0,TLQ) ATG13_cpc
ATG101(HORMA) ATG101_cpc
RB1CC1(LQFL,unknown_ULK1) RB1CC1_cpc
ULK1(Pkinase,T180~0,PS,S317~0,S556~0,S758~0,EAT,unknown_RB1CC1) ULK1_cpc

#####################################
# abundances of Ambra1 and Beclin-1 #
#####################################
#---
# An equilibration simulation is required to determine the distribution of
# Ambra1 and Beclin-1 phosphorylation states. Both of these proteins are members
# of multiple multimeric protein complexes and effectors of ULK1-mediated regulation
# of autophagy. They are included in the model as reporters of ULK1 kinase activity.
#---

AMBRA1(S465_S635~0) AMBRA1_cpc
BECN1(S15~0) BECN1_cpc

end seed species

begin observables

