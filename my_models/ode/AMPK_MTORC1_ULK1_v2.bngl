PRKAA1_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^PRKAA1_iBAQ1_HEK293 # copies per cell
PRKAA2_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^PRKAA2_iBAQ1_HEK293 # copies per cell
PRKAB1_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^PRKAB1_iBAQ1_HEK293 # copies per cell
PRKAB2_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^PRKAB2_iBAQ1_HEK293 # copies per cell
PRKAG1_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^PRKAG1_iBAQ1_HEK293 # copies per cell
#PRKAG2_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^PRKAG2_iBAQ1_HEK293 # copies per cell
PRKAG3_cpc_HEK293 = 0 # iBAQ_to_cpc_HEK293*10^PRKAG3_iBAQ1_HEK293 # copies per cell

