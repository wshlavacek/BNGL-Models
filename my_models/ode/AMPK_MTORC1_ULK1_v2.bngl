Species MTORC1_with_2_mLST8 MTOR(HEAT_horn!3,HEAT_step!1,FAT!4,LBE_FATC!5).RPTOR(RNC_ARM!1).MLST8(WD40!5).MTOR(HEAT_horn!4,HEAT_step!2,FAT!3,LBE_FATC!6).RPTOR(RNC_ARM!2).MLST8(WD40!6)
Species MTORC1_with_1_mLST8 MTOR(HEAT_horn!3,HEAT_step!1,FAT!4,LBE_FATC!5).RPTOR(RNC_ARM!1).MLST8(WD40!5).MTOR(HEAT_horn!4,HEAT_step!2,FAT!3,LBE_FATC).RPTOR(RNC_ARM!2)
Species MTORC1_with_0_mLST8 MTOR(HEAT_horn!3,HEAT_step!1,FAT!4,LBE_FATC).RPTOR(RNC_ARM!1).MTOR(HEAT_horn!4,HEAT_step!2,FAT!3,LBE_FATC).RPTOR(RNC_ARM!2)
Species MTORC1_1pt_lys_anchor MTOR(HEAT_horn!3,HEAT_step!1,FAT!4).RPTOR(RNC_ARM!1,ARM).MTOR(HEAT_horn!4,HEAT_step!2,FAT!3).RPTOR(RNC_ARM!2,ARM!+)
Species MTORC1_2pt_lys_anchor MTOR(HEAT_horn!3,HEAT_step!1,FAT!4).RPTOR(RNC_ARM!1,ARM!+).MTOR(HEAT_horn!4,HEAT_step!2,FAT!3).RPTOR(RNC_ARM!2,ARM!+)

Molecules MTOR_bound_RHEB_GTP RHEB(G~GTP!1).MTOR(N_LBE!1)
Molecules MTOR_bound_RHEB_GDP RHEB(G~GDP!1).MTOR(N_LBE!1)

Species MTORC1_with_2_RHEB MTOR(HEAT_horn!3,HEAT_step!1,FAT!4,N_LBE!5).RPTOR(RNC_ARM!1).RHEB(G!5).MTOR(HEAT_horn!4,HEAT_step!2,FAT!3,N_LBE!6).RPTOR(RNC_ARM!2).RHEB(G!6)
Species MTORC1_with_1_RHEB MTOR(HEAT_horn!3,HEAT_step!1,FAT!4,N_LBE!5).RPTOR(RNC_ARM!1).RHEB(G!5).MTOR(HEAT_horn!4,HEAT_step!2,FAT!3,N_LBE).RPTOR(RNC_ARM!2)
Species MTORC1_with_0_RHEB MTOR(HEAT_horn!3,HEAT_step!1,FAT!4,N_LBE).RPTOR(RNC_ARM!1).MTOR(HEAT_horn!4,HEAT_step!2,FAT!3,N_LBE).RPTOR(RNC_ARM!2)

#Molecules RPTOR_monMTOR_MLST8_trimers RPTOR(RNC_ARM!1).MTOR(HEAT_horn,HEAT_step!1,FAT,LBE_FATC!2).MLST8(WD40!2)

#Molecules RPS6KB1 RPS6KB1()
