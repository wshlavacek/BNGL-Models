LAMTOR1_cpc_HeLa_Kyoto 662783*f # copies per cell
LAMTOR2_cpc_HeLa_Kyoto  64104*f # copies per cell
LAMTOR3_cpc_HeLa_Kyoto  45618*f # copies per cell
LAMTOR4_cpc_HeLa_Kyoto   5324*f # copies per cell
LAMTOR5_cpc_HeLa_Kyoto 922421*f # copies per cell

RRAGA_cpc_HeLa_Kyoto 95388*f # copies per cell
RRAGB_cpc_HeLa_Kyoto 0 # Hein et al. (2015) report a single value for RagA/B.
RRAGC_cpc_HeLa_Kyoto 31053*f # copies per cell
RRAGD_cpc_HeLa_Kyoto 0 # copies per cell, no value reported by Hein et al. (2015)

RHEB_cpc_HeLa_Kyoto  352672*f # copies per cell
PDE6D_cpc_HeLa_Kyoto 608996*f # copies per cell

TSC1_cpc_HeLa_Kyoto    7114*f # copies per cell
TSC2_cpc_HeLa_Kyoto   10010*f # copies per cell
TBC1D7_cpc_HeLa_Kyoto 19136*f # copies per cell

AKT1_cpc_HeLa_Kyoto   34910*f # copies per cell
AKT2_cpc_HeLa_Kyoto   38432*f # copies per cell

PRKAA1_cpc_HeLa_Kyoto 147133*f # copies per cell
PRKAA2_cpc_HeLa_Kyoto      0 # no value reported by Hein et al. (2015)

PRKAB1_cpc_HeLa_Kyoto 277161*f # copies per cell
PRKAB2_cpc_HeLa_Kyoto  12909*f # copies per cell 

PRKAG1_cpc_HeLa_Kyoto  96958*f # copies per cell  
PRKAG2_cpc_HeLa_Kyoto      0 # no value reported by Hein et al. (2015) 
