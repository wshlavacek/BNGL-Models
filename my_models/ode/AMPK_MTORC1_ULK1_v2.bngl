STK11_cpc_HeLa_Kyoto        0 # no value reported by Hein et al. (2015)

ATG13_cpc_HeLa_Kyoto   4902*f # copies per cell
ATG101_cpc_HeLa_Kyoto 30357*f # copies per cell
RB1CC1_cpc_HeLa_Kyoto 12371*f # copies per cell
ULK1_cpc_HeLa_Kyoto       0 # no value reported by Hein et al. (2015)

