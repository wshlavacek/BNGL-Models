#   Site3~AMP_RIM2
#PRKAA2(T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)->\
#PRKAA2(T172~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2) kslow_dephosT_AMPKa2b2g1

########################################################################################
# Interactions of the AMPK regulatory subunit with ATP (inhibitor) and AMP (activator) #
########################################################################################

# inhibitor (ATP) binding to AMPK
#  AMPKa1b1g1
PRKAA1(CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)<->\
PRKAA1(CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP) kpInh_AMPKa1b1g1,kmInh
#  AMPKa1b2g1
PRKAA1(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)<->\
PRKAA1(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP) kpInh_AMPKa1b2g1,kmInh
#  AMPKa2b1g1
#PRKAA2(CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)<->\
#PRKAA2(CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP) kpInh_AMPKa2b1g1,kmInh
#  AMPKa2b2g1
#PRKAA2(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)<->\
#PRKAA2(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP) kpInh_AMPKa2b2g1,kmInh

# activator (AMP) binding to AMPK
#  AMPKa1b1g1
PRKAA1(CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)<->\
PRKAA1(CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP) kpAct_AMPKa1b1g1,kmAct
#  AMPKa1b2g1
PRKAA1(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)<->\
PRKAA1(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP) kpAct_AMPKa1b2g1,kmAct
#  AMPKa2b1g1
#PRKAA2(CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)<->\
#PRKAA2(CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP) kpAct_AMPKa2b1g1,kmAct
#  AMPKa2b2g1
#PRKAA2(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)<->\
#PRKAA2(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP) kpAct_AMPKa2b2g1,kmAct

##################################################################################################
# Intramolecular interaction between the RIM2 in AMPKalpha and AMP docked at Site 3 in AMPKgamma #
##################################################################################################

# clamping (RIM2 in AMPKalpha binds AMP docked at Site 3 in AMPKgamma)
#  AMPKa1b1g1
PRKAA1(CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)<->\
PRKAA1(CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2) kpX_AMPKa1b1g1,kmX
#  AMPKa1b2g1
PRKAA1(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)<->\
PRKAA1(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2) kpX_AMPKa1b2g1,kmX
#  AMPKa2b1g1
#PRKAA2(CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)<->\
#PRKAA2(CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2) kpX_AMPKa2b1g1,kmX
#  AMPKa2b2g1
#PRKAA2(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)<->\
#PRKAA2(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2) kpX_AMPKa2b2g1,kmX

###############################################################
# phosphorylation of cytosolic (non-lysosomal) RAPTOR by AMPK #
###############################################################

# AMPK-mediated substrate phosphorylation via Michaelis-Menten mechanism
#  comments:
#   - We assume that phosphorylation of RPTOR by AMPK does not involve
#     a substrate docking site in AMPK, which may be located in the C-terminal end of the catalytic subunit.
#  AMPKa1b1g1
#   substrate docks in catalytic cleft of enzyme
#    comments:
#     - requires T-loop phosphorylation
PRKAA1(CAMK,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2)+RPTOR(ARM,S792~0)->\
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2).RPTOR(ARM,S792~0!3) kf_substrate_AMPKa1b1g1
#   substrate dissociates (without phosphorylation)
PRKAA1(CAMK!1).RPTOR(ARM,S792~0!1)->PRKAA1(CAMK)+RPTOR(ARM,S792~0) kr_substrate_AMPKa1
#   catalysis, followed very closely by release of phosphorylated substrate
#    relatively slow phosphorylation (when AMPK is NOT allosterically activated by AMP)
#     Site3~0 (empty Site 3)
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0).RPTOR(ARM,S792~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)+RPTOR(ARM,S792~P) kcat_AMPKa1b1g1
#     Site3~P (phosphorylated Site 3)
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P).RPTOR(ARM,S792~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)+RPTOR(ARM,S792~P) kcat_AMPKa1b1g1
#     Site3~ATP (ATP-bound Site 3)
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP).RPTOR(ARM,S792~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)+RPTOR(ARM,S792~P) kcat_AMPKa1b1g1
#     Site3~AMP (AMP docked at Site 3 but not clamped by RIM2 - no allosteric activation)
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP).RPTOR(ARM,S792~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)+RPTOR(ARM,S792~P) kcat_AMPKa1b1g1
#    relatively fast phosphorylation (when AMPK IS allosterically activated by AMP)
#     Site3~AMP_RIM2 (AMP-bound Site 3, with AMP clamped by RIM2 and allosterically activating the kinase)
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).RPTOR(ARM,S792~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)+RPTOR(ARM,S792~P) \
allosteric_foldincrease_AMPbinding_AMPKa1b1g1*kcat_AMPKa1b1g1
#  AMPKa1b2g1
#   substrate docks in catalytic cleft of enzyme
#    comments:
#     - requires T-loop phosphorylation
PRKAA1(CAMK,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2)+RPTOR(ARM,S792~0)->\
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2).RPTOR(ARM,S792~0!3) kf_substrate_AMPKa1b2g1
#   substrate dissociates (without phosphorylation)
#PRKAA1(CAMK!1).RPTOR(ARM,S792~0!1)->PRKAA1(CAMK)+RPTOR(ARM,S792~0) kr_substrate_AMPKa1 # <-- This rule is already defined above.
#   catalysis, followed very closely by release of phosphorylated substrate
#    relatively slow phosphorylation (when AMPK is NOT allosterically activated by AMP)
#     Site3~0 (empty Site 3)
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0).RPTOR(ARM,S792~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)+RPTOR(ARM,S792~P) kcat_AMPKa1b2g1
#     Site3~P (phosphorylated Site 3)
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P).RPTOR(ARM,S792~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)+RPTOR(ARM,S792~P) kcat_AMPKa1b2g1
#     Site3~ATP (ATP-bound Site 3)
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP).RPTOR(ARM,S792~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)+RPTOR(ARM,S792~P) kcat_AMPKa1b2g1
#     Site3~AMP (AMP docked at Site 3 but not clamped by RIM2 - no allosteric activation)
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP).RPTOR(ARM,S792~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)+RPTOR(ARM,S792~P) kcat_AMPKa1b2g1
#    relatively fast phosphorylation (when AMPK IS allosterically activated by AMP)
#     Site3~AMP_RIM2 (AMP-bound Site 3, with AMP clamped by RIM2 and allosterically activating the kinase)
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).RPTOR(ARM,S792~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)+RPTOR(ARM,S792~P) \
allosteric_foldincrease_AMPbinding_AMPKa1b2g1*kcat_AMPKa1b2g1
#  AMPKa2b1g1
#   substrate docks in catalytic cleft of enzyme
#    comments:
#     - requires T-loop phosphorylation
#PRKAA2(CAMK,T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2)+RPTOR(ARM,S792~0)->\
#PRKAA2(CAMK!3,T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2).RPTOR(ARM,S792~0!3) kf_substrate_AMPKa2b1g1
#   substrate dissociates (without phosphorylation)
#PRKAA2(CAMK!1).RPTOR(ARM,S792~0!1)->PRKAA2(CAMK)+RPTOR(ARM,S792~0) kr_substrate_AMPKa2
#   catalysis, followed very closely by release of phosphorylated substrate
#    relatively slow phosphorylation (when AMPK is NOT allosterically activated by AMP)
#     Site3~0 (empty Site 3)
#PRKAA2(CAMK!3,T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0).RPTOR(ARM,S792~0!3)->\
#PRKAA2(CAMK,T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)+RPTOR(ARM,S792~P) kcat_AMPKa2b1g1
#     Site3~P (phosphorylated Site 3)
#PRKAA2(CAMK!3,T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P).RPTOR(ARM,S792~0!3)->\
#PRKAA2(CAMK,T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)+RPTOR(ARM,S792~P) kcat_AMPKa2b1g1
#     Site3~ATP (ATP-bound Site 3)
#PRKAA2(CAMK!3,T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP).RPTOR(ARM,S792~0!3)->\
#PRKAA2(CAMK,T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)+RPTOR(ARM,S792~P) kcat_AMPKa2b1g1
#     Site3~AMP (AMP docked at Site 3 but not clamped by RIM2 - no allosteric activation)
#PRKAA2(CAMK!3,T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP).RPTOR(ARM,S792~0!3)->\
#PRKAA2(CAMK,T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)+RPTOR(ARM,S792~P) kcat_AMPKa2b1g1
#    relatively fast phosphorylation (when AMPK IS allosterically activated by AMP)
#     Site3~AMP_RIM2 (AMP-bound Site 3, with AMP clamped by RIM2 and allosterically activating the kinase)
#PRKAA2(CAMK!3,T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).RPTOR(ARM,S792~0!3)->\
#PRKAA2(CAMK,T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)+RPTOR(ARM,S792~P) \
#allosteric_foldincrease_AMPbinding_AMPKa2b1g1*kcat_AMPKa2b1g1
#  AMPKa2b2g1
#   substrate docks in catalytic cleft of enzyme
#    comments:
#     - requires T-loop phosphorylation
#PRKAA2(CAMK,T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2)+RPTOR(ARM,S792~0)->\
#PRKAA2(CAMK!3,T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2).RPTOR(ARM,S792~0!3) kf_substrate_AMPKa2b2g1
#   substrate dissociates (without phosphorylation)
#PRKAA2(CAMK!1).RPTOR(ARM,S792~0!1)->PRKAA2(CAMK)+RPTOR(ARM,S792~0) kr_substrate_AMPKa2 # <-- This rule is already defined above.
#   catalysis, followed very closely by release of phosphorylated substrate
#    relatively slow phosphorylation (when AMPK is NOT allosterically activated by AMP)
#     Site3~0 (empty Site 3)
#PRKAA2(CAMK!3,T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0).RPTOR(ARM,S792~0!3)->\
#PRKAA2(CAMK,T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)+RPTOR(ARM,S792~P) kcat_AMPKa2b2g1
#     Site3~P (phosphorylated Site 3)
#PRKAA2(CAMK!3,T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P).RPTOR(ARM,S792~0!3)->\
#PRKAA2(CAMK,T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)+RPTOR(ARM,S792~P) kcat_AMPKa2b2g1
#     Site3~ATP (ATP-bound Site 3)
#PRKAA2(CAMK!3,T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP).RPTOR(ARM,S792~0!3)->\
#PRKAA2(CAMK,T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)+RPTOR(ARM,S792~P) kcat_AMPKa2b2g1
#     Site3~AMP (AMP docked at Site 3 but not clamped by RIM2 - no allosteric activation)
#PRKAA2(CAMK!3,T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP).RPTOR(ARM,S792~0!3)->\
#PRKAA2(CAMK,T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)+RPTOR(ARM,S792~P) kcat_AMPKa2b2g1
#    relatively fast phosphorylation (when AMPK IS allosterically activated by AMP)
#     Site3~AMP_RIM2 (AMP-bound Site 3, with AMP clamped by RIM2 and allosterically activating the kinase)
#PRKAA2(CAMK!3,T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).RPTOR(ARM,S792~0!3)->\
#PRKAA2(CAMK,T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)+RPTOR(ARM,S792~P) \
#allosteric_foldincrease_AMPbinding_AMPKa2b2g1*kcat_AMPKa2b2g1

# dephosphorylation of RPTOR
RPTOR(S792~P)->RPTOR(S792~0) k_dephos_RPTOR_pS792

#################################################################################
# AMPK phosphorylates S1387 in TSC2 via Michaelis-Menten mechanism (no docking) #
#################################################################################

#################################################################
# AMPK alpha1-beta1-gamma1 isoform phosphorylates S1387 in TSC2 #
#################################################################

# AMPK binds substrate (S1387 in TSC2)
PRKAA1(CAMK,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2)+TSC2(S1387~0)->\
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2).TSC2(S1387~0!3) kf_substrate_AMPKa1b1g1

# AMPK releases substrate (S1387 in TSC2) without catalysis of phosphorylation
PRKAA1(CAMK!1).TSC2(S1387~0!1)->PRKAA1(CAMK)+TSC2(S1387~0) kr_substrate_AMPKa1

# AMPK catalyzes phosphorylation of substrate (S1387 in TSC2) followed very closely by product dissociation
#  Site3~0
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0).TSC2(S1387~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)+TSC2(S1387~P) kcat_AMPKa1b1g1
#  Site3~P
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P).TSC2(S1387~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)+TSC2(S1387~P) kcat_AMPKa1b1g1
#  Site3~ATP
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP).TSC2(S1387~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)+TSC2(S1387~P) kcat_AMPKa1b1g1
#  Site3~AMP
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP).TSC2(S1387~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)+TSC2(S1387~P) kcat_AMPKa1b1g1
#  Site3~AMP_RIM2
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).TSC2(S1387~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)+TSC2(S1387~P) \
allosteric_foldincrease_AMPbinding_AMPKa1b1g1*kcat_AMPKa1b1g1

#######################################################################
# AMPK alpha1-beta2-gamma1 isoform phosphorylates T1330/S1387 in TSC2 #
#######################################################################

# AMPK binds substrate (S1387 in TSC2)
PRKAA1(CAMK,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2)+TSC2(S1387~0)->\
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2).TSC2(S1387~0!3) kf_substrate_AMPKa1b2g1

# AMPK releases substrate (S1387 in TSC2) without catalysis of phosphorylation
#PRKAA1(CAMK!1).TSC2(S1387~0!1)->PRKAA1(CAMK)+TSC2(S1387~0) kr_substrate_AMPKa1 # <-- This rule is already defined above.

# AMPK catalyzes phosphorylation of substrate (S1387 in TSC2) followed very closely by product dissociation
#  Site3~0
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0).TSC2(S1387~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)+TSC2(S1387~P) kcat_AMPKa1b2g1
#  Site3~P
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P).TSC2(S1387~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)+TSC2(S1387~P) kcat_AMPKa1b2g1
#  Site3~ATP
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP).TSC2(S1387~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)+TSC2(S1387~P) kcat_AMPKa1b2g1
#  Site3~AMP
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP).TSC2(S1387~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)+TSC2(S1387~P) kcat_AMPKa1b2g1
#  Site3~AMP_RIM2
PRKAA1(CAMK!3,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).TSC2(S1387~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)+TSC2(S1387~P) \
allosteric_foldincrease_AMPbinding_AMPKa1b2g1*kcat_AMPKa1b2g1

# dephosphorylation of S1387 in TSC2
TSC2(S1387~P)->TSC2(S1387~0) k_dephos_TSC2_pS1387

#-- start of ULK1 complex assembly rules

############################
# ATG13-ATG101 interaction #
############################

# ATG101 reversibly associates with ATG13.
#  Association of ATG101 with ATG13 stabilizes ATG13's HORMA domain.
#   ATG101 binds/releases a copy of ATG13 that is NOT bound to RB1CC1.
ATG13(HORMAb,HORMAa)+ATG101(HORMA)<->\
ATG13(HORMAb,HORMAa!1).ATG101(HORMA!1) kf_ATG13_ATG101,kr_ATG13_ATG101
#   ATG101 releases a copy of ATG13 that IS bound to RB1CC1...
#    ...and ATG13 is NOT indirectly connected to RB1CC1.
#    RB1CC1 (aka FIP200) rapidly dissociates from ATG13 when ATG101 dissociates from ATG13
#    because of destabilization of ATG13's HORMA domain.
#    This rule liberates three reaction products.
ATG101(HORMA!1).ATG13(HORMAb!2,HORMAa!1).RB1CC1(LQFL!2)->\
ATG101(HORMA)+ATG13(HORMAb,HORMAa)+RB1CC1(LQFL) kr_ATG13_ATG101
#   ATG101 releases a copy of ATG13 that IS bound to RB1CC1...
#    ...and ATG13 IS indirectly connnected to RB1CC1.
#    RB1CC1 (aka FIP200) rapidly dissociates from ATG13 when ATG101 dissociates from ATG13
#    because of destabilization of ATG13's HORMA domain.
#    This rule liberates two reaction products.
#    NB: the rule below is not required when using NFsim (up to version 1.12) to perform simulations
#        because NFsim (up to version 1.12) does not check molecularity constraints on products.
ATG101(HORMA!1).ATG13(HORMAb!4,HORMAa!1,TLQ!2).RB1CC1(LQFL!4,unknown_ULK1!3).ULK1(EAT!2,unknown_RB1CC1!3)->\
ATG101(HORMA)+ATG13(HORMAb,HORMAa,TLQ!2).RB1CC1(LQFL,unknown_ULK1!3).ULK1(EAT!2,unknown_RB1CC1!3) kf_ATG13_ATG101

######################################
# ATG13-RB1CC1-ULK1 complex assembly #
######################################

# monomer-monomer association (3 rules)

# RB1CC1 associates with ATG13.
#  but only if ATG13 is bound at its HORMA domain by ATG101.
ATG13(HORMAb,HORMAa!+,TLQ)+RB1CC1(LQFL,unknown_ULK1)->\
ATG13(HORMAb!1,HORMAa!+,TLQ).RB1CC1(LQFL!1,unknown_ULK1) kf_ATG13_RB1CC1

# ULK1 associates with ATG13.
ATG13(HORMAb,TLQ)+ULK1(EAT,unknown_RB1CC1)->\
ATG13(HORMAb,TLQ!1).ULK1(EAT!1,unknown_RB1CC1) kf_ATG13_ULK1

# ULK1 associates with RB1CC1.
RB1CC1(LQFL,unknown_ULK1)+ULK1(EAT,unknown_RB1CC1)->\
RB1CC1(LQFL,unknown_ULK1!1).ULK1(EAT,unknown_RB1CC1!1) kf_RB1CC1_ULK1

# monomer-dimer association (6 rules)
#  Add ATG13 to an RB1CC1-ULK1 dimer (2 of 6 rules)...
#   ...via the ATG13-RB1CC1 interface.
ATG13(HORMAb,HORMAa!+,TLQ)+RB1CC1(LQFL,unknown_ULK1!1).ULK1(EAT,unknown_RB1CC1!1)->\
ATG13(HORMAb!2,HORMAa!+,TLQ).RB1CC1(LQFL!2,unknown_ULK1!1).ULK1(EAT,unknown_RB1CC1!1) kf_ATG13_RB1CC1
#   ...via the ATG13-ULK1 interface.
ATG13(HORMAb,TLQ)+RB1CC1(LQFL,unknown_ULK1!1).ULK1(EAT,unknown_RB1CC1!1)->\
ATG13(HORMAb,TLQ!2).RB1CC1(LQFL,unknown_ULK1!1).ULK1(EAT!2,unknown_RB1CC1!1) kf_ATG13_ULK1
#  Add RB1CC1 to an ATG13-ULK1 dimer (2 of 6 rules)...
#   ...via the RB1CC1-ATG13 interface.
RB1CC1(LQFL,unknown_ULK1)+ATG13(HORMAb,HORMAa!+,TLQ!1).ULK1(EAT!1,unknown_RB1CC1)->\
RB1CC1(LQFL!2,unknown_ULK1).ATG13(HORMAb!2,HORMAa!+,TLQ!1).ULK1(EAT!1,unknown_RB1CC1) kf_ATG13_RB1CC1
#   ...via the RB1CC1-ULK1 interface.
RB1CC1(LQFL,unknown_ULK1)+ATG13(HORMAb,TLQ!1).ULK1(EAT!1,unknown_RB1CC1)->\
RB1CC1(LQFL,unknown_ULK1!2).ATG13(HORMAb,TLQ!1).ULK1(EAT!1,unknown_RB1CC1!2) kf_RB1CC1_ULK1
#  Add ULK1 to an ATG13-RB1CC1 dimer (2 of 6 rules)...
#   ...via the ULK1-ATG13 interface.
ULK1(EAT,unknown_RB1CC1)+ATG13(HORMAb!1,HORMAa!+,TLQ).RB1CC1(LQFL!1,unknown_ULK1)->\
ULK1(EAT!2,unknown_RB1CC1).ATG13(HORMAb!1,HORMAa!+,TLQ!2).RB1CC1(LQFL!1,unknown_ULK1) kf_ATG13_ULK1
#   ...via the ULK1-RB1CC1 interace.
ULK1(EAT,unknown_RB1CC1)+ATG13(HORMAb!1,HORMAa!+,TLQ).RB1CC1(LQFL!1,unknown_ULK1)->\
ULK1(EAT,unknown_RB1CC1!2).ATG13(HORMAb!1,HORMAa!+,TLQ).RB1CC1(LQFL!1,unknown_ULK1!2) kf_RB1CC1_ULK1

# ring-closure (isomerization) reactions (3 rules)
#  cycle formation through ATG13-RB1CC1 association
ATG13(HORMAb,HORMAa!+,TLQ!1).RB1CC1(LQFL,unknown_ULK1!2).ULK1(EAT!1,unknown_RB1CC1!2)->\
ATG13(HORMAb!3,HORMAa!+,TLQ!1).RB1CC1(LQFL!3,unknown_ULK1!2).ULK1(EAT!1,unknown_RB1CC1!2) iso_ARU*kf_ATG13_RB1CC1
#  cycle formation through ATG13-ULK1 association
ATG13(HORMAb!1,HORMAa!+,TLQ).RB1CC1(LQFL!1,unknown_ULK1!2).ULK1(EAT,unknown_RB1CC1!2)->\
ATG13(HORMAb!1,HORMAa!+,TLQ!3).RB1CC1(LQFL!1,unknown_ULK1!2).ULK1(EAT!3,unknown_RB1CC1!2) iso_ARU*kf_ATG13_ULK1
#  cycle formation through RB1CC1-ULK1 association
ATG13(HORMAb!1,HORMAa!+,TLQ!2).RB1CC1(LQFL!1,unknown_ULK1).ULK1(EAT!2,unknown_RB1CC1)->\
ATG13(HORMAb!1,HORMAa!+,TLQ!2).RB1CC1(LQFL!1,unknown_ULK1!3).ULK1(EAT!2,unknown_RB1CC1!3) iso_ARU*kf_RB1CC1_ULK1

# dissociation reactions generating two products (3 rules)
#  Break an ATG13-RB1CC1 bond.
ATG13(HORMAb!1,HORMAa!+).RB1CC1(LQFL!1)->ATG13(HORMAb,HORMAa!+)+RB1CC1(LQFL) kr_ATG13_RB1CC1
#  Break an ATG13-ULK1 bond.
ATG13(TLQ!1).ULK1(EAT!1)->ATG13(TLQ)+ULK1(EAT) kr_ATG13_ULK1
#  Break an RB1CC1-ULK1 bond.
RB1CC1(unknown_ULK1!1).ULK1(unknown_RB1CC1!1)->RB1CC1(unknown_ULK1)+ULK1(unknown_RB1CC1) kr_RB1CC1_ULK1

# dissociation reactions generating only one product (3 rules)
#  NB: these rules are not required when using NFsim (up to version 1.12) to perform simulations
#      because NFsim (up to version 1.12) does not check molecularity constraints on products.
#  Break an ATG13-RB1CC1 bond.
ATG13(HORMAb!3,HORMAa!+,TLQ!1).RB1CC1(LQFL!3,unknown_ULK1!2).ULK1(EAT!1,unknown_RB1CC1!2)->\
ATG13(HORMAb,HORMAa!+,TLQ!1).RB1CC1(LQFL,unknown_ULK1!2).ULK1(EAT!1,unknown_RB1CC1!2) kr_ATG13_RB1CC1
#  Break an ATG13-ULK1 bond.
ATG13(HORMAb!1,HORMAa!+,TLQ!3).RB1CC1(LQFL!1,unknown_ULK1!2).ULK1(EAT!3,unknown_RB1CC1!2)->\
ATG13(HORMAb!1,HORMAa!+,TLQ).RB1CC1(LQFL!1,unknown_ULK1!2).ULK1(EAT,unknown_RB1CC1!2) kr_ATG13_ULK1
#  Break an RB1CC1-ULK1 bond.
ATG13(HORMAb!1,HORMAa!+,TLQ!2).RB1CC1(LQFL!1,unknown_ULK1!3).ULK1(EAT!2,unknown_RB1CC1!3)->\
ATG13(HORMAb!1,HORMAa!+,TLQ!2).RB1CC1(LQFL!1,unknown_ULK1).ULK1(EAT!2,unknown_RB1CC1) kr_RB1CC1_ULK1

#-- end of ULK1 complex assembly rules

# rule for degradation of (free) ATG13 (for simulation of ATG13 knockdown)
#ATG13(HORMAb,HORMAa,S224,S259,S355,S389,LIR,TLQ)->0 kdeg_ATG13

################################################
# AMPK associates with and phosphorylates ULK1 #
################################################
#---
# transformations:
#  - PRKAA1(Dock)+ULK1(S758)<->PRKAA1(Dock!1).ULK1(S758!1)
#  - ULK1(S317~0)->ULK1(S317~P)
#  - ULK1(S556~0)->ULK1(S556~P)
#  comments:
#   - activating phosphorylation
#   - We assume that AMPK must be docked at S758 in ULK1 to phosphorylate S317 and S556.
#   - Phosphorylation of S317 is taken to allow self-interaction of ULK1's kinase domain, 
#     which in turn, is taken to be important for autophosphorylation of T180 in the kinase
#     domain's activation loop.
#   - Phosphorylation of S556 enables interaction with 14-3-3 proteins.
#---

# AMPK (PRKAA1) associates with ULK1
PRKAA1(Dock~0)+ULK1(S758~0)<->PRKAA1(Dock~0!1).ULK1(S758~0!1) kf_AMPK_ULK1,kr_AMPK_ULK1

# activated AMPK catalyzes phosphorylation of tethered ULK1 at S317
#  alpha1-beta1-gamma1 isoform of AMPK
PRKAA1(CAMK,T183~P,CTD!1,Dock~0!3).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).\
ULK1(S317~0,S758~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1,Dock~0!3).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).\
ULK1(S317~P,S758~0!3) kcat_AMPK_ULK1
#  alpha1-beta2-gamma1 isoform of AMPK
PRKAA1(CAMK,T183~P,CTD!1,Dock~0!3).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).\
ULK1(S317~0,S758~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1,Dock~0!3).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).\
ULK1(S317~P,S758~0!3) kcat_AMPK_ULK1

# activated AMPK catalyzes phosphorylation of tethered ULK1 at S556
#  alpha1-beta1-gamma1 isoform of AMPK
PRKAA1(CAMK,T183~P,CTD!1,Dock~0!3).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).\
ULK1(S556~0,S758~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1,Dock~0!3).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).\
ULK1(S556~P,S758~0!3) kcat_AMPK_ULK1
#  alpha1-beta2-gamma1 isoform of AMPK
PRKAA1(CAMK,T183~P,CTD!1,Dock~0!3).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).\
ULK1(S556~0,S758~0!3)->\
PRKAA1(CAMK,T183~P,CTD!1,Dock~0!3).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2).\
ULK1(S556~P,S758~0!3) kcat_AMPK_ULK1

################################################
# dephosphorylation of pS317 and pS556 in ULK1 #
################################################

ULK1(S317~P)->ULK1(S317~0) k_dephos_ULK1_pS317
ULK1(S556~P)->ULK1(S556~0) k_dephos_ULK1_pS556

#######################################################################
# MTORC1 associates with and phosphorylates ULK1 and ULK1-bound ATG13 #
#######################################################################
#---
# transformations: 
#  - RPTOR(RNC)+ULK1(S317)<->RPTOR(RNC!1).ULK1(S317!1)
#  - ULK1(S758~0)->ULK1(S758~P)
#  comments:
#   - inhibitory phosphorylation
#   - We assume that MTORC1 must be docked at S317 in ULK1 to phosphorylate S758.
#   - Phosphorylation of S758 is taken to block AMPK-ULK1 interaction.
#---

# RPTOR associates with ULK1
RPTOR(RNC,S792~0,S855_S859~0)+ULK1(S317~0)->RPTOR(RNC!1,S792~0,S855_S859~0).ULK1(S317~0!1) kf_RPTOR_ULK1
RPTOR(RNC!1).ULK1(S317~0!1)->RPTOR(RNC)+ULK1(S317~0) kr_RPTOR_ULK1

# activated MTORC1 catalyzes phosphorylation of tethered ULK1 at S758
ULK1(S317~0!1,S758~0).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,PIKK~ATP,N_LBE!3).RHEB(G~GTP!3)->\
ULK1(S317~0!1,S758~P).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,PIKK~ATP,N_LBE!3).RHEB(G~GTP!3) \
kcat_MTORC1_ULK1

# activated MTORC1 catalyzes phosphorylation of tethered ATG13 at S259
ULK1(S317~0!1,EAT!2).ATG13(S259~0,TLQ!2).RPTOR(RNC!1,RNC_ARM!3).MTOR(HEAT_step!3,PIKK~ATP,N_LBE!4).RHEB(G~GTP!4)->\
ULK1(S317~0!1,EAT!2).ATG13(S259~P,TLQ!2).RPTOR(RNC!1,RNC_ARM!3).MTOR(HEAT_step!3,PIKK~ATP,N_LBE!4).RHEB(G~GTP!4) \
kcat_MTORC1_ULK1_ATG13

######################################
# dephosphorylation of pS758 in ULK1 #
######################################

ULK1(S758~P)->ULK1(S758~0) k_dephos_ULK1_pS758

#######################################
# dephosphorylation of pS259 in ATG13 #
#######################################

ATG13(S259~P)->ATG13(S259~0) k_dephos_ATG13_pS259

############################
# ULK1 autophosphorylation #
############################
#---
# transformations:
#  - ULK1(Pkinase)+ULK1(T180)<->ULK1(Pkinase!1).ULK1(T180!1)
#  - ULK1(T180~0)->ULK1(T180~P)
#  comments:
#   - autocatalytic positive feedback
#   - Activated ULK1 phosphorylates T180 in the activation loop of a second copy of ULK1.
#   - We assume that phosphorylation of S317 (and/or nearby S/T sites) in each of two
#     copies of ULK1 allows the kinase domains in these copies of ULK1 to self-associate.
#   - We assume that ULK1 is maximally activated if phosphorylated at T180.
#   - We assume that ULK1 is minimally activated if bound to a copy of ATG13
#     that is not phosphorylated at S224 or S259. This mode of activation may be critical
#     when phosphorylation of T180 is zero or very low.
#---

# ATG13-activated ULK1 binds T180 in a second copy of ULK1
ULK1(Pkinase,S317~P,EAT!1).ATG13(S259~0,TLQ!1)+ULK1(T180~0,S317~P)->\
ULK1(Pkinase!2,S317~P,EAT!1).ATG13(S259~0,TLQ!1).ULK1(T180~0!2,S317~P) kp1_ULK1_ULK1
# Autophosphorylated ULK1 binds T180 in a second copy of ULK1
ULK1(Pkinase,T180~P,S317~P)+ULK1(T180~0,S317~P)->\
ULK1(Pkinase!1,T180~P,S317~P).ULK1(T180~0!1,S317~P) kp1_ULK1_ULK1
# ULK1 releases T180 without catalysis of phosphorylation
ULK1(Pkinase!1).ULK1(T180~0!1)->ULK1(Pkinase)+ULK1(T180~0) km1_ULK1_ULK1
# ATG13-activated ULK1 phosphorylates T180 in a second copy of ULK1, followed closely by product release
ULK1(Pkinase!1,EAT!+).ULK1(T180~0!1)->ULK1(Pkinase,EAT!+)+ULK1(T180~P) kcat_ULK1_ULK1_slow
# Autophosphorylated ULK1 phosphorylates T180 in a second copy of ULK1, followed closely by product release 
ULK1(Pkinase!1,T180~P).ULK1(T180~0!1)->ULK1(Pkinase,T180~P)+ULK1(T180~P) kcat_ULK1_ULK1_fast

######################################
# dephosphorylation of pT180 in ULK1 #
######################################

ULK1(T180~P)->ULK1(T180~0) k_dephos_ULK1_pT180

###########################################################################
# ULK1 phosphorylates AMPK at its docking site and AMP/ATP-binding site 3 #
###########################################################################
#---
# transformations: 
#  - ULK1(Pkinase)+PRKAA1(Dock)<->ULK1(Pkinase!1).PRKAA1(Dock!1)
#  - PRKAA1(Dock~0)->PRKAA1(Dock~P)
#  - ULK1(Pkinase)+PRKAG1(Site3)<->ULK1(Pkinase!1).PRKAG1(Site3!1)
#  - PRKAG1(Site3~0)->PRKAG1(Site3~P)
#  comments:
#   - negative feedback from ULK1 to AMPK
#   - Phosphorylation of Dock in the alpha subunit of AMPK prevents AMPK docking to AMPK substrates (e.g., ULK1).
#   - Phosphorylation of Site 3 in the gamma subunit of AMPK prevents AMP/ATP binding to AMPK.
#---

# ULK1 phosphorylates the hypothetical substrate-docking site in the alpha subunit of AMPK
ULK1(Pkinase,T180~P)+PRKAA1(Dock~0)->ULK1(Pkinase!1,T180~P).PRKAA1(Dock~0!1) kp1_ULK1_AMPK
ULK1(Pkinase!1).PRKAA1(Dock~0!1)->ULK1(Pkinase)+PRKAA1(Dock~0) km1_ULK1_AMPK
ULK1(Pkinase!1,T180~P).PRKAA1(Dock~0!1)->ULK1(Pkinase,T180~P)+PRKAA1(Dock~P) kcat_ULK1_AMPK

# ULK1 phosphorylates AMP/ATP-binding site 3 (Site3) in the gamma subunit of AMPK
ULK1(Pkinase,T180~P)+PRKAG1(Site3~0)->ULK1(Pkinase!1,T180~P).PRKAG1(Site3~0!1) kp1_ULK1_AMPK
ULK1(Pkinase!1).PRKAG1(Site3~0!1)->ULK1(Pkinase)+PRKAG1(Site3~0) km1_ULK1_AMPK
ULK1(Pkinase!1,T180~P).PRKAG1(Site3~0!1)->ULK1(Pkinase,T180~P)+PRKAG1(Site3~P) kcat_ULK1_AMPK

###################################################################################################
# dephosphorylation of pDock in PRKAA1/2 subunit of AMPK and pSite3 in PRKAG1/2/3 subunit of AMPK #
###################################################################################################

PRKAA1(Dock~P)->PRKAA1(Dock~0) k_dephos_AMPK_pDock
PRKAG1(Site3~P)->PRKAG1(Site3~0) k_dephos_AMPK_pSite3

###########################################
# ULK1 phosphorylates RAPTOR at S855/S859 #
###########################################
#---
# transformations:
#  - ULK1(Pkinase)+RPTOR(S855_S859)<->ULK1(Pkinase!1).RPTOR(S855_S859!1)
#  - RPTOR(S855_S859~0)->RPTOR(S855_S859~P)
#  comments:
#   - positive feedback (relief of MTORC1-mediated repression)
#   - S855 and S859 are lumped together.
#   - Phosphorylation of S855/S859 in RPTOR prevents RPTOR docking to MTORC1 substrates.
#---

ULK1(Pkinase,T180~P)+RPTOR(S855_S859~0)->ULK1(Pkinase!1,T180~P).RPTOR(S855_S859~0!1) kp1_ULK1_RPTOR
ULK1(Pkinase!1).RPTOR(S855_S859!1)->ULK1(Pkinase)+RPTOR(S855_S859~0) km1_ULK1_RPTOR
ULK1(Pkinase!1,T180~P).RPTOR(S855_S859~0!1)->ULK1(Pkinase,T180~P)+RPTOR(S855_S859~P) kcat_ULK1_RPTOR

##########################################
# dephosphorylation pS855/pS859 in RPTOR #
##########################################

RPTOR(S855_S859~P)->RPTOR(S855_S859~0) k_dephos_RPTOR_pS855_S859

###########################################
# ULK1 phosphorylates AMBRA1 at S465/S635 #
###########################################
#---
# transformations:
#  - ULK1(Pkinase)+AMBRA1(S465_S635)<->ULK1(Pkinase!1).AMBRA1(S465_S635!1)
#  - AMBRA1(S465_S635~0)->AMBRA1(S465_S635~P)
#  comments:
#   - activating phosphorylation of an effector of autophagy
#   - S465 and S635 are lumped together.
#---

ULK1(Pkinase,T180~P)+AMBRA1(S465_S635~0)->ULK1(Pkinase!1,T180~P).AMBRA1(S465_S635~0!1) kp1_ULK1_AMBRA1
ULK1(Pkinase!1).AMBRA1(S465_S635!1)->ULK1(Pkinase)+AMBRA1(S465_S635~0) km1_ULK1_AMBRA1
ULK1(Pkinase!1,T180~P).AMBRA1(S465_S635~0!1)->ULK1(Pkinase,T180~P)+AMBRA1(S465_S635~P) kcat_ULK1_AMBRA1

##############################################
# dephosphorylation of pS465/pS635 in AMBRA1 #
##############################################

AMBRA1(S465_S635~P)->AMBRA1(S465_S635~0) k_dephos_pAMBRA1

#######################################
# ULK1 phosphorylates Beclin-1 at S15 #
#######################################
#---
# transformations:
#  - ULK1(Pkinase)+BECN1(S15)<->ULK1(Pkinase!1).BECN1(S15!1)
#  - BECN1(S15~0)->BECN1(S15~P)
#  comments:
#   - activating phosphorylation of an effector of autophagy
#---

ULK1(Pkinase,T180~P)+BECN1(S15~0)->ULK1(Pkinase!1,T180~P).BECN1(S15~0!1) kp1_ULK1_AMBRA1
ULK1(Pkinase!1).BECN1(S15!1)->ULK1(Pkinase)+BECN1(S15~0) km1_ULK1_AMBRA1
ULK1(Pkinase!1,T180~P).BECN1(S15~0!1)->ULK1(Pkinase,T180~P)+BECN1(S15~P) kcat_ULK1_AMBRA1

#########################################
# dephosphorylation of pS15 in Beclin-1 #
#########################################

BECN1(S15~P)->BECN1(S15~0) k_dephos_pBECN1

end reaction rules

end model

