#   Site3~AMP_RIM2
#PRKAA2(T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)->\
#PRKAA2(T172~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2) kslow_dephosT_AMPKa2b1g1
#  AMPKa2b2g1
#   Site3~0
#PRKAA2(T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)->\
#PRKAA2(T172~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0) kfast_dephosT_AMPKa2b2g1
#   Site3~P
#PRKAA2(T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)->\
#PRKAA2(T172~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P) kfast_dephosT_AMPKa2b2g1
#   Site3~ATP
#PRKAA2(T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)->\
