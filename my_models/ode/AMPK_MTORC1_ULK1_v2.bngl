begin parameters

# fraction of a cell to consider in a stochastic simulation
#  comments:
#   - The scaling factor f should multiply volumes, copy numbers 
#     and rate constants for zero-order processes (e.g., a synthesis reaction).
#   - This parameter can be set to a value <1 to accelerate stochastic simulation.
#   - The value of f has no effect on the speed of a deterministic (ODE-based) simulation.
f 0.0001 # dimensionless, 0<f<=1

# ratio of a circle's circumference to its diameter
pi 3.14159265359 # dimensionless 

# Avogadro constant
NA 6.02214e23 # molecules per mol

#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# top of "sizes of compartments" section

#########################
# sizes of compartments #
#########################

##############################
# extracellular fluid  (ecf) #
##############################

# volume of extracellular fluid surrounding a single cell on average (Vecf)
#  comments:
#   - We assume that cells have been grown in 15 cm culture dishes to 95% confluency.
#   - For these conditions, we estimate a surface density of 1.25e5 adherent cells per cm^2 
#     and a growth surface area of 140 cm^2 per dish. Thus, we estimate 1.7e7 cells per dish.
#   - We assume that 0.25 mL of medium has been added to dishes for each square cm of growth surface.
#     Thus, we estimate 35 mL of medium per dish.
#   - The volume (L) of extracellular fluid per cell is (0.25e-3*140)/(1.25e5*140) = 2.0e-9 L per cell.
Vecf_condition_01 2.0e-9*f # L (dm^3) per cell

# experimental condition-specific parameter setting (Vecf)
Vecf=Vecf_condition_01 # L (dm^3) per cell

#################
# cytosol (cyt) #
#################

# volume of cytosol (Vcyt)
#  comments:
#   - We could consider 1.2 pL to be a typical volume for a non-dividing mammalian cell
#     in culture based on the volume assays of Tan et al. (2012) for 5 mammalian cell 
#     lines (HEK293T, MDCK, Caco-2, SW480, and SW480APC):
#     median=1.16 pL, avg=1.36 pL, min=1.15 pL, and max=1.87 pL.
#   - HeLa and U2OS cells were not evaluated in the study of Tan et al. (2012).
#   - Hein et al. (2015) assumed a volume of 2 pL for HeLa Kyoto cells when estimating 
#     protein concentrations; see Table S3.
Vcyt_A549       2e-12*f # L (dm^3) per cell
Vcyt_HEK293     1.16e-12*f # L (dm^3) per cell, from Table 3 in Tan et al. (2012)
Vcyt_U2OS       2e-12*f # L (dm^3) per cell
Vcyt_HeLa_S3    2e-12*f # L (dm^3) per cell
Vcyt_HeLa_Kyoto 2e-12*f # L (dm^3) per cell

# cell line-specific parameter setting (Vcyt)
Vcyt=Vcyt_U2OS # L (dm^3) per cell

# viscosity of cytosolic fluid (water)
eta_cyt 6.913e-4 # Pa s

#######################################################################
# thin layer adjacent to lysosomal membranes facing the cytosol (lys) #
#######################################################################

# effective thickness of a thin layer in which reactions occur on lysosomal membranes 
#  comments:
#   - basalolateral membranes of lysosomes, i.e., lysosomal membranes facing the cytosol
#   - assumed range is 10 to 20 nm
Tlys 2e-7 # dm

# characteristic diameter of a lysosome
#  comments:
#   - http://bionumbers.hms.harvard.edu/bionumber.aspx?id=106072
#   - assumed range is 0.1 to 1.2 microns
Dlys_A549       5e-6 # dm
Dlys_HEK293     5e-6 # dm
Dlys_U2OS       5e-6 # dm
Dlys_HeLa_S3    5e-6 # dm
Dlys_HeLa_Kyoto 5e-6 # dm

# cell line-specific parameter setting (Dlys)
Dlys=Dlys_U2OS # dm 

# number of lysosomes per cell
#  comments:
#   - http://bionumbers.hms.harvard.edu/bionumber.aspx?id=107483
#   - range is 50 to 1000 lysosomes per cell
Nlys_A549       50*f # copies per cell
Nlys_HEK293     50*f # copies per cell
Nlys_U2OS       50*f # copies per cell
Nlys_HeLa_S3    50*f # copies per cell
Nlys_HeLa_Kyoto 50*f # copies per cell

# cell line-specific parameter setting (Nlys)
Nlys=Nlys_U2OS # copies per cell

# total lysosomal membrane surface area 
Alys=Nlys*(pi*Dlys^2) # dm^2 per cell

# volume of cytoplasmic perilysosomal thin layer
Vlys=Nlys*(pi/6)*((Dlys+Tlys)^3-Dlys^3) # L (dm^3) per cell

# viscosity of lysosomal membrane (olive oil)
eta_lys 3.41e-2 # Pa s

