# factor that converts abundance as measured by iBAQ value to copies per cell
#  comments:
#   - This factor is specific to a particular experiment.
#   - The iBAQ value of a protein is proportional to its molar abundance in cell lysate.
iBAQ1_to_cpc_HEK293 0.16*f # converts iBAQ value to copies per cell

# convert from log10(iBAQ) to copies per cell
FKBP1A_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^FKBP1A_iBAQ1_HEK293 # copies per cell

MTOR_cpc_HEK293   = iBAQ1_to_cpc_HEK293*10^MTOR_iBAQ1_HEK293   # copies per cell
RPTOR_cpc_HEK293  = iBAQ1_to_cpc_HEK293*10^RPTOR_iBAQ1_HEK293  # copies per cell
MLST8_cpc_HEK293  = iBAQ1_to_cpc_HEK293*10^MLST8_iBAQ1_HEK293  # copies per cell

RPS6KB1_cpc_HEK293  = iBAQ1_to_cpc_HEK293*10^RPS6KB1_iBAQ1_HEK293  # copies per cell
EIF4EBP1_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^EIF4EBP1_iBAQ1_HEK293 # copies per cell
EIF4E_cpc_HEK293    = iBAQ1_to_cpc_HEK293*10^EIF4E_iBAQ1_HEK293    # copies per cell

LAMTOR1_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^LAMTOR1_iBAQ1_HEK293 # copies per cell
LAMTOR2_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^LAMTOR2_iBAQ1_HEK293 # copies per cell
LAMTOR3_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^LAMTOR3_iBAQ1_HEK293 # copies per cell
#LAMTOR4_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^LAMTOR4_iBAQ1_HEK293 # copies per cell
LAMTOR5_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^LAMTOR5_iBAQ1_HEK293 # copies per cell

# We will set the abundance of LAMTOR4 to the average of the abundances of LAMTOR1,2,3,5.
LAMTOR4_cpc_HEK293=(LAMTOR1_cpc_HEK293+LAMTOR2_cpc_HEK293+LAMTOR3_cpc_HEK293+LAMTOR5_cpc_HEK293)/4

RRAGA_cpc_HEK293 = iBAQ1_to_cpc_HEK293*10^RRAGA_iBAQ1_HEK293 # copies per cell
