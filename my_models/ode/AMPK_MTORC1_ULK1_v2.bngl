Molecules PIKK_ATP MTOR(PIKK~ATP!?)
#Molecules PIKK_AZD8055 MTOR(PIKK~AZD8055!?)

#Molecules boundPIKK MTOR(PIKK!+)
#Molecules boundRNC RPTOR(RNC!+)

#Molecules RPTOR_not_assoc_with_MTOR RPTOR(RNC_ARM)
#Molecules MLST8_MTOR_bonds MTOR(LBE_FATC!1).MLST8(WD40!1)
#Molecules MTOR_RPTOR_bonds MTOR(HEAT_step!1).RPTOR(RNC_ARM!1)
