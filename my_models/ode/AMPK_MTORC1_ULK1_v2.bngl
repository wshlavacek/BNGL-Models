#Molecules AMPK_a2b2g3 PRKAA2(CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG3(CBS1!2)

Molecules AMPKa1b1g1_isActivated PRKAA1(T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2!?)
Molecules AMPKa1b2g1_isActivated PRKAA1(T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2!?)
#Molecules AMPKa2b1g1_isActivated PRKAA2(T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2!?)
#Molecules AMPKa2b2g1_isActivated PRKAA2(T172~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2!?)

Molecules ATG13tot ATG13()
Molecules ATG101tot ATG101()
Molecules RB1CC1tot RB1CC1()
Molecules ULK1tot ULK1()

Molecules ATG101_ATG13_bonds_cpc ATG101(HORMA!1).ATG13(HORMAa!1)
Molecules ATG13_ULK1_bonds_cpc ATG13(TLQ!1).ULK1(EAT!1)
Molecules ATG13_RB1CC1_bonds_cpc ATG13(HORMAb!1).RB1CC1(LQFL!1)
Molecules RB1CC1_ULK1_bonds_cpc RB1CC1(unknown_ULK1!1).ULK1(unknown_RB1CC1!1)
Species cyclic_ternary_complex_ATG13_RB1CC1_ULK1_cpc ATG13(HORMAb!1,TLQ!2).RB1CC1(LQFL!1,unknown_ULK1!3).ULK1(EAT!2,unknown_RB1CC1!3)

Molecules AMBRA1_total AMBRA1()
Molecules AMBRA1_0 AMBRA1(S465_S635~0!?)
Molecules AMBRA1_P AMBRA1(S465_S635~P!?)

Molecules BECN1_total BECN1()
Molecules BECN1_0 BECN1(S15~0!?)
Molecules BECN1_P BECN1(S15~P!?)

Molecules TSC2tot TSC2()
Molecules TSC2_S1387_0 TSC2(S1387~0!?)
Molecules TSC2_S1387_P TSC2(S1387~P!?)

Molecules RPTOR_S792_0 RPTOR(S792~0!?)
Molecules RPTOR_S792_P RPTOR(S792~P!?)
Molecules RPTOR_S855_S859_0 RPTOR(S855_S859~0!?)
Molecules RPTOR_S855_S859_P RPTOR(S855_S859~P!?)

Molecules ULK1_pS317 ULK1(S317~P!?)
Molecules ULK1_pS556 ULK1(S556~P!?)
Molecules ULK1_pS758 ULK1(S758~P!?)

Molecules AMPK_pT172 PRKAA1(T183~P!?)
Molecules AMPK_bound_to_AMP PRKAG1(Site3~AMP!?) PRKAG1(Site3~AMP_RIM2!?)
Molecules activated_AMPK PRKAA1(T183~P!?,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2!?) PRKAA1(T183~P!?,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2!?)

Molecules AMPK_docked_to_ULK1 PRKAA1(Dock~0!1).ULK1(S758~0!1)
Molecules AMPK_pDock PRKAA1(Dock~P!?)
Molecules AMPK_pSite3 PRKAG1(Site3~P!?)

end observables

begin functions

#AZD8055_abundance() AZD8055_cpc
#rapamycin_abundance() rapamycin_cpc

#frac_MTOR_monomers() (MTORtot-2*MTOR_MTOR_interfaces)/MTORtot
#frac_MTOR_in_tetramers() 2*MTORC1_with_0_mLST8/MTORtot
#frac_MTOR_in_pentamers() 2*MTORC1_with_1_mLST8/MTORtot
#frac_MTOR_in_hexamers()  2*MTORC1_with_2_mLST8/MTORtot
#frac_MTORdimers_with_1or2_MLST8() 2*(MTORC1_with_2_mLST8+MTORC1_with_1_mLST8)/MTORtot
#one_MTOR() ((MTORtot-2*MTOR_MTOR_interfaces)+2*(MTORC1_with_0_mLST8+MTORC1_with_1_mLST8+MTORC1_with_2_mLST8))/MTORtot

#frac_RPTOR_in_monomers() RPTOR_not_assoc_with_MTOR/RPTORtot
#frac_RPTOR_in_heterodimers_with_MTOR() MTOR_RPTOR_dimers/RPTORtot
#frac_RPTOR_in_heterotrimers_with_MTOR_MLST8() RPTOR_monMTOR_MLST8_trimers/RPTORtot
#frac_RPTOR_in_tetramers_with_0_MLST8() 2*MTORC1_with_0_mLST8/RPTORtot
#frac_RPTOR_in_tetramers_with_1_MLST8() 2*MTORC1_with_1_mLST8/RPTORtot
#frac_RPTOR_in_tetramers_with_2_MLST8() 2*MTORC1_with_2_mLST8/RPTORtot
#one_RPTOR() (RPTOR_not_assoc_with_MTOR+MTOR_RPTOR_dimers+RPTOR_monMTOR_MLST8_trimers+2*(MTORC1_with_0_mLST8+MTORC1_with_1_mLST8+MTORC1_with_2_mLST8))/RPTORtot

# approximate rate laws for ATP/AZD8055 exchange
#  comments:
#   - The 1e-6 term is just a small number (<<1) included to avoid a "divide by zero" issue.
#   - We assume that the internal and exteranl AZD8055 concentrations are essentially the same.
#   - We assume that the free pools of AZD8055 and ATP cannot be significantly depleted by MTOR.
#   - We assume that the amount of free ATP-binding site in MTOR's kinase domain is negligible.
#   - With these assumptions, we obtain the following equation for AZD8055-PIKK binding dynamics:
#     dB/dt = (kpB/(1+KA))*MTORtot - (kmB+kpB/(1+KA))*B, where B = [PIKK~AZD8055].
#     Furthermore, we obtain [PIKK~0] = 0 dA/dt = -dB/dt, where A = [PIKK~ATP].
rateLaw_AZD8055_replaces_ATP() AZD8055_isPresent*((MTORtot/(PIKK_ATP+1e-6))*(kpB/(1+KA)))
rateLaw_ATP_replaces_AZD8055() AZD8055_isPresent*(kmB+kpB/(1+KA))

#PIKK_ATP_approx_formula() MTORtot*(1+KA)/(1+KA+KB)
#PIKK_AZD8055_approx_formula() MTORtot*KB/(1+KA+KB)

#PIKK_0_exact_formula() fracPIKK_0*MTOR_cpc
#PIKK_ATP_exact_formula() fracPIKK_ATP*MTOR_cpc
#PIKK_AZD8055_exact_formula() fracPIKK_AZD8055*MTOR_cpc

# a factor that ranges from 1 to 10 and that characterizes the effect of
#  AMPK-mediated phosphorylation of TSC2 at S1387, which increases TSC2 GAP activity
AMPK_boost_factor() 1+9*TSC2_S1387_P/TSC2tot

end functions

begin reaction rules

########################################################################
# amino acid control of GDP/GTP-loading status of RagA/B-RagC/D dimers #
########################################################################
#---
# amino acid control of GDP/GTP-loading status of RagA/B-RagC/D dimers
#  transformations:
#   - RRAGC(G~GDP)->RRAGC(G~GTP)
#   - RRAGC(G~GTP)->RRAGC(G~GDP)
#  comments:
#   - RAPTOR interacts with both RagA/B and RagC/D in a Rag dimer, but in this model,
#     for simplicity, we take RAPTOR to interact with just RagC/D.
#     The contribution of RagA/B to RAPTOR interaction with a Rag dimer is implicit.
#   - The GDP/GTP-loading status of RagC/D (and RagA/B) determines whether a
#     Ragulator-associated Rag dimer is competent for interaction with RAPTOR:
#     GDP-loaded RagC/D is competent for RAPTOR interaction and
#     GTP-loaded RagC/D is incompetent for RAPTOR interaction.
#   - Rag proteins freely exchange guanine nucleotides.
#   - Amino-acid regulated RagC/D GAPs include leucyl-tRNA-synthetase and folliculin.
#   - We assume that RagC/D GAPs act only on Ragulator-associated RagC/D in RagA/B-RagC/D dimers.
#   - The effective Rag/CD GAP activity (i.e., the value of the rate constant
#     "kRagCD_AA_regulated_GAP_activity") can be tuned by adjusting the "AA_conc_uM" parameter.
#     Use the setParameter command in the actions block for this purpose.
#     Increasing the amino acid (AA) concentration will activate RagC/D GAP activity
#     and promote recruitment of RAPTOR (and MTORC1) to Rag-Ragulator complexes on lysosomes.
#     Decreasing the amino acid (AA) concentration will inhibit RagC/D GAP activity
#     and dampen recruitment of RAPTOR (and MTORC1) to Rag-Ragulator complexes on lysosomes.
#---

# GDP-to-GTP transition (spontaneous)
RRAGC(G~GDP)->RRAGC(G~GTP) kRagCD_exchange

# GTP-to-GDP transition (mediated by amino acid-regulated RagC/D GAPs)
RRAGC(G~GTP,RB!+,GdistalC!+)->RRAGC(G~GDP,RB!+,GdistalC!+) kRagCD_AA_regulated_GAP_activity

####################################################
# growth factor control of lysosomal RHEB activity #
####################################################
#---
# growth factor control of lysosomal RHEB activity
#  transformations:
#   - RHEB(G~GDP)->RHEB(G~GT 
#   - RHEB(G~GTP)->RHEB(G~GDP)
#  comments:
#   - The GDP-to-GTP transition is taken to occur spontaneously.
#   - The GTP-to-GDP transition is mediated by TSC2, a RHEB GAP.
#   - TSC2 GAP activity is inhibited by growth factor signaling,
#     partly via AKT-mediated phosphorylation of TSC2 at S939 and T1462.
#   - TSC2 GAP activity is increased after AMPK phosphorylates TSC2 at S1387.
#   - A detailed treatment of how growth factor signaling inhibits TSC2 GAP activity
#     (or how AMPK activates TSC2 GAP activity) is beyond the intended scope of this model.
#   - The effective TSC2 GAP activity (i.e., the value of the rate constant
#     "kRHEB_TSC2_GAP_activity") can be tuned by adjusting the "growth_factor_conc_pM" parameter.
#     Use the setParameter command in the actions block for this purpose.
#     Increasing the growth factor concentration will inhibit TSC2 GAP activity 
#     and promote GTP-loading of RHEB.
#     Decreasing the growth factor concentration will relieve inhibition of TSC2 GAP activity
#     and promote GDP-loading of RHEB.
#---

# GDP-to-GTP transition (spontaneous)
RHEB(G~GDP,GKSSC_farnesyl,loc~lys)->RHEB(G~GTP,GKSSC_farnesyl,loc~lys) kRHEB_exchange

# GTP-to-GDP transition (mediated by TSC2 GAP activity)
#  AMPK-mediated phosphorylation of TSC2 at S1387 increases TSC2 GAP activity by a factor.
#  See the global function "AMPK_boost_factor()" defined in the functions block.
RHEB(G~GTP,GKSSC_farnesyl,loc~lys)->RHEB(G~GDP,GKSSC_farnesyl,loc~lys) \
kRHEB_TSC2_GAP_activity*AMPK_boost_factor()

#############################
# rapamycin inhibits MTORC1 #
#############################

# rapamycin in complex with FKBP1A reversibly binds the FRB domain in MTOR 
FKBP1A(FKBP~rapamycin)+MTOR(FRB)<->FKBP1A(FKBP~rapamycin!1).MTOR(FRB!1) kf_FRB_rapaFKBP,kr_FRB_rapaFKBP

###########################
# AZD8055 inhibits MTORC1 #
###########################

# ATP/AZD8055 exchange
MTOR(PIKK~ATP!?)->MTOR(PIKK~AZD8055!?) rateLaw_AZD8055_replaces_ATP()
MTOR(PIKK~AZD8055!?)->MTOR(PIKK~ATP!?) rateLaw_ATP_replaces_AZD8055()

#-- start of rules for assembly of MTORC1

##########################
# MTOR-MLST8 interaction #
##########################

# monomeric MLST8 associates with monomeric RPTOR-free MTOR
#  comments:
#   - We assume that dimeric MTOR is always bound to RPTOR (i.e., there is no
#     rule that allows RPTOR to dissociate from dimeric MTOR), so we do
#     not need to consider the case of dimeric RPTOR-free MTOR.
#   - MTOR associates with itself via its HEAT_horn and FAT domains, 
#     so it is monomeric when these parts of the protein are unoccupied.
#   - MTOR associates with RPTOR via the HEAT_step structure, so MTOR is free
#     of RPTOR when this structure is unoccupied.
MTOR(HEAT_horn,HEAT_step,FAT,LBE_FATC)+MLST8(WD40)->\
MTOR(HEAT_horn,HEAT_step,FAT,LBE_FATC!1).MLST8(WD40!1) kf_MLST8_MTOR

# monomeric MLST8 associates with monomeric or dimeric RPTOR-bound MTOR
#  comments:
#   - Association is assumed to be faster than when MTOR is bound to RPTOR (positive cooperativity).
#   - RPTOR-bound MTOR can be monomeric or dimeric.
#   - We assume that the oligomerization state of MTOR does not affect
#     association of MLST8 with MTOR.
MTOR(HEAT_step!1,LBE_FATC).RPTOR(RNC_ARM!1)+MLST8(WD40)->\
MTOR(HEAT_step!1,LBE_FATC!2).RPTOR(RNC_ARM!1).MLST8(WD40!2) \
kf_MLST8_MTOR*phi_kf_MLST8_MTOR_RPTOR

# dissociation of MLST8 from monomeric or dimeric RPTOR-free MTOR
#  comments:
#   - MTOR associates with RPTOR via its HEAT_step structure, so it is free
#     of RPTOR when this structure is unoccupied.
MTOR(HEAT_step,LBE_FATC!1).MLST8(WD40!1)->\
MTOR(HEAT_step,LBE_FATC)+MLST8(WD40) kr_MLST8_MTOR

# dissociation of MLST8 from monomeric or dimeric RPTOR-bound MTOR
#  comments:
#   - Dissociation is assumed to be slower when MTOR is bound to RPTOR (positive cooperativity).
#   - RPTOR-bound MTOR can be monomeric or dimeric.
#   - We assume that the oligomerization state of MTOR does not affect
#     dissociation of MLST8 from MTOR.
MTOR(HEAT_step!1,LBE_FATC!2).RPTOR(RNC_ARM!1).MLST8(WD40!2)->\
MTOR(HEAT_step!1,LBE_FATC).RPTOR(RNC_ARM!1)+MLST8(WD40) kr_MLST8_MTOR*phi_kr_MLST8_MTOR_RPTOR

##########################
# MTOR-RPTOR interaction #
##########################

# monomeric RPTOR associates with monomeric MLST8-free MTOR
#  comments:
#   - Association is not blocked when S792 in RPTOR is phosphorylated (and bound to 14-3-3 proteins).
#   - MTOR associates with itself via its HEAT_horn and FAT domains, 
#     so it is monomeric when these parts of the protein are unoccupied.
#   - MTOR associates with MLST8 via its LBE_FATC structure, so it is free of MLST8
#     when this structure is unoccupied.
MTOR(HEAT_horn,HEAT_step,FAT,LBE_FATC)+RPTOR(RNC_ARM)->\
MTOR(HEAT_horn,HEAT_step!1,FAT,LBE_FATC).RPTOR(RNC_ARM!1) kf_MTOR_RPTOR

# monomeric RPTOR associates with monomeric MLST8-bound MTOR
#  comments:
#   - Association is not blocked when S792 in RPTOR is phosphorylated (and bound to 14-3-3 proteins).
#   - MTOR associates with itself via its HEAT_horn and FAT domains, 
#     so it is monomeric when these parts of the protien are unoccupied.
#   - Association is assumed to be faster when MTOR is bound to MLST8 (positive cooperativity).
MTOR(HEAT_horn,HEAT_step,FAT,LBE_FATC!1).MLST8(WD40!1)+RPTOR(RNC_ARM)->\
MTOR(HEAT_horn,HEAT_step!2,FAT,LBE_FATC!1).MLST8(WD40!1).RPTOR(RNC_ARM!2) \
kf_MTOR_RPTOR*phi_kf_MLST8_MTOR_RPTOR

# dissociation of RPTOR from monomeric MLST8-free MTOR
#  comments:
#   - We assume that dissociation of RPTOR from dimeric MTOR is unfavorable, so we 
#     do not allow for dissociation of RPTOR from dimeric MTOR.
#   - MTOR associates with itself via its HEAT_horn and FAT domains, 
#     so it is monomeric when these parts of the protein are unoccupied.
#   - MTOR associates with MLST8 via its LBE_FATC structure, so it is free of MLST8
#     when this structure is unoccupied.
#   - As a simplification, we require that MTOR's kinase domain (PIKK) be free of substrate.
#     This constraint prevents a substrate from tethering RPTOR and MTOR together after break up
#     of the RPTOR-MTOR interface.
MTOR(HEAT_horn,HEAT_step!1,FAT,PIKK,LBE_FATC).RPTOR(RNC_ARM!1)->\
MTOR(HEAT_horn,HEAT_step,FAT,PIKK,LBE_FATC)+RPTOR(RNC_ARM) kr_MTOR_RPTOR

# dissociation of RPTOR from monomeric MLST8-bound MTOR
#  comments:
#   - We assume that dissociation of RPTOR from dimeric MTOR is unfavorable, so we
#     do not allow for dissociation of RPTOR from dimeric MTOR.
#   - Dissociation is assumed to be slower when MTOR is bound to MLST8 (positive cooperativity).
#   - As a simplification, we require that MTOR's kinase domain (PIKK) be free of substrate.
#     This constraint prevents a substrate from tethering RPTOR and MTOR together after break up
#     of the RPTOR-MTOR interface.
MTOR(HEAT_horn,HEAT_step!2,FAT,PIKK,LBE_FATC!1).MLST8(WD40!1).RPTOR(RNC_ARM!2)->\
MTOR(HEAT_horn,HEAT_step,FAT,PIKK,LBE_FATC!1).MLST8(WD40!1)+RPTOR(RNC_ARM) \
kr_MTOR_RPTOR*phi_kr_MLST8_MTOR_RPTOR

#########################
# MTOR homodimerization #
#########################

# RPTOR-dependent formation of an MTOR homodimer
#  comments:
#   - MTOR homodimerization is taken to require RPTOR stabilization of MTOR's HEAT domain.
#   - We assume that homodimerization only occurs in the cytosol, meaning that
#     RPTOR's ARM domain is not bound to a lysosomal RRAGA/B-RRAGC/D dimer
MTOR(HEAT_horn,HEAT_step!1,FAT).RPTOR(RNC_ARM!1,ARM)+\
MTOR(HEAT_horn,HEAT_step!2,FAT).RPTOR(RNC_ARM!2,ARM)<->\
MTOR(HEAT_horn!3,HEAT_step!1,FAT!4).RPTOR(RNC_ARM!1,ARM).\
MTOR(HEAT_horn!4,HEAT_step!2,FAT!3).RPTOR(RNC_ARM!2,ARM) kf_MTOR_MTOR,kr_MTOR_MTOR

#--- end of rules for assembly of MTORC1
 
# rule for degradation of free MLST8 (for simulation of MLST8 knockdown)
MLST8(WD40)->0 kdeg_MLST8 
  
#--- start of rules for phosphorylation of substrates by MTORC1

##########################################################################
# RPTOR-mediated recruitment of TOS motif-containing substrate to MTORC1 #
##########################################################################

# RAPTOR associates with S6K1 
RPTOR(RNC,S792~0,S855_S859~0)+RPS6KB1(TOS)->RPTOR(RNC!1,S792~0,S855_S859~0).RPS6KB1(TOS!1) kf_RNC_TOS
# RAPTOR dissociates from S6K1
#  comments:
#   - RAPTOR is not bound to MTOR (i.e., the RNC_ARM site is free).
RPTOR(RNC!1,RNC_ARM).RPS6KB1(TOS!1)->RPTOR(RNC,RNC_ARM)+RPS6KB1(TOS) kr_RNC_TOS
# RAPTOR dissociates from S6K1
#  comments:
#   - RAPTOR is bound to MTOR.
#   - In this case, we require that the catalytic site of MTOR be free of substrate.
#     This constraint is introduced as a simplification so that we do not need to deal
#     with a ternary complex in which substrate bridges unconnected copies of RAPTOR and MTOR.
#   - The presence of MTOR does not otherwise affect dissociation 
#     (cf. the rate constants assigned to the rules above and below).
RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,PIKK).RPS6KB1(TOS!1)->\
RPTOR(RNC,RNC_ARM!2).MTOR(HEAT_step!2,PIKK)+RPS6KB1(TOS) kr_RNC_TOS

# RAPTOR associates with 4E-BP1
RPTOR(RNC,S792~0,S855_S859~0)+EIF4EBP1(TOS)->RPTOR(RNC!1,S792~0,S855_S859~0).EIF4EBP1(TOS!1) kf_RNC_TOS
# RAPTOR dissociates from 4E-BP1
#  comments:
#   - RAPTOR is not bound to MTOR (i.e., the RNC_ARM site is free).
# S65
RPTOR(RNC!1,RNC_ARM).EIF4EBP1(S65_T70~0,TOS!1)->RPTOR(RNC,RNC_ARM)+EIF4EBP1(S65_T70~0,TOS) kr_RNC_TOS
# pS65
RPTOR(RNC!1,RNC_ARM).EIF4EBP1(S65_T70~P,TOS!1)->RPTOR(RNC,RNC_ARM)+EIF4EBP1(S65_T70~P,TOS) kr_RNC_TOS*factor_pS65
# RAPTOR dissociates from 4E-BP1
#  comments:
#   - RAPTOR is bound to MTOR.
#   - In this case, we require that the catalytic site of MTOR be free of substrate.
#     This constraint is introduced as a simplification so that we do not need to deal
#     with a ternary complex in which substrate bridges unconnected copies of RAPTOR and MTOR.
#   - The presence of MTOR does not otherwise affect dissociation 
#     (cf. the rate constants assigned to the rules above and below).
# S65
RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,PIKK).EIF4EBP1(S65_T70~0,TOS!1)->\
RPTOR(RNC,RNC_ARM!2).MTOR(HEAT_step!2,PIKK)+EIF4EBP1(S65_T70~0,TOS) kr_RNC_TOS
# pS65
RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,PIKK).EIF4EBP1(S65_T70~P,TOS!1)->\
RPTOR(RNC,RNC_ARM!2).MTOR(HEAT_step!2,PIKK)+EIF4EBP1(S65_T70~P,TOS) kr_RNC_TOS*factor_pS65

#############################################################################
# RPTOR-tethered substrate reversibly associates with MTOR's catalytic site #
#############################################################################

# T389 in S6K1 associates with MTOR's catalytic site 
# when MTOR's FRB domain is free 
#  comments:
#   - unimolecular isomerization
#   - T389 in S6K1 is a rapamycin-sensitive site.
#   - We assume that access to MTOR's catalytic cleft is blocked
#     unless MTOR is dimeric, which is true when the FAT domain is bound
#     (by the HEAT_horn domain in a second copy of MTOR).
RPS6KB1(TOS!1,T389~0).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,FAT!+,PIKK,FRB)->\
RPS6KB1(TOS!1,T389~0!3).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,FAT!+,PIKK!3,FRB) \
kp1_MTOR_tetheredSub_s*eps
# T389 in S6K1 associates with MTOR's catalytic site 
# when MTOR's FRB domain is bound by rapamycin-FKBP12 (steric hindrance)
#  comments:
#   - unimolecular isomerization
#   - T389 in S6K1 is a rapamycin-sensitive site.
#   - We assume that access to MTOR's catalytic cleft is blocked
#     unless MTOR is dimeric, which is true when the FAT domain is bound
#     (by the HEAT_horn domain in a second copy of MTOR).
#   - The rate of reaction is reduced by a factor phi, which accounts for
#     steric hindrance.
RPS6KB1(TOS!1,T389~0).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,FAT!+,PIKK,FRB!+)->\
RPS6KB1(TOS!1,T389~0!3).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,FAT!+,PIKK!3,FRB!+) \
phi*kp1_MTOR_tetheredSub_s*eps
# T389 in S6K1 dissociates from MTOR's catalytic site (without phosphorylation)
#  comments:
#   - We assume that dissociation is not influenced by the occupancy of the FRB domain.
RPS6KB1(TOS!1,T389~0!3).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,PIKK!3)->\
RPS6KB1(TOS!1,T389~0).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,PIKK) km1_MTOR_substrate

# T37/T46 in 4E-BP1 associates with MTOR's catalytic site
# when MTOR's FRB domain is free
#  comments:
#   - isomerization reaction
#   - T37 and T46 in 4E-BP1 are rapamycin-resistant sites.
#   - We assume that access to MTOR's catalytic cleft is blocked
#     unless MTOR is dimeric, which is true when the FAT domain is bound
#     (by the HEAT_horn domain in a second copy of MTOR).
EIF4EBP1(T37_T46~0,TOS!1).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,FAT!+,PIKK,FRB)->\
EIF4EBP1(T37_T46~0!3,TOS!1).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,FAT!+,PIKK!3,FRB) \
kp1_MTOR_tetheredSub_r*eps
# T37/T46 in 4E-BP1 associates with MTOR's catalytic site
# when MTOR's FRB domain is bound by rapamycin-FKBP12 (steric hindrance)
#  comments:
#   - isomerization reaction
#   - T37 and T46 in 4E-BP1 are rapamycin-resistant sites.
#   - We assume that access to MTOR's catalytic cleft is blocked
#     unless MTOR is dimeric, which is true when the FAT domain is bound
#     (by the HEAT_horn domain in a second copy of MTOR).
#   - The rate of reaction is reduced by a factor phi, which accounts for
#     steric hindrance.
EIF4EBP1(T37_T46~0,TOS!1).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,FAT!+,PIKK,FRB!+)->\
EIF4EBP1(T37_T46~0!3,TOS!1).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,FAT!+,PIKK!3,FRB!+) \
phi*kp1_MTOR_tetheredSub_r*eps
# T37/T46 dissociates from MTOR's catalytic site (without phosphorylation)
#  comments:
#   - We assume that dissociation is not influenced by the occupancy of the FRB domain.
EIF4EBP1(T37_T46~0!3,TOS!1).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,PIKK!3)->\
EIF4EBP1(T37_T46~0,TOS!1).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,PIKK) km1_MTOR_substrate

# S65/T70 in 4E-BP1 associates with MTOR's catalytic site
# when MTOR's FRB domain is free
#  comments:
#   - isomerization reaction
#   - S65 and T70 in 4E-BP1 are rapamycin-sensitive sites.
#   - We assume that S65/T70 are hidden unless T37/T46 are phosphorylated.
#   - We assume that access to MTOR's catalytic cleft is blocked
#     unless MTOR is dimeric, which is true when the FAT domain is bound
#     (by the HEAT_horn domain in a second copy of MTOR).
EIF4EBP1(T37_T46~P,S65_T70~0,TOS!1).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,FAT!+,PIKK,FRB)->\
EIF4EBP1(T37_T46~P,S65_T70~0!3,TOS!1).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,FAT!+,PIKK!3,FRB) \
kp1_MTOR_tetheredSub_s*eps
# S65/T70 in 4E-BP1 associates with MTOR's catalytic site
# when MTOR's FRB domain is bound by rapamycin-FKBP12 (steric hindrance)
#  comments:
#   - isomerization reaction
#   - S65 and T70 in 4E-BP1 are rapamycin-sensitive sites.
#   - We assume that access to MTOR's catalytic cleft is blocked
#     unless MTOR is dimeric, which is true when the FAT domain is bound
#     (by the HEAT_horn domain in a second copy of MTOR).
#   - The rate of reaction is reduced by a factor phi, which accounts for
#     steric hindrance.
EIF4EBP1(T37_T46~P,S65_T70~0,TOS!1).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,FAT!+,PIKK,FRB!+)->\
EIF4EBP1(T37_T46~P,S65_T70~0!3,TOS!1).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,FAT!+,PIKK!3,FRB!+) \
phi*kp1_MTOR_tetheredSub_s*eps
# S65/T70 dissociates from MTOR's catalytic site (without phosphorylation)
#  comments:
#   - We assume that dissociation is not influenced by the occupancy of the FRB domain.
EIF4EBP1(S65_T70~0!3,TOS!1).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,PIKK!3)->\
EIF4EBP1(S65_T70~0,TOS!1).RPTOR(RNC!1,RNC_ARM!2).MTOR(HEAT_step!2,PIKK) km1_MTOR_substrate

##############################################################
# MTOR-catalyzed phosphorylation followed by                 #
# rapid dissociation of substrate from MTOR's catalytic site #
# and rapid recharging of MTOR's ATP-binding pocket with ATP #
##############################################################

# phosphorylation of T389 in S6K1
#  comments:
#   - Note that MTOR's ATP-binding pocket must be charged with ATP (PIKK~ATP).
#   - We require MTOR to be associated (indirectly) with a Rag-Ragulator complex.
#     This condition holds if RPTOR's ARM domain is bound.
#   - We require that the N_LBE fragment in MTOR be bound by GTP-loaded RHEB.
RPS6KB1(TOS!1,T389~0!3).RPTOR(RNC!1,RNC_ARM!2,ARM!+).\
MTOR(HEAT_step!2,PIKK~ATP!3,N_LBE!4).RHEB(G~GTP!4)->\
RPS6KB1(TOS!1,T389~P).RPTOR(RNC!1,RNC_ARM!2,ARM!+).\
MTOR(HEAT_step!2,PIKK~ATP,N_LBE!4).RHEB(G~GTP!4) kcat_MTOR

# phosphorylation of T37/T46 in 4E-BP1
#  comments:
#   - Note that MTOR's ATP-binding pocket must be charged with ATP (PIKK~ATP).
#   - We require MTOR to be associated (indirectly) with a Rag-Ragulator complex.
#     This condition holds if RPTOR's ARM domain is bound.
#   - We require that the N_LBE fragment in MTOR be bound by GTP-loaded RHEB.
EIF4EBP1(T37_T46~0!3,TOS!1).RPTOR(RNC!1,RNC_ARM!2,ARM!+).\
MTOR(HEAT_step!2,PIKK~ATP!3,N_LBE!4).RHEB(G~GTP!4)->\
EIF4EBP1(T37_T46~P,TOS!1).RPTOR(RNC!1,RNC_ARM!2,ARM!+).\
MTOR(HEAT_step!2,PIKK~ATP,N_LBE!4).RHEB(G~GTP!4) kcat_MTOR

# phosphorylation of S65/T70 in 4E-BP1
#  comments:
#   - Note that MTOR's ATP-binding pocket must be charged with ATP (PIKK~ATP).
#   - We require MTOR to be associated (indirectly) with a Rag-Ragulator complex.
#     This condition holds if RPTOR's ARM domain is bound.
#   - We require that the N_LBE fragment in MTOR be bound by GTP-loaded RHEB.
EIF4EBP1(S65_T70~0!3,TOS!1).RPTOR(RNC!1,RNC_ARM!2,ARM!+).\
MTOR(HEAT_step!2,PIKK~ATP!3,N_LBE!4).RHEB(G~GTP!4)->\
EIF4EBP1(S65_T70~P,TOS!1).RPTOR(RNC!1,RNC_ARM!2,ARM!+).\
MTOR(HEAT_step!2,PIKK~ATP,N_LBE!4).RHEB(G~GTP!4) kcat_MTOR

#-- end of rules for phosphorylation of substrates by MTORC1
  
# dephosphorylation of MTORC1 substrates
#  comments:
#   - We assume that phosphatases are available in excess and constitutively active.
RPS6KB1(T389~P)->RPS6KB1(T389~0) k_dephosphorylation
EIF4EBP1(T37_T46~P)->EIF4EBP1(T37_T46~0) k_dephosphorylation 
EIF4EBP1(S65_T70~P)->EIF4EBP1(S65_T70~0) k_dephosphorylation 

######################
# Ragulator assembly #
######################

# heterodimerization of LAMTOR2 and LAMTOR3
#  comments:
#   - The intention of requiring the Gdistal and Gproximal components to be free
#     is to restrict this interaction to the cytosol.
LAMTOR2(RB,Gdistal)+LAMTOR3(RB,Gproximal)<->\
LAMTOR2(RB!1,Gdistal).LAMTOR3(RB!1,Gproximal) kf_LAMTOR23,kr_LAMTOR23

# heterodimerization of LAMTOR4 and LAMTOR5
#  comments:
#   - The intention of requiring the Gdistal and Gproximal components to be free
#     is to restrict this interaction to the cytosol.
LAMTOR4(RB,Gdistal)+LAMTOR5(RB,Gproximal)<->\
LAMTOR4(RB!1,Gdistal).LAMTOR5(RB!1,Gproximal) kf_LAMTOR45,kr_LAMTOR45

# homodimerization of LAMTOR5
#  comments:
#   - The intention of requiring the Gdistal and Gproximal components to be free
#     is to restrict this interaction to the cytosol.
#   - This interaction limits the amount of LAMTOR5 available to interact with LAMTOR4.
LAMTOR5(RB,Gproximal)+LAMTOR5(RB,Gproximal)<->\
LAMTOR5(RB!1,Gproximal).LAMTOR5(RB!1,Gproximal) kf_LAMTOR55,kr_LAMTOR55

# capture of cytosolic LAMTOR2/3 dimer by lysosomal LAMTOR1
#  comments:
#   - We assume that LAMTOR2 and LAMTOR3 are only competent to interact with LAMTOR1 as a dimer 
LAMTOR1(Cloop)+LAMTOR2(RB!1,Gdistal).LAMTOR3(RB!1,Gproximal)<->\
LAMTOR1(Cloop!2).LAMTOR2(RB!1,Gdistal!2).LAMTOR3(RB!1,Gproximal) kf_LAMTOR12,kr_LAMTOR12

# capture of cytosolic LAMTOR4/5 dimer by lysosomal LAMTOR1
#  comments:
#   - We assume that LAMTOR4 and LAMTOR5 are only competent to interact with LAMTOR1 as a dimer 
LAMTOR1(Helix)+LAMTOR4(RB!1,Gdistal).LAMTOR5(RB!1,Gproximal)<->\
LAMTOR1(Helix!2).LAMTOR4(RB!1,Gdistal!2).LAMTOR5(RB!1,Gproximal) kf_LAMTOR14,kr_LAMTOR14

#################################
# dimerization of RagA and RagC #
#################################

# heterodimerization of RagA and RagC
#  comments:
#   - The intention of requiring the GdistalA and GdistalC components to be free is
#     to restrict this interaction to the cytosol.
#   - We require the two G domains of RagA and RagC to be free for both association
#     and dissociation reactions.
#   - RagA-RagC interaction is assumed to be unaffected by G domain state (~0,~GDP,~GTP).
RRAGA(G,RB,GdistalA)+RRAGC(G,RB,GdistalC)<->RRAGA(G,RB!1,GdistalA).RRAGC(G,RB!1,GdistalC) kf_RagAC,kr_RagAC

########################################################
# RagA-RagC dimer interacts with the Ragulator complex #
########################################################

# capture of RagA-RagC heterodimer by Ragulator complex
#  comments:
#   - Addition of RagA-RagC to the Ragulator complex generates a cyclic aggregate, which we assume is stable.
#     This is consistent with the observation that Ego2p deletion destabilizes Gtr11-Gtr2p interaction
#     (Powis et al., 2015).
#   - Addition is assumed to proceed via binding of RagA or RagC to a G-proximal face of a 
#     LAMTOR2/3 or LAMTOR4/5 dimer, followed very closely by ring closure (i.e., isomerization from
#     an open linear aggregate to a closed cyclic aggregate).
#   - Thus, addition generates two bonds in an effective one-step reaction:
#      1) GdistalA in RagA binds the Gproximal face of LAMTOR2/3, and
#      2- GdistalC in RagC binds the Gproximal face of LAMTOR4/5.
#   - We only allow the cyclic Rag-Ragulator complex to form by addition of RagA-RagC to Ragulator.
#   - We only allow the cyclic Rag-Ragulator complex to disassemble by removal of RagA-RagC.
#   - Removal eliminates two bonds in an effective one-step reaction, which takes much longer than the lifetime
#     of either of the two individual Rag-Ragulator interfaces (because of ring reformation whenever one of the 
#     two interfaces opens).
#   - We require the two G domains of RagA and RagC to be free for both association
#     and dissociation reactions. This means that RAPTOR binding to Rag-Ragulator will stabilize
#     Rag-Ragulator association.
#   - RagA-RagC interaction with the Ragulator complex is assumed to be unaffected 
#     by the RagA and RagC G domain states (~0,~GDP,~GTP).
RRAGA(G,RB!7,GdistalA).RRAGC(G,RB!7,GdistalC)+\
LAMTOR1(Helix!1,Cloop!2).\
LAMTOR2(RB!3,Gdistal!2).LAMTOR3(RB!3,Gproximal).\
LAMTOR4(RB!4,Gdistal!1).LAMTOR5(RB!4,Gproximal)<->\
RRAGA(G,RB!7,GdistalA!5).RRAGC(G,RB!7,GdistalC!6).\
LAMTOR1(Helix!1,Cloop!2).\
LAMTOR2(RB!3,Gdistal!2).LAMTOR3(RB!3,Gproximal!5).\
LAMTOR4(RB!4,Gdistal!1).LAMTOR5(RB!4,Gproximal!6) kf_RagAC_Ragulator,kr_RagAC_Ragulator

# degradation of (free) LAMTOR componentnts
#LAMTOR2(RB,Gdistal)->0 kdeg_LAMTOR
LAMTOR5(RB,Gproximal)->0 kdeg_LAMTOR
 
 ###############################################################
 # recruitment of RAPTOR (and MTORC1) to Rag-Ragulator complex #
 ###############################################################
 
# Ragulator-bound RagA-RagC dimer interacts with cytosolic RAPTOR
#  comments:
#   - For simplicity, we assume that RAPTOR only recognizes RagA-RagC dimers docked to 
#     the Ragulator complex. 
#   - We assume that a "GTP-locked" conformation of RagA and that a "GDP-locked" conformation 
#     of RagC are both required for RagA-RagC interaction with RAPTOR.
#   - Both G domains of a RagA-RagC dimer interact with RAPTOR; however, for simplicity, we will
#     only explicitly represent a bond between the G domain in RagC and RAPTOR. Similarly, we will
#     only explicitly represent bonding with RAPTOR's ARM domain, even though other parts of RAPTOR
#     may be important for interaction with Rag proteins.
#   - A RagA-RagC dimer is bound to a Ragulator complex when its GdistalA and GdistalC sites are
#     occupied.
#  RAPTOR is NOT bound to MTOR (RAPTOR's RNC_ARM structure is free)
RRAGA(G~GTP,RB!1,GdistalA!+).RRAGC(G~GDP,RB!1,GdistalC!+)+\
RPTOR(RNC_ARM,ARM)<->\
RRAGA(G~GTP,RB!1,GdistalA!+).RRAGC(G~GDP!2,RB!1,GdistalC!+).RPTOR(RNC_ARM,ARM!2) \
kf_RAPTOR_RagAC,kr_RAPTOR_RagAC
#  RAPTOR is bound to MTOR and MTOR is NOT bound to a second copy of MTOR
#   (MTOR's HEAT_horn and FAT structures are free)
RRAGA(G~GTP,RB!1,GdistalA!+).RRAGC(G~GDP,RB!1,GdistalC!+)+\
RPTOR(RNC_ARM!2,ARM).MTOR(HEAT_horn,HEAT_step!2,FAT)<->\
RRAGA(G~GTP,RB!1,GdistalA!+).RRAGC(G~GDP!3,RB!1,GdistalC!+).\
RPTOR(RNC_ARM!2,ARM!3).MTOR(HEAT_horn,HEAT_step!2,FAT) \
kf_RAPTOR_RagAC,kr_RAPTOR_RagAC
# RAPTOR is part of cytosolic MTORC1
RRAGA(G~GTP,RB!1,GdistalA!+).RRAGC(G~GDP,RB!1,GdistalC!+)+\
RPTOR(RNC_ARM!2,ARM).MTOR(HEAT_horn!3,HEAT_step!2,FAT!4).\
MTOR(HEAT_horn!4,HEAT_step!5,FAT!3).RPTOR(RNC_ARM!5,ARM)<->\
RRAGA(G~GTP,RB!1,GdistalA!+).RRAGC(G~GDP!6,RB!1,GdistalC!+).\
RPTOR(RNC_ARM!2,ARM!6).MTOR(HEAT_horn!3,HEAT_step!2,FAT!4).\
MTOR(HEAT_horn!4,HEAT_step!5,FAT!3).RPTOR(RNC_ARM!5,ARM) \
kf_RAPTOR_RagAC,kr_RAPTOR_RagAC

# MTORC1-mediated crosslinking of RagA(GTP)-RagC(GDP)-Ragulator
#  Detachment of RAPTOR from Rag-Ragulator requires that both copies
#  of MTOR be free of RHEB.
RRAGA(G~GTP,RB!1,GdistalA!+).RRAGC(G~GDP!6,RB!1,GdistalC!+).\
RPTOR(RNC_ARM!2,ARM!6).MTOR(HEAT_horn!3,HEAT_step!2,FAT!4,N_LBE).\
MTOR(HEAT_horn!4,HEAT_step!5,FAT!3,N_LBE).RPTOR(RNC_ARM!5,ARM)+\
RRAGA(G~GTP,RB!7,GdistalA!+).RRAGC(G~GDP,RB!7,GdistalC!+)<->\
RRAGA(G~GTP,RB!1,GdistalA!+).RRAGC(G~GDP!6,RB!1,GdistalC!+).\
RPTOR(RNC_ARM!2,ARM!6).MTOR(HEAT_horn!3,HEAT_step!2,FAT!4,N_LBE).\
MTOR(HEAT_horn!4,HEAT_step!5,FAT!3,N_LBE).RPTOR(RNC_ARM!5,ARM!8).\
RRAGA(G~GTP,RB!7,GdistalA!+).RRAGC(G~GDP!8,RB!7,GdistalC!+) \
kpx_RAPTOR_RagAC,kmx_RAPTOR_RagAC

#####################################################
# RHEB interaction with MTOR bound to Rag-Ragulator #
#####################################################

# Binding of RHEB to MTOR requires that MTOR be doubly anchored via RAPTOR
# and Rag-Ragulator to a lysosome. 
# Binding to MTOR is independent of the GDP/GTP loading status of RHEB.
RHEB(G,GKSSC_farnesyl,loc~lys)+\
MTOR(HEAT_horn!3,HEAT_step!1,FAT!4,N_LBE).RPTOR(RNC_ARM!1,ARM!+).\
MTOR(HEAT_horn!4,HEAT_step!2,FAT!3).RPTOR(RNC_ARM!2,ARM!+)<->\
RHEB(G!5,GKSSC_farnesyl,loc~lys).\
MTOR(HEAT_horn!3,HEAT_step!1,FAT!4,N_LBE!5).RPTOR(RNC_ARM!1,ARM!+).\
MTOR(HEAT_horn!4,HEAT_step!2,FAT!3).RPTOR(RNC_ARM!2,ARM!+) kf_MTORC1_RHEB,kr_MTORC1_RHEB

#################
# AMPK assembly #
#################

# AMPK assembly/disassembly
#   The beta subunit reversibly binds the alpha subunit.
PRKAB1(CTD_alpha)+PRKAA1(CTD)<->PRKAB1(CTD_alpha!1).PRKAA1(CTD!1) kf_BA_AMPK,kr_BA_AMPK
PRKAB2(CTD_alpha)+PRKAA1(CTD)<->PRKAB2(CTD_alpha!1).PRKAA1(CTD!1) kf_BA_AMPK,kr_BA_AMPK
#PRKAB1(CTD_alpha)+PRKAA2(CTD)<->PRKAB1(CTD_alpha!1).PRKAA2(CTD!1) kf_BA_AMPK,kr_BA_AMPK
#PRKAB2(CTD_alpha)+PRKAA2(CTD)<->PRKAB2(CTD_alpha!1).PRKAA2(CTD!1) kf_BA_AMPK,kr_BA_AMPK
#   The beta subunit reversibly binds the gamma subunit.
PRKAB1(CTD_gamma)+PRKAG1(CBS1)<->PRKAB1(CTD_gamma!1).PRKAG1(CBS1!1) kf_BG_AMPK,kr_BG_AMPK
PRKAB2(CTD_gamma)+PRKAG1(CBS1)<->PRKAB2(CTD_gamma!1).PRKAG1(CBS1!1) kf_BG_AMPK,kr_BG_AMPK
#PRKAB1(CTD_gamma)+PRKAG2(CBS1)<->PRKAB1(CTD_gamma!1).PRKAG2(CBS1!1) kf_BG_AMPK,kr_BG_AMPK
#PRKAB2(CTD_gamma)+PRKAG2(CBS1)<->PRKAB2(CTD_gamma!1).PRKAG2(CBS1!1) kf_BG_AMPK,kr_BG_AMPK
#PRKAB1(CTD_gamma)+PRKAG3(CBS1)<->PRKAB1(CTD_gamma!1).PRKAG3(CBS1!1) kf_BG_AMPK,kr_BG_AMPK
#PRKAB2(CTD_gamma)+PRKAG3(CBS1)<->PRKAB2(CTD_gamma!1).PRKAG3(CBS1!1) kf_BG_AMPK,kr_BG_AMPK

#################################################################
# phosphorylationp/dephosphorylation of the T-loop in AMPKalpha #
#################################################################
#
# phosphorylation of AMPKalpha's T-loop threonine by LKB1 via Michaelis-Menten mechanism
#
#  association of kinase and substrate (LKB1cat+AMPKalpha_Tloop->LKB1cat.AMPKalpha_Tloop)
#   comments:
#    - The forward rate constant depends on the activation state of AMPK.
#    - Association is faster (by assumption) when AMPK is activated by AMP.
#
#   AMPKa1b1g1
#    Site3~0
STK11(CAMK)+PRKAA1(T183~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)->\
STK11(CAMK!3).PRKAA1(T183~0!3,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0) kf_AMPK_LKB1_slow
#    Site3~P
STK11(CAMK)+PRKAA1(T183~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)->\
STK11(CAMK!3).PRKAA1(T183~0!3,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P) kf_AMPK_LKB1_slow
#    Site3~ATP
STK11(CAMK)+PRKAA1(T183~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)->\
STK11(CAMK!3).PRKAA1(T183~0!3,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP) kf_AMPK_LKB1_slow
#    Site3~AMP
STK11(CAMK)+PRKAA1(T183~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)->\
STK11(CAMK!3).PRKAA1(T183~0!3,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP) kf_AMPK_LKB1_slow
#    Site3~AMP_RIM2
STK11(CAMK)+PRKAA1(T183~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)->\
STK11(CAMK!3).PRKAA1(T183~0!3,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2) kf_AMPK_LKB1_fast
#
#   AMPKa1b2g1
#    Site3~0
STK11(CAMK)+PRKAA1(T183~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)->\
STK11(CAMK!3).PRKAA1(T183~0!3,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0) kf_AMPK_LKB1_slow
#    Site3~P
STK11(CAMK)+PRKAA1(T183~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)->\
STK11(CAMK!3).PRKAA1(T183~0!3,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P) kf_AMPK_LKB1_slow
#    Site3~ATP
STK11(CAMK)+PRKAA1(T183~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)->\
STK11(CAMK!3).PRKAA1(T183~0!3,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP) kf_AMPK_LKB1_slow
#    Site3~AMP
STK11(CAMK)+PRKAA1(T183~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)->\
STK11(CAMK!3).PRKAA1(T183~0!3,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP) kf_AMPK_LKB1_slow
#    Site3~AMP_RIM2
STK11(CAMK)+PRKAA1(T183~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)->\
STK11(CAMK!3).PRKAA1(T183~0!3,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2) kf_AMPK_LKB1_fast
#
#  dissociation of substrate (without phosphorylation)
#   comments:
#    - We assume that dissociation is not affected by the activation state of AMPK.
#
#   AMPKa1
STK11(CAMK!1).PRKAA1(T183~0!1)->STK11(CAMK)+PRKAA1(T183~0) kr_AMPK_LKB1
#
#  phosphorylation, followed very closely by dissociation of product
#   comments:
#    - We assume that the catalytic step (the transition from enzyme-substrate complex
#      to product and enzyme) is not affected by whether AMPK is bound to AMP.
#
#   AMPKa1
STK11(CAMK!1).PRKAA1(T183~0!1)->STK11(CAMK)+PRKAA1(T183~P) kcat_AMPK_LKB1
#
#  association of kinase and substrate (LKB1cat+AMPKalpha_Tloop->LKB1cat.AMPKalpha_Tloop)
#   comments:
#    - The forward rate constant depends on the activation state of AMPK.
#    - Association is faster (by assumption) when AMPK is activated by AMP.
#
#   AMPKa2b1g1
#
#STK11(CAMK)+PRKAA2(T172~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)->\
#STK11(CAMK!3).PRKAA2(T172~0!3,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0) kf_AMPK_LKB1_slow
#    Site3~P
#STK11(CAMK)+PRKAA2(T172~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)->\
#STK11(CAMK!3).PRKAA2(T172~0!3,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P) kf_AMPK_LKB1_slow
#    Site3~ATP
#STK11(CAMK)+PRKAA2(T172~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)->\
#STK11(CAMK!3).PRKAA2(T172~0!3,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP) kf_AMPK_LKB1_slow
#    Site3~AMP
#STK11(CAMK)+PRKAA2(T172~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)->\
#STK11(CAMK!3).PRKAA2(T172~0!3,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP) kf_AMPK_LKB1_slow
#    Site3~AMP_RIM2
#STK11(CAMK)+PRKAA2(T172~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)->\
#STK11(CAMK!3).PRKAA2(T172~0!3,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2) kf_AMPK_LKB1_fast
#
#   AMPKa2b2g1
#    Site3~0
#STK11(CAMK)+PRKAA2(T172~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)->\
#STK11(CAMK!3).PRKAA2(T172~0!3,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0) kf_AMPK_LKB1_slow
#    Site3~P
#STK11(CAMK)+PRKAA2(T172~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)->\
#STK11(CAMK!3).PRKAA2(T172~0!3,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P) kf_AMPK_LKB1_slow
#    Site3~ATP
#STK11(CAMK)+PRKAA2(T172~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)->\
#STK11(CAMK!3).PRKAA2(T172~0!3,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP) kf_AMPK_LKB1_slow
#    Site3~AMP
#STK11(CAMK)+PRKAA2(T172~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)->\
#STK11(CAMK!3).PRKAA2(T172~0!3,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP) kf_AMPK_LKB1_slow
#    Site3~AMP_RIM2
#STK11(CAMK)+PRKAA2(T172~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)->\
#STK11(CAMK!3).PRKAA2(T172~0!3,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2) kf_AMPK_LKB1_fast
#
#  dissociation of substrate (without phosphorylation)
#   comments:
#    - We assume that dissociation is not affected by the activation state of AMPK.
#
#   AMPKa2
#STK11(CAMK!1).PRKAA2(T172~0!1)->STK11(CAMK)+PRKAA2(T172~0) kr_AMPK_LKB1
#
#  phosphorylation, followed very closely by dissociation of product
#   comments:
#    - We assume that the catalytic step is not affected by the activation state of AMPK.
#
#   AMPKa2
#STK11(CAMK!1).PRKAA2(T172~0!1)->STK11(CAMK)+PRKAA2(T172~P) kcat_AMPK_LKB1

# dephosphorylation of T-loop in AMPK's catalytic subunit
#  AMPKa1b1g1
#   Site3~0
PRKAA1(T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)->\
PRKAA1(T183~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0) kfast_dephosT_AMPKa1b1g1
#   Site3~P
PRKAA1(T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)->\
PRKAA1(T183~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P) kfast_dephosT_AMPKa1b1g1
#   Site3~ATP
PRKAA1(T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)->\
PRKAA1(T183~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP) kfast_dephosT_AMPKa1b1g1
#   Site3~AMP
PRKAA1(T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)->\
PRKAA1(T183~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP) kfast_dephosT_AMPKa1b1g1
#   Site3~AMP_RIM2
PRKAA1(T183~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)->\
PRKAA1(T183~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2) kslow_dephosT_AMPKa1b1g1
#  AMPKa1b2g1
#   Site3~0
PRKAA1(T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)->\
PRKAA1(T183~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0) kfast_dephosT_AMPKa1b2g1
#   Site3~P
PRKAA1(T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)->\
PRKAA1(T183~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P) kfast_dephosT_AMPKa1b2g1
#   Site3~ATP
PRKAA1(T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)->\
PRKAA1(T183~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP) kfast_dephosT_AMPKa1b2g1
#   Site3~AMP
PRKAA1(T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP)->\
PRKAA1(T183~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP) kfast_dephosT_AMPKa1b2g1
#   Site3~AMP_RIM2
PRKAA1(T183~P,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2)->\
PRKAA1(T183~0,CTD!1).PRKAB2(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~AMP_RIM2) kslow_dephosT_AMPKa1b2g1
#  AMPKa2b1g1
#   Site3~0
#PRKAA2(T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0)->\
#PRKAA2(T172~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~0) kfast_dephosT_AMPKa2b1g1
#   Site3~P
#PRKAA2(T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P)->\
#PRKAA2(T172~0,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~P) kfast_dephosT_AMPKa2b1g1
#   Site3~ATP
#PRKAA2(T172~P,CTD!1).PRKAB1(CTD_alpha!1,CTD_gamma!2).PRKAG1(CBS1!2,Site3~ATP)->\
