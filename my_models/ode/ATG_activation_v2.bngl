# factor that converts abundance as measured by iBAQ value to copies per cell
#  The iBAQ value of a protein is proportional to its molar abundance.
iBAQ_to_cpc 0.02*f

# convert from log10(iBAQ) to copies per cell
ATG13_cpc_U2OS=iBAQ_to_cpc*10^ATG13_iBAQ3_U2OS
ATG101_cpc_U2OS=iBAQ_to_cpc*10^ATG101_iBAQ3_U2OS
RB1CC1_cpc_U2OS=iBAQ_to_cpc*10^RB1CC1_iBAQ3_U2OS
ULK1_cpc_U2OS=iBAQ_to_cpc*10^ULK1_iBAQ3_U2OS  

AMBRA1_cpc_U2OS=iBAQ_to_cpc*10^AMBRA1_iBAQ3_U2OS
