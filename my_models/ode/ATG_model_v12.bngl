begin reaction rules
0->counter() 1 # track time
####################################
# Model for starvation experiments #
####################################
# AA-dependent recruitment of X to omegasomes
sX(loc~0)<->sX(loc~1) salpha(),c # Recall that salpha()=
# X-controlled PG synthesis
0->sPG() ksyn_sX1()
# maturation (the rate of maturation is saturable)
sPG()->sAP() SatRate_div_sPG() # rate=[sPG]*SatRate_div_sPG()
# autophagosome clearance
sAP()->0 delta*toggle() # rate=delta*[sAP()] if toggle()=1; rate=0 if toggle()=0
######################################
# Model for restimulation experiment #
######################################
# AA-dependent recruitment of X to omegasomes
rX(loc~0)<->rX(loc~1) ralpha(),c # Recall that ralpha()=
# X-controlled PG synthesis
0->rPG() ksyn_rX1()
# maturation (the rate of maturation is saturable)
rPG()->rAP() SatRate_div_rPG() # rate=[rPG]*SatRate_div_rPG()
# autophagosome clearance
rAP()->0 delta*toggle() # rate=delta*[rAP()] if toggle()=1; rate=0 if toggle()=0
end reaction rules
end model
begin actions
# All output GDAT files contain simulation data for the restimulation experiment.
# Each output GDAT files contains simulation data for a specific starvation experiment.
# The suffix of the GDAT file identifies the starvation experiment.
generate_network({overwrite=>1})
# For a starvation experiment, the initial condition is the nutrient-replete steady state.
# For the restimulation experiment, the initial condition is the fully starved steady state.
saveParameters()
saveConcentrations()
#
#############################################
# simulation of AA restimulation experiment #
#############################################
# rAAinit=0
# rAAterm=100
resetConcentrations()
simulate({suffix=>"supplementAA_100",method=>"ode",t_start=>0,t_end=>120,n_steps=>12,print_functions=>1})
#####################################################
# simulations of AA starvation experiments (-BafA1) #
#####################################################
# plusBafA1=0
# sAAinit=100
# sAAterm=(as indicated)
setParameter("plusBafA1",0) # -BafA1
resetConcentrations()
setParameter("sAAterm",0) # AA=0% 
simulate({suffix=>"starveAA_0_noBafA1",method=>"ode",t_start=>0,t_end=>360,n_steps=>36,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",1) # AA=1%
simulate({suffix=>"starveAA_1_noBafA1",method=>"ode",t_start=>0,t_end=>360,n_steps=>36,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",5) # AA=5%
simulate({suffix=>"starveAA_5_noBafA1",method=>"ode",t_start=>0,t_end=>360,n_steps=>36,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",7) # AA=7%
simulate({suffix=>"starveAA_7_noBafA1",method=>"ode",t_start=>0,t_end=>360,n_steps=>36,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",10) # AA=10%
simulate({suffix=>"starveAA_10_noBafA1",method=>"ode",t_start=>0,t_end=>360,n_steps=>36,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",100) # AA=100%
simulate({suffix=>"starveAA_100_noBafA1",method=>"ode",t_start=>0,t_end=>360,n_steps=>36,print_functions=>1})
###################################################################
# simulations of AA starvation experiments (+BafA1), 0 to 120 min #
###################################################################
# plusBafA1=1
# sAAinit=100
# sAAterm=(as indicated)
# t=0 to 120 min
setParameter("plusBafA1",1)
resetConcentrations()
setParameter("sAAterm",0) # AA=0%
simulate({suffix=>"starveAA_0_plusBafA1_0to120",method=>"ode",t_start=>0,t_end=>120,n_steps=>12,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",1) # AA=1% 
simulate({suffix=>"starveAA_1_plusBafA1_0to120",method=>"ode",t_start=>0,t_end=>120,n_steps=>12,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",5) # AA=5%
simulate({suffix=>"starveAA_5_plusBafA1_0to120",method=>"ode",t_start=>0,t_end=>120,n_steps=>12,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",7) # AA=7%
simulate({suffix=>"starveAA_7_plusBafA1_0to120",method=>"ode",t_start=>0,t_end=>120,n_steps=>12,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",10) # AA=10%
simulate({suffix=>"starveAA_10_plusBafA1_0to120",method=>"ode",t_start=>0,t_end=>120,n_steps=>12,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",100) # AA=100%
simulate({suffix=>"starveAA_100_plusBafA1_0to120",method=>"ode",t_start=>0,t_end=>120,n_steps=>12,print_functions=>1})
#####################################################################
# simulations of AA starvation experiments (+BafA1), 120 to 240 min #
#####################################################################
# plusBafA1=2
# sAAinit=100
# sAAterm=(as indicated)
# t=0 to 240 min
setParameter("plusBafA1",2)
resetConcentrations()
setParameter("sAAterm",0) # AA=0%
simulate({suffix=>"starveAA_0_plusBafA1_120to240",method=>"ode",t_start=>0,t_end=>240,n_steps=>24,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",1) # AA=1% 
simulate({suffix=>"starveAA_1_plusBafA1_120to240",method=>"ode",t_start=>0,t_end=>240,n_steps=>24,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",5) # AA=5%
simulate({suffix=>"starveAA_5_plusBafA1_120to240",method=>"ode",t_start=>0,t_end=>240,n_steps=>24,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",7) # AA=7%
simulate({suffix=>"starveAA_7_plusBafA1_120to240",method=>"ode",t_start=>0,t_end=>240,n_steps=>24,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",10) # AA=10% 
simulate({suffix=>"starveAA_10_plusBafA1_120to240",method=>"ode",t_start=>0,t_end=>240,n_steps=>24,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",100) # AA=100%
simulate({suffix=>"starveAA_100_plusBafA1_120to240",method=>"ode",t_start=>0,t_end=>240,n_steps=>24,print_functions=>1})
#####################################################################
# simulations of AA starvation experiments (+BafA1), 240 to 360 min #
#####################################################################
# plusBafA1=3
# sAAinit=100
# sAAterm=(as indicated)
# t=240 to 360 min
setParameter("plusBafA1",3)
resetConcentrations()
setParameter("sAAterm",0) # AA=0%
simulate({suffix=>"starveAA_0_plusBafA1_240to360",method=>"ode",t_start=>0,t_end=>360,n_steps=>36,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",1) # AA=1% 
simulate({suffix=>"starveAA_1_plusBafA1_240to360",method=>"ode",t_start=>0,t_end=>360,n_steps=>36,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",5) # AA=5%
simulate({suffix=>"starveAA_5_plusBafA1_240to360",method=>"ode",t_start=>0,t_end=>360,n_steps=>36,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",7) # AA=7%
simulate({suffix=>"starveAA_7_plusBafA1_240to360",method=>"ode",t_start=>0,t_end=>360,n_steps=>36,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",10) # AA=10% 
simulate({suffix=>"starveAA_10_plusBafA1_240to360",method=>"ode",t_start=>0,t_end=>360,n_steps=>36,print_functions=>1})
resetConcentrations()
setParameter("sAAterm",100) # AA=100% 
simulate({suffix=>"starveAA_100_plusBafA1_240to360",method=>"ode",t_start=>0,t_end=>360,n_steps=>36,print_functions=>1})
end actions