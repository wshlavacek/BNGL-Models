begin model
# This BNGL file defines two models.
# One is used to simulate multiple starvation (s) experiments.
# The other is used to simulate one restimulation (r) experiment.
# The simulations of starvation experiments are partially defined in the actions block.
# PG = phagophore
# AP = autophagosome
begin parameters
# Fixed parameters (4): XT, AAmax
# Constrained parameters (3): n, k, ksyn=chi/XT
# Adjustable parameters (6): chi:=ksyn*XT, a, b, c, r, delta, PGmin, PGmax
# PGstationary_sigma0 = PGbaseline__FREE
# PGstationary_sigma1 = PGbaseline__FREE+PGdelta__FREE
########## BEST-FIT PARAMETER VALUES ##########
# objective function value = 75,921
PGbaseline__FREE 1.0012889151372875
PGdelta__FREE 12.120702494169034
a__FREE 0.061982316168408984
b__FREE 4.082378262912279
c__FREE 0.027206941385495106
chi__FREE 0.9804864009687888
delta__FREE 0.03551124041882026
r__FREE 3137.6285990798024
########## BEST-FIT PARAMETER VALUES ##########
# We assume that there is a factor X that controls the rate of PG synthesis.
# We assume that X trafficks between the cytosol (loc~0) and omegasomes (loc~1).
# There is basal trafficking.
# There is starvation-induced recruitment of X to omegasomes.
# Total cellualar abundance of X
# This setting is arbitrary.
XT 4e4 # copies per cell (typical abundance for a signaling protein)
# The rate of PG synthesis is taken to be ksyn*[X(loc~1)].
# chi:=ksyn*XT 
chi chi__FREE # (molecules/cell)/min
# rate constant for X-dependent PG synthesis
ksyn=chi/XT # /min
# rate constant for basal recruitment of X to omegasomes
a a__FREE # /min
# maximum rate constant for AA-dependent recruitment of X to omegasomes
# AA-dependent rate constant is b*max(0,(AAmax-AA)/AAmax)
b b__FREE # /min
# nutrient threshold above which autophagy is minimal and no longer regulated
AAmax 12 # percent
# rate constant for release of X from omegasomes (recruitment is reversible)
c c__FREE # /min
# maximum rate of PG maturation
# r must be greater than ksyn*XT*(a+b)/(a+b+c)=chi*(a+b/(a+b+c)
r r__FREE # (molecules/cell)/min
# steady-state value of [PG] at no starvation (sigma=0)
PG_stationary_sigma0 PGbaseline__FREE # copies per cell
# steady-state value of [PG] at full starvation (sigma=1)
PG_stationary_sigma1 PGbaseline__FREE+PGdelta__FREE # copies per cell
# ratio
rho=PG_stationary_sigma1/PG_stationary_sigma0 # dimensionless
# We set n and k for consistency with PG_stationary_sigma0/1 
# Hill number n
x1_0=a/(a+c) # x1_0 is fraction of X at omegasomes (loc~1) when sigma=0 (no starvation)
x1_1=(a+b)/(a+b+c) # x1_1 is the same quantity but when sigma=1 (full starvation)
n=ln((r*x1_1-chi*x1_0*x1_1)/(r*x1_0-chi*x1_0*x1_1))/ln(rho) # dimensionless
# Hill constant k
k=(PG_stationary_sigma0^n*(r-chi*x1_0)/(chi*x1_0))^(1/n) # copies per cell
# rate constant for AP clearance
delta delta__FREE # /min
# indicator function for presence/absence of BafA1
# NB: this setting is adjusted in the actions block.
# =0: absent
# =1: added at t=0
# =2: added at t=120 min
# =3: added at t=240 min
plusBafA1 0 
# initial AA level in s and r experiments
sAAinit 100 # nutrient replete condition for t<0
rAAinit 0 # starvation condition for t<0
# terminal AA level in s and r experiments
# NB: the setting for sAAterm is changed in the actions block.
sAAterm 0 # full starvation for t>=0
rAAterm 100 # nutrient replete for t>=0
# initial condition for a starvation (s) experiment
sX0init=XT*c/(a+b*max(0,(AAmax-sAAinit)/AAmax)+c) # nutrient replete 
sX1init=XT-sX0init # nutrient replete 
sPGinit=(k^n*((ksyn*sX1init)/(r-ksyn*sX1init)))^(1/n)
sAPinit=ksyn*sX1init/delta
# initial condition for a restimulation (r) experiment
rX0init=XT*c/(a+b*max(0,(AAmax-rAAinit)/AAmax)+c) # starved
rX1init=XT-rX0init # starved
rPGinit=(k^n*((ksyn*rX1init)/(r-ksyn*rX1init)))^(1/n)
rAPinit=ksyn*rX1init/delta
end parameters
begin molecule types
counter()
sX(loc~0~1)
sPG()
sAP()
rX(loc~0~1)
rPG()
rAP()
end molecule types
begin seed species
counter() 0
sX(loc~0) sX0init
sX(loc~1) sX1init
sPG() sPGinit 
sAP() sAPinit
rX(loc~0) rX0init
rX(loc~1) rX1init
rPG() rPGinit
rAP() rAPinit
end seed species
begin observables
Molecules t counter() # time
Molecules sPG sPG()
Molecules sAP sAP()
Molecules sX1 sX(loc~1)
Molecules rPG rPG()
Molecules rAP rAP()
Molecules rX1 rX(loc~1)
# redundant - these observable names are used as labels in EXP files
Molecules PG sPG()
Molecules AP sAP()
Molecules PG0 rPG()
end observables
begin functions
ratio_r_div_chiTerm()=r/(chi*(a+b)/(a+b+c)) # sanity check, ratio should be >1
x1_0_calc()=x1_0 # =a/(a+c), fracton of X localized to omegasomes when sigma=0 (no starvation)
x1_1_calc()=x1_1 # =(a+b)/(a+b+c), fraction of X localized to omegasomes when sigma=1 (full starvation)
n_calc()=n # calculated value of n, which depends on r, chi, rho, a, b, c
k_calc()=k # calculated value of k, which depends on r, n, chi, a, c, PG_stationary_sigma0
PG_sigma0()=(k^n*((chi*a/(a+c))/(r-chi*a/(a+c))))^(1/n) # sanity check, value should equal PG_stationary_sigma0
PG_sigma1()=(k^n*((chi*(a+b)/(a+b+c))/(r-chi*(a+b)/(a+b+c))))^(1/n) # sanity check, value should equal PG_stationary_sigma1
# toggle() accounts for effect of BafA1 (if present). BafA1 treatment blocks AP clearance.
toggle()=if(plusBafA1==1 && t>=0,0,\
if(plusBafA1==2 && t>=120,0,\
if(plusBafA1==3 && t>=240,0,1)))
# parameters for simulating a starvation experiment
salpha()=a+b*max(0,(AAmax-sAAterm)/AAmax) 
ksyn_sX1()=ksyn*XT*salpha()/(salpha()+c)-(ksyn*XT*salpha()/(salpha()+c)-ksyn*sX1init)*exp(-t*(salpha()+c))
SatRate_div_sPG()=r*sPG^(n-1)/(sPG^n+k^n)
sATG_flux()=r*PG^n/(sPG^n+k^n) # (number of APs synthesized per cell)/min
# parameters for simulating the restimulation experiment
ralpha()=a+b*max(0,(AAmax-rAAterm)/AAmax) 
ksyn_rX1()=ksyn*XT*ralpha()/(ralpha()+c)-(ksyn*XT*ralpha()/(ralpha()+c)-ksyn*rX1init)*exp(-t*(ralpha()+c))
SatRate_div_rPG()=r*rPG^(n-1)/(rPG^n+k^n)
rATG_flux()=r*rPG^n/(rPG^n+k^n) # (number of APs synthesized per cell)/min
########
# Data #
########
