PIK3CD(RB)		PIK3CD_total	
PIK3CG(RB)		PIK3CG_total	
PLCE1(RA,RasGEF)	PLCE1_total	
RALGDS(RA)		RALGDS_total	
RGL1(RA)		RGL1_total	
RGL2(RA)		RGL2_total	
RGL3(RA)		RGL3_total	
