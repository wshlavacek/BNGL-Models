RIN2(RA)		RIN2_total	
RIN3(RA)		RIN3_total	
TIAM1(RB)		TIAM1_total	


end seed species

########################################################################################################

begin observables

# Ratio of Ras-GTP to Ras-GDP in cells is about 1 to 10 in normal cells (Bollag et al 1996 Nature Genetics): 10% RAS-GTP
# This ratio increases in leukemia to 1 in 5 (Bollag et al 1996 Nature Genetics): 20% RAS-GTP
# Donovan et al 2002 Biochimica et Biophysica Act also has a table with some % binding info:
# % of RAS that is GTP bound for Pro-61 = 16%, Trp-61 = 24%, His-61=32%, Arg-61=36%, Lys-61=61%, Leu-61=54%, Gln-61=1%
Molecules	RAS_switch_free		KRAS(switch),HRAS(switch),NRAS(switch)
Molecules	RASGTP_free			KRAS(switch,G~GTP),HRAS(switch,G~GTP),NRAS(switch,G~GTP)
Molecules	GEF_bound_RASGTP	SOS(cat!1).KRAS(switch!1,G~GTP),SOS(cat!1).HRAS(switch!1,G~GTP),SOS(cat!1).NRAS(switch!1,G~GTP)
Molecules	GAP_bound_RASGTP	NF1(RasGAP!1).KRAS(switch!1,G~GTP),NF1(RasGAP!1).HRAS(switch!1,G~GTP),NF1(RasGAP!1).NRAS(switch!1,G~GTP)
Molecules	GTP_bound_RAS		KRAS(G~GTP),HRAS(G~GTP),NRAS(G~GTP) 
Molecules	GDP_bound_RAS		KRAS(G~GDP),HRAS(G~GDP),NRAS(G~GDP)
Molecules	RAS_bound_SOS_allo	SOS(all!1).KRAS(switch!1,G~GTP),SOS(all!1).HRAS(switch!1,G~GTP),SOS(all!1).NRAS(switch!1,G~GTP) 
Molecules	GTP_free		GTP()
Molecules	GDP_free		GDP()
Molecules	GTP_all GTP(), KRAS(G~GTP),HRAS(G~GTP),NRAS(G~GTP)
Molecules	GDP_all GDP(), KRAS(G~GDP),HRAS(G~GDP),NRAS(G~GDP)
Molecules	RAS_all KRAS(),HRAS(),NRAS()

Molecules	ARAF_recruited		ARAF(RB!+)
Molecules	BRAF_recruited		BRAF(RB!+)
Molecules	CRAF_recruited		CRAF(RB!+)
Molecules	AFADIN_recruited	AFADIN(RA1!+)
Molecules	RASSF1_recruited	RASSF1(RA!+)
Molecules	RASSF2_recruited	RASSF2(RA!+)
Molecules	RASSF4_recruited	RASSF4(RA!+)
Molecules	RASSF5_recruited	RASSF5(RA!+)
Molecules	RASSF9_recruited	RASSF9(RA!+)
Molecules	PIK3CA_recruited	PIK3CA(RB!+)
Molecules	PIK3CD_recruited	PIK3CD(RB!+)
Molecules	PIK3CG_recruited	PIK3CG(RB!+)
Molecules	PLCE1_recruited		PLCE1(RA!+)
Molecules	RALGDS_recruited	RALGDS(RA!+)
Molecules	RGL1_recruited		RGL1(RA!+)
Molecules	RGL2_recruited		RGL2(RA!+)
Molecules	RGL3_recruited		RGL3(RA!+)
Molecules	RASIP1_recruited	RASIP1(RA!+)
Molecules	RGS12_recruited		RGS12(RB!+)
Molecules	RGS14_recruited		RGS14(RB!+)
Molecules	RIN1_recruited		RIN1(RA!+)
Molecules	RIN2_recruited		RIN2(RA!+)
Molecules	RIN3_recruited		RIN3(RA!+)
Molecules	TIAM1_recruited		TIAM1(RB!+)


end observables

########################################################################################################

begin functions

ratio_GTP_GDP() GTP_all/GDP_all # this should be around 10
perc_activated_RAS() GTP_bound_RAS/RAS_all # this should be around 5-10% in normal cells and 20-60% in cells with oncogenic RAS

end functions

########################################################################################################

begin reaction rules

# GDP to GTP conversion (by things like NDP kinase, not explicitly considered here)
GDP() -> GTP() ksynGTP

##### GTP/GDP binding apo RAS #####
KRAS(G~apo,switch) + GTP() <-> KRAS(G~GTP,switch) kaGTPKRAS,kdGTPKRAS
KRAS(G~apo,switch) + GDP() <-> KRAS(G~GDP,switch) kaGDPKRAS,kdGDPKRAS
HRAS(G~apo,switch) + GTP() <-> HRAS(G~GTP,switch) kaGTPHRAS,kdGTPHRAS
HRAS(G~apo,switch) + GDP() <-> HRAS(G~GDP,switch) kaGDPHRAS,kdGDPHRAS
NRAS(G~apo,switch) + GTP() <-> NRAS(G~GTP,switch) kaGTPNRAS,kdGTPNRAS
NRAS(G~apo,switch) + GDP() <-> NRAS(G~GDP,switch) kaGDPNRAS,kdGDPNRAS

##### Intrinsic GTPase activity by RAS #####
KRAS(G~GTP,switch) -> KRAS(G~GDP,switch) khydKRAS
HRAS(G~GTP,switch) -> HRAS(G~GDP,switch) khydHRAS
NRAS(G~GTP,switch) -> NRAS(G~GDP,switch) khydNRAS

##### GAP activity #####
# GTP hydrolysis to GDP by the Ras-GAP NF1
# binding of GAP to RAS
KRAS(G~GTP,switch) + NF1(RasGAP) <-> KRAS(G~GTP,switch!0).NF1(RasGAP!0) kaGAP_KRAS, kdGAP
HRAS(G~GTP,switch) + NF1(RasGAP) <-> HRAS(G~GTP,switch!0).NF1(RasGAP!0) kaGAP_HRAS, kdGAP
NRAS(G~GTP,switch) + NF1(RasGAP) <-> NRAS(G~GTP,switch!0).NF1(RasGAP!0) kaGAP_NRAS, kdGAP

# Hydrolysis catalyzed by GAP
# Q: Includes dissociation of GAP? Or should this be separate?
KRAS(G~GTP,switch!0).NF1(RasGAP!0) -> KRAS(G~GDP,switch) + NF1(RasGAP) khydGAP_KRAS
HRAS(G~GTP,switch!0).NF1(RasGAP!0) -> HRAS(G~GDP,switch) + NF1(RasGAP) khydGAP_HRAS
NRAS(G~GTP,switch!0).NF1(RasGAP!0) -> NRAS(G~GDP,switch) + NF1(RasGAP) khydGAP_NRAS

##### GEF activity #####
# Binding/unbinding of GEF to Ras
# Q: should GEF be able to bind to Ras(G~apo)? Yes.
# Assuming whether or not SOS is allosterically activated doesnt matter
KRAS(G~GDP,switch) + SOS(cat) <-> KRAS(G~GDP,switch!1).SOS(cat!1) kaGEF,kdGEF
KRAS(G~GTP,switch) + SOS(cat) <-> KRAS(G~GTP,switch!1).SOS(cat!1) kaGEF,kdGEF
HRAS(G~GDP,switch) + SOS(cat) <-> HRAS(G~GDP,switch!1).SOS(cat!1) kaGEF,kdGEF
HRAS(G~GTP,switch) + SOS(cat) <-> HRAS(G~GTP,switch!1).SOS(cat!1) kaGEF,kdGEF
NRAS(G~GDP,switch) + SOS(cat) <-> NRAS(G~GDP,switch!1).SOS(cat!1) kaGEF,kdGEF
NRAS(G~GTP,switch) + SOS(cat) <-> NRAS(G~GTP,switch!1).SOS(cat!1) kaGEF,kdGEF
HRAS(G~apo,switch) + SOS(cat) <-> HRAS(G~GTP,switch!1).SOS(cat!1) kaGEF,kdGEF
NRAS(G~apo,switch) + SOS(cat) <-> NRAS(G~GDP,switch!1).SOS(cat!1) kaGEF,kdGEF
NRAS(G~apo,switch) + SOS(cat) <-> NRAS(G~GTP,switch!1).SOS(cat!1) kaGEF,kdGEF

# GEF promotes nucleotide dissociation. 
# Nucleotides are allowed to re-associate with the Ras-GEF complex. 
# Q: does GEF promote dissociation of both GTP and GDP? We assume it does.
KRAS(G~GDP,switch!1).SOS(cat!1) <-> KRAS(G~apo,switch!1).SOS(cat!1) + GDP() kdGDPGEF,kaGDPGEFKRAS
KRAS(G~GTP,switch!1).SOS(cat!1) <-> KRAS(G~apo,switch!1).SOS(cat!1) + GTP() kdGTPGEF,kaGTPGEF
HRAS(G~GDP,switch!1).SOS(cat!1) <-> HRAS(G~apo,switch!1).SOS(cat!1) + GDP() kdGDPGEF,kaGDPGEFHRAS
HRAS(G~GTP,switch!1).SOS(cat!1) <-> HRAS(G~apo,switch!1).SOS(cat!1) + GTP() kdGTPGEF,kaGTPGEF
NRAS(G~GDP,switch!1).SOS(cat!1) <-> NRAS(G~apo,switch!1).SOS(cat!1) + GDP() kdGDPGEF,kaGDPGEFNRAS
NRAS(G~GTP,switch!1).SOS(cat!1) <-> NRAS(G~apo,switch!1).SOS(cat!1) + GTP() kdGTPGEF,kaGTPGEF

##### SOS positive feedback #####
# RasGTP binds to SOS allosteric site
KRAS(G~GTP,switch) + SOS(all) <-> KRAS(G~GTP,switch!1).SOS(all!1) kaGEF,kdGEF
HRAS(G~GTP,switch) + SOS(all) <-> HRAS(G~GTP,switch!1).SOS(all!1) kaGEF,kdGEF
NRAS(G~GTP,switch) + SOS(all) <-> NRAS(G~GTP,switch!1).SOS(all!1) kaGEF,kdGEF
# RasGDP binds to SOS allosteric site
KRAS(G~GDP,switch) + SOS(all) <-> KRAS(G~GDP,switch!1).SOS(all!1) kaGEF,kdGEF
HRAS(G~GDP,switch) + SOS(all) <-> HRAS(G~GDP,switch!1).SOS(all!1) kaGEF,kdGEF
NRAS(G~GDP,switch) + SOS(all) <-> NRAS(G~GDP,switch!1).SOS(all!1) kaGEF,kdGEF

# RasGTP bound to SOS allosteric site increases GEF activity by factor phi
# KRAS as substrate
KRAS(G~GDP,switch!1).SOS(all!0,cat!1).KRAS(G~GTP,switch!0) <-> KRAS(G~apo,switch!1).SOS(all!0,cat!1).KRAS(G~GTP,switch!0) + GDP() phi*kdGDPGEF,kaGDPGEFKRAS
KRAS(G~GTP,switch!1).SOS(all!0,cat!1).KRAS(G~GTP,switch!0) <-> KRAS(G~apo,switch!1).SOS(all!0,cat!1).KRAS(G~GTP,switch!0) + GTP() phi*kdGTPGEF,kaGTPGEF
KRAS(G~GDP,switch!1).SOS(all!0,cat!1).HRAS(G~GTP,switch!0) <-> KRAS(G~apo,switch!1).SOS(all!0,cat!1).HRAS(G~GTP,switch!0) + GDP() phi*kdGDPGEF,kaGDPGEFKRAS
KRAS(G~GTP,switch!1).SOS(all!0,cat!1).HRAS(G~GTP,switch!0) <-> KRAS(G~apo,switch!1).SOS(all!0,cat!1).HRAS(G~GTP,switch!0) + GTP() phi*kdGTPGEF,kaGTPGEF
KRAS(G~GDP,switch!1).SOS(all!0,cat!1).NRAS(G~GTP,switch!0) <-> KRAS(G~apo,switch!1).SOS(all!0,cat!1).NRAS(G~GTP,switch!0) + GDP() phi*kdGDPGEF,kaGDPGEFKRAS
KRAS(G~GTP,switch!1).SOS(all!0,cat!1).NRAS(G~GTP,switch!0) <-> KRAS(G~apo,switch!1).SOS(all!0,cat!1).NRAS(G~GTP,switch!0) + GTP() phi*kdGTPGEF,kaGTPGEF
# HRAS as substrate
HRAS(G~GDP,switch!1).SOS(all!0,cat!1).KRAS(G~GTP,switch!0) <-> HRAS(G~apo,switch!1).SOS(all!0,cat!1).KRAS(G~GTP,switch!0) + GDP() phi*kdGDPGEF,kaGDPGEFHRAS
HRAS(G~GTP,switch!1).SOS(all!0,cat!1).KRAS(G~GTP,switch!0) <-> HRAS(G~apo,switch!1).SOS(all!0,cat!1).KRAS(G~GTP,switch!0) + GTP() phi*kdGTPGEF,kaGTPGEF
HRAS(G~GDP,switch!1).SOS(all!0,cat!1).HRAS(G~GTP,switch!0) <-> HRAS(G~apo,switch!1).SOS(all!0,cat!1).HRAS(G~GTP,switch!0) + GDP() phi*kdGDPGEF,kaGDPGEFHRAS
HRAS(G~GTP,switch!1).SOS(all!0,cat!1).HRAS(G~GTP,switch!0) <-> HRAS(G~apo,switch!1).SOS(all!0,cat!1).HRAS(G~GTP,switch!0) + GTP() phi*kdGTPGEF,kaGTPGEF
HRAS(G~GDP,switch!1).SOS(all!0,cat!1).NRAS(G~GTP,switch!0) <-> HRAS(G~apo,switch!1).SOS(all!0,cat!1).NRAS(G~GTP,switch!0) + GDP() phi*kdGDPGEF,kaGDPGEFHRAS
HRAS(G~GTP,switch!1).SOS(all!0,cat!1).NRAS(G~GTP,switch!0) <-> HRAS(G~apo,switch!1).SOS(all!0,cat!1).NRAS(G~GTP,switch!0) + GTP() phi*kdGTPGEF,kaGTPGEF
# NRAS as substrate
NRAS(G~GDP,switch!1).SOS(all!0,cat!1).KRAS(G~GTP,switch!0) <-> NRAS(G~apo,switch!1).SOS(all!0,cat!1).KRAS(G~GTP,switch!0) + GDP() phi*kdGDPGEF,kaGDPGEFNRAS
NRAS(G~GTP,switch!1).SOS(all!0,cat!1).KRAS(G~GTP,switch!0) <-> NRAS(G~apo,switch!1).SOS(all!0,cat!1).KRAS(G~GTP,switch!0) + GTP() phi*kdGTPGEF,kaGTPGEF
NRAS(G~GDP,switch!1).SOS(all!0,cat!1).HRAS(G~GTP,switch!0) <-> NRAS(G~apo,switch!1).SOS(all!0,cat!1).HRAS(G~GTP,switch!0) + GDP() phi*kdGDPGEF,kaGDPGEFNRAS
NRAS(G~GTP,switch!1).SOS(all!0,cat!1).HRAS(G~GTP,switch!0) <-> NRAS(G~apo,switch!1).SOS(all!0,cat!1).HRAS(G~GTP,switch!0) + GTP() phi*kdGTPGEF,kaGTPGEF
NRAS(G~GDP,switch!1).SOS(all!0,cat!1).NRAS(G~GTP,switch!0) <-> NRAS(G~apo,switch!1).SOS(all!0,cat!1).NRAS(G~GTP,switch!0) + GDP() phi*kdGDPGEF,kaGDPGEFNRAS
NRAS(G~GTP,switch!1).SOS(all!0,cat!1).NRAS(G~GTP,switch!0) <-> NRAS(G~apo,switch!1).SOS(all!0,cat!1).NRAS(G~GTP,switch!0) + GTP() phi*kdGTPGEF,kaGTPGEF

# RasGDP bound to SOS allosteric site increases GEF activity by factor phi
# KRAS as substrate
KRAS(G~GDP,switch!1).SOS(all!0,cat!1).KRAS(G~GDP,switch!0) <-> KRAS(G~apo,switch!1).SOS(all!0,cat!1).KRAS(G~GDP,switch!0) + GDP() phi_GDP*kdGDPGEF,kaGDPGEFKRAS
KRAS(G~GTP,switch!1).SOS(all!0,cat!1).KRAS(G~GDP,switch!0) <-> KRAS(G~apo,switch!1).SOS(all!0,cat!1).KRAS(G~GDP,switch!0) + GTP() phi_GDP*kdGTPGEF,kaGTPGEF
KRAS(G~GDP,switch!1).SOS(all!0,cat!1).HRAS(G~GDP,switch!0) <-> KRAS(G~apo,switch!1).SOS(all!0,cat!1).HRAS(G~GDP,switch!0) + GDP() phi_GDP*kdGDPGEF,kaGDPGEFKRAS
KRAS(G~GTP,switch!1).SOS(all!0,cat!1).HRAS(G~GDP,switch!0) <-> KRAS(G~apo,switch!1).SOS(all!0,cat!1).HRAS(G~GDP,switch!0) + GTP() phi_GDP*kdGTPGEF,kaGTPGEF
KRAS(G~GDP,switch!1).SOS(all!0,cat!1).NRAS(G~GDP,switch!0) <-> KRAS(G~apo,switch!1).SOS(all!0,cat!1).NRAS(G~GDP,switch!0) + GDP() phi_GDP*kdGDPGEF,kaGDPGEFKRAS
KRAS(G~GTP,switch!1).SOS(all!0,cat!1).NRAS(G~GDP,switch!0) <-> KRAS(G~apo,switch!1).SOS(all!0,cat!1).NRAS(G~GDP,switch!0) + GTP() phi_GDP*kdGTPGEF,kaGTPGEF
# HRAS as substrate
HRAS(G~GDP,switch!1).SOS(all!0,cat!1).KRAS(G~GDP,switch!0) <-> HRAS(G~apo,switch!1).SOS(all!0,cat!1).KRAS(G~GDP,switch!0) + GDP() phi_GDP*kdGDPGEF,kaGDPGEFHRAS
HRAS(G~GTP,switch!1).SOS(all!0,cat!1).KRAS(G~GDP,switch!0) <-> HRAS(G~apo,switch!1).SOS(all!0,cat!1).KRAS(G~GDP,switch!0) + GTP() phi_GDP*kdGTPGEF,kaGTPGEF
HRAS(G~GDP,switch!1).SOS(all!0,cat!1).HRAS(G~GDP,switch!0) <-> HRAS(G~apo,switch!1).SOS(all!0,cat!1).HRAS(G~GDP,switch!0) + GDP() phi_GDP*kdGDPGEF,kaGDPGEFHRAS
HRAS(G~GTP,switch!1).SOS(all!0,cat!1).HRAS(G~GDP,switch!0) <-> HRAS(G~apo,switch!1).SOS(all!0,cat!1).HRAS(G~GDP,switch!0) + GTP() phi_GDP*kdGTPGEF,kaGTPGEF
HRAS(G~GDP,switch!1).SOS(all!0,cat!1).NRAS(G~GDP,switch!0) <-> HRAS(G~apo,switch!1).SOS(all!0,cat!1).NRAS(G~GDP,switch!0) + GDP() phi_GDP*kdGDPGEF,kaGDPGEFHRAS
HRAS(G~GTP,switch!1).SOS(all!0,cat!1).NRAS(G~GDP,switch!0) <-> HRAS(G~apo,switch!1).SOS(all!0,cat!1).NRAS(G~GDP,switch!0) + GTP() phi_GDP*kdGTPGEF,kaGTPGEF
# NRAS as substrate
NRAS(G~GDP,switch!1).SOS(all!0,cat!1).KRAS(G~GDP,switch!0) <-> NRAS(G~apo,switch!1).SOS(all!0,cat!1).KRAS(G~GDP,switch!0) + GDP() phi_GDP*kdGDPGEF,kaGDPGEFNRAS
NRAS(G~GTP,switch!1).SOS(all!0,cat!1).KRAS(G~GDP,switch!0) <-> NRAS(G~apo,switch!1).SOS(all!0,cat!1).KRAS(G~GDP,switch!0) + GTP() phi_GDP*kdGTPGEF,kaGTPGEF
NRAS(G~GDP,switch!1).SOS(all!0,cat!1).HRAS(G~GDP,switch!0) <-> NRAS(G~apo,switch!1).SOS(all!0,cat!1).HRAS(G~GDP,switch!0) + GDP() phi_GDP*kdGDPGEF,kaGDPGEFNRAS
NRAS(G~GTP,switch!1).SOS(all!0,cat!1).HRAS(G~GDP,switch!0) <-> NRAS(G~apo,switch!1).SOS(all!0,cat!1).HRAS(G~GDP,switch!0) + GTP() phi_GDP*kdGTPGEF,kaGTPGEF
NRAS(G~GDP,switch!1).SOS(all!0,cat!1).NRAS(G~GDP,switch!0) <-> NRAS(G~apo,switch!1).SOS(all!0,cat!1).NRAS(G~GDP,switch!0) + GDP() phi_GDP*kdGDPGEF,kaGDPGEFNRAS
NRAS(G~GTP,switch!1).SOS(all!0,cat!1).NRAS(G~GDP,switch!0) <-> NRAS(G~apo,switch!1).SOS(all!0,cat!1).NRAS(G~GDP,switch!0) + GTP() phi_GDP*kdGTPGEF,kaGTPGEF

###### Effectors binding RAS-GTP ######
# KRAS binding effectors
KRAS(G~GTP,switch) + ARAF(RB) <-> KRAS(G~GTP,switch!0).ARAF(RB!0) kon_universal,koff_ARAF_KRAS 
KRAS(G~GTP,switch) + BRAF(RB) <-> KRAS(G~GTP,switch!0).BRAF(RB!0) kon_universal,koff_BRAF_KRAS  
KRAS(G~GTP,switch) + CRAF(RB) <-> KRAS(G~GTP,switch!0).CRAF(RB!0) kon_universal,koff_CRAF_KRAS  
KRAS(G~GTP,switch) + AFADIN(RA1) <-> KRAS(G~GTP,switch!0).AFADIN(RA1!0) kon_universal,koff_AFADIN_KRAS  
KRAS(G~GTP,switch) + RASSF1(RA) <-> KRAS(G~GTP,switch!0).RASSF1(RA!0) kon_universal,koff_RASSF1_KRAS  
KRAS(G~GTP,switch) + RASSF2(RA) <-> KRAS(G~GTP,switch!0).RASSF2(RA!0) kon_universal,koff_RASSF2_KRAS  
KRAS(G~GTP,switch) + RASSF4(RA) <-> KRAS(G~GTP,switch!0).RASSF4(RA!0) kon_universal,koff_RASSF4_KRAS  
KRAS(G~GTP,switch) + RASSF5(RA) <-> KRAS(G~GTP,switch!0).RASSF5(RA!0) kon_universal,koff_RASSF5_KRAS  
KRAS(G~GTP,switch) + RASSF9(RA) <-> KRAS(G~GTP,switch!0).RASSF9(RA!0) kon_universal,koff_RASSF9_KRAS 
KRAS(G~GTP,switch) + PIK3CA(RB) <-> KRAS(G~GTP,switch!0).PIK3CA(RB!0) kon_universal,koff_PIK3CA_KRAS  
KRAS(G~GTP,switch) + PIK3CD(RB) <-> KRAS(G~GTP,switch!0).PIK3CD(RB!0) kon_universal,koff_PIK3CD_KRAS  
KRAS(G~GTP,switch) + PIK3CG(RB) <-> KRAS(G~GTP,switch!0).PIK3CG(RB!0) kon_universal,koff_PIK3CG_KRAS  
KRAS(G~GTP,switch) + PLCE1(RA) <-> KRAS(G~GTP,switch!0).PLCE1(RA!0) kon_universal,koff_PLCE1_KRAS  
KRAS(G~GTP,switch) + RALGDS(RA) <-> KRAS(G~GTP,switch!0).RALGDS(RA!0) kon_universal,koff_RALGDS_KRAS  
KRAS(G~GTP,switch) + RGL1(RA) <-> KRAS(G~GTP,switch!0).RGL1(RA!0) kon_universal,koff_RGL1_KRAS  
KRAS(G~GTP,switch) + RGL2(RA) <-> KRAS(G~GTP,switch!0).RGL2(RA!0) kon_universal,koff_RGL2_KRAS  
KRAS(G~GTP,switch) + RGL3(RA) <-> KRAS(G~GTP,switch!0).RGL3(RA!0) kon_universal,koff_RGL3_KRAS  
KRAS(G~GTP,switch) + RASIP1(RA) <-> KRAS(G~GTP,switch!0).RASIP1(RA!0) kon_universal,koff_RASIP1_KRAS  
KRAS(G~GTP,switch) + RGS12(RB) <-> KRAS(G~GTP,switch!0).RGS12(RB!0) kon_universal,koff_RGS12_KRAS  
