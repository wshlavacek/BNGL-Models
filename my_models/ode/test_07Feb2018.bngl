begin model
begin parameters
NA 6.02214e23 # molecules per mol
V 1e-12 # L per cell
kf 1e6/(NA*V) # /M/s
kr 0.01 # /s
end parameters
begin molecule types
A(s)
B(s)
end molecule types
begin seed species
A(s) 1e4
B(s) 1e4
end seed species
begin observables
Species Afree A(s)
Species Bfree B(s)
Species C A(s!1).B(s!1)
end observables
begin reaction rules
LineLabelRevRule: A(s)+B(s)<->A(s!1).B(s!1) kf,kr
end reaction rules
end model
begin actions
generate_network({overwrite=>1})
simulate({method=>"ode",t_end=>100,n_steps=>100})
visualize({type=>"contactmap"})
visualize({type=>"ruleviz_pattern"})
visualize({type=>"ruleviz_operation"})
end actions