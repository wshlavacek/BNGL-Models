# simplified version of HIV dynamics model from Hlavacek WS et al. (2000) PNAS 97: 10966-10971
# Default parameter settings are for Patient 20485

begin model
begin parameters
# Avogadro constant
NA 6.02214076e23 # molecules per mol
# volume of extracellular fluid per body
Vecf 15 # L
# zero-order rate constant for de novo generation of target cells
lambda 0 # 7.2e8 # cells per body per d
# rate constant for proliferation of target cells
p 0.01 # /d 
# target cell carrying capacity
Tc 2.9e11 # cells per body
# rate constant for target cell death
mu 0.0038 # /d
# rate constant for death of productively infected cells
delta 2.7 # /d
# efficiency of reverse transcriptase inhibitor (0 if absent, 1 if present)
er 0 # dimensionless
# efficiency of protease inhibitor (0 if absent, 1 if present)
ep 0 # dimensionless
# rate constant for death of chronically infected cells
muC 0.0035 # /d
# rate constant for generation of productively infected cells
k 6.8e-12 # cells per body per d
# rate constant for generation of chronically infected cells
kC 2.9e-16 # cells per body per d
# rate constant for viral clearance
c 34 # /d
# number of virions generated by a productively infected cell over its lifetime
N 49
# therapeutic antibody binding parameters
# equilibrium dissociation constant
KD 1e-11*(NA*Vecf) # convert M to molecules per body
koff 1e-3*3600*24 # convert /s to /d
kon = koff/KD # (molecules/body)/d
# initial number of uninfected target cells
T0=c/(k*N*(1-er)) # 1.020e11, 9.9e10 in Table 1
# initial number of free viral particles
V0=(p*(1-T0/Tc)-mu)/((1-er)*(k+kC)) # 3.943e8, 4.1e8 in Table 1
# initial number of productively infected cells
P0=(1-er)*k*V0*T0/delta # 1.013e8, 1.1e8 in Table 1
# initial number of chronically infected cells
C0=(1-er)*kC*V0*T0/muC # 3.334e6, 3.0e6 in Table 1
# number of complement receptors (CD21) on FDCs in tissue
R0 1.8e12 # molecules per body
# number of therapeutic antibodies
#A0 5.6e18 # molecules per body, based on 20 mg/kg body weight dose, 150,000 g/mol molecular weight, 70 kg/body, yields >>99% occupancy
#A0 = KD*99 # yields 99% occupancy of CD21
A0 0 # no anti-CD21
# effective forward rate constant for virus capture
alpha 1.5e-10 # /d
# rate constant for virus release
kr 8600/4 # /d
kmx = kr
# crosslinking rate constant
kpx = 40*kmx/R0 # /(molecule/body)/d
end parameters
begin molecule types
T() # target cell
P() # productively infected cell
C() # chronically infected cell
V(C3,C3,viable~T~F) # virion
R(s) # complement receptor (CD21)
A(s) # anti-CD21 therapeutic antibody
end molecule types
begin seed species
T() T0
P() P0
C() C0
V(C3,C3,viable~T) V0
A(s) A0
R(s) R0
end seed species
begin observables
Molecules T T()
Molecules P P()
Molecules C C()
Species pVL_infectious V(C3,C3,viable~T)
Species pVL_inf_plus_noninf V(C3,C3)
Species FDC_bound_virus V(C3!1,C3).R(s!1) V(C3!1,C3!2).R(s!1).R(s!2)
Molecules V_all V()
Molecules freeA A(s)
Molecules freeR R(s)
Molecules ARcomplex A(s!1).R(s!1)
end observables
begin functions
proliferate()=p*(1-T/Tc)
infect_P()=(1-er)*k*pVL_infectious
infect_C()=(1-er)*kC*pVL_infectious
birth()=N*delta*P
#zero_V0()=N*delta*P0-c*V0
#zero_V()=N*delta*P-c*pVL
#zero_P0()=(1-er)*k*V0*T0-delta*P0
#zero_C0()=(1-er)*kC*V0*T0-muC*C0
#zero_T0()=lambda+p*T0*(1-T0/Tc)-mu*T0-(1-er)*(k+kC)*V0*T0
#zero_T()=lambda+p*T*(1-T/Tc)-mu*T-(1-er)*(k+kC)*pVL*T
#synT()=lambda+p*T*(1-T/Tc)
#degT()=mu*T+(1-er)*(k+kC)*T*V0
#diff()=synT()-degT()
#T0_func()=T0
#V0_func()=V0
end functions
begin reaction rules
# de novo generation of target cells
0->T() lambda
# proliferation of target cells
T()->T()+T() proliferate()
# target cell death
T()->0 mu
# infection of target cells
#  generation of productively infected cells
T()->P() infect_P()
#  generation of chronically infected cells
T()->C() infect_C()
# death of productively infected cells
P()->0 delta
# death of chronically infected cells
C()->0 muC
# viral generation
0->V(C3,C3,viable~T) (1-ep)*birth()
0->V(C3,C3,viable~F) ep*birth()
# viral clearance
V(C3,C3)->0 c
# interaction of anti-CD21 with CD21
A(s)+R(s)<->A(s!1).R(s!1) kon,koff
# capture-release of virions from FDC surfaces in tissues via C3-CD21 interaction
V(C3,C3)+R(s)<->V(C3!1,C3).R(s!1) alpha,kr
V(C3!+,C3)+R(s)<->V(C3!+,C3!1).R(s!1) kpx,kmx
end reaction rules
end model
begin actions
generate_network({overwrite=>1})
# 12 weeks is 84 days is 2016 hours.
simulate({method=>"ode",t_start=>0,t_end=>84,n_steps=>2016,print_functions=>1})
end actions