# Translation of Boolean model in Full Boolean T-Cell Model.txt to BNGL format within the GSP (Gillespie) update mode.
begin model
begin parameters
	x	1
end parameters
begin molecule types
   tcr(state~0~1)
   tcr_low(state~0~1)
   tcr_high(state~0~1)
   cd28(state~0~1)
   tgfbeta(state~0~1)
   il2(state~0~1)
   il2r(state~0~1)
   ap1(state~0~1)
   fos(state~0~1)
   fos_d(state~0~1)
   fos_dd(state~0~1)
   fos_ddd(state~0~1)
   jun(state~0~1)
   erk(state~0~1)
   mek2(state~0~1)
   tak1(state~0~1)
   mkk7(state~0~1)
   jnk(state~0~1)
   raf(state~0~1)
   ras(state~0~1)
   ca(state~0~1)
   nfat(state~0~1)
   pkctheta(state~0~1)
   nfkappab(state~0~1)
   akt(state~0~1)
   mtorc1(state~0~1)
