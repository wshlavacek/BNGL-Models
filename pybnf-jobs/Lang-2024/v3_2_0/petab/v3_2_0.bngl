begin observables
	# --- species sums that enter the 8 nuclear observation functions ---
	Species tCCNA   CCNA()                          # total cyclin A  (all CCNA species)
	Species tCCNB   CCNB()                          # total cyclin B1 (all CCNB species)
	Species tCCNE   CCNE()                          # total cyclin E  (all CCNE species)
	Species tSKP2   SKP2()                          # total Skp2
	Species tCDKN1A CDKN1A()                         # total p21 (all CDKN1A species)
	Species tCDKN1B CDKN1B()                         # total p27 (all CDKN1B species)
	Species pRB     RB1(E2F,Ser807_Ser811~p)         # phospho-RB (Ser807/811), free (only pRB species)
	Species tE2F    E2F()                            # total E2F1 (all E2F species)
	Species E2F_pSer332_prom E2F(DBD!+,RB1,Ser332~p) # E2F Ser332~p bound to a promoter (excluded from obs_E2F1)
end observables

begin functions
	# obs_X = offset o* + scale s* x (species sum).  Names/parens are the .exp column headers.
	obs_cycA__nuc_median()  = oCCNA + sCCNA*tCCNA
	obs_cycB1__nuc_median() = oCCNB + sCCNB*tCCNB
	obs_cycE__nuc_median()  = oCCNE + sCCNE*tCCNE
	obs_E2F1__nuc_median()  = oE2F + sE2F*(tE2F - E2F_pSer332_prom)
	obs_pRB__nuc_median()   = oRB1_pSer807Ser811 + sRB1_pSer807Ser811*pRB
	obs_Skp2__nuc_median()  = oSKP2 + sSKP2*tSKP2
	obs_p21__nuc_median()   = oCDKN1A + sCDKN1A*tCDKN1A
	obs_p27__nuc_median()   = oCDKN1B + sCDKN1B*tCDKN1B
end functions

begin reaction rules
    SyE2f1: 0  -> @cell:E2F(DBD,RB1,Ser332~u) kSyE2f1
	AspFoxPcb: @cell:FOXM1(DBD,Thr600~p) + CCNB_promoter(FOXM1) <-> @cell:FOXM1(DBD!1,Thr600~p).CCNB_promoter(FOXM1!1) kAsFPcb,kDiFPcb
